@{
    ViewData["Title"] = "QC Comparison";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="@Url.Content("~/js/i18n.js")"></script>
    <style>
        :root {
            --denim:        #1B4F8A;
            --denim-dark:   #0f2f52;
            --denim-mid:    #2563a8;
            --denim-light:  #dbeafe;
            --denim-xlight: #eff6ff;
            --white:        #ffffff;
            --gray-50:      #f8fafc;
            --gray-100:     #f1f5f9;
            --gray-200:     #e2e8f0;
            --gray-400:     #94a3b8;
            --gray-600:     #475569;
            --gray-800:     #1e293b;
            --success:      #10b981;
            --warning:      #f59e0b;
            --danger:       #ef4444;
            --shadow-sm:    0 1px 3px rgba(27,79,138,0.08);
            --shadow-md:    0 4px 20px rgba(27,79,138,0.12);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50); min-height: 100vh;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(27,79,138,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(37,99,168,0.05) 0%, transparent 50%);
        }

        /* ── PAGE WRAPPER ── */
        .page-wrapper { max-width: 1700px; margin: 0 auto; padding: 1.5rem 1rem; }
        @@media (min-width: 600px) { .page-wrapper { padding: 2rem 1.5rem; } }

        /* ── PAGE HEADER ── */
        .page-header { margin-bottom: 1.5rem; }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.7rem; font-weight: 700; color: var(--denim-dark);
            display: flex; align-items: center; gap: 10px;
        }
        .page-header p { color: var(--gray-600); font-size: 0.9rem; margin-top: 6px; }
        .header-line {
            width: 48px; height: 4px;
            background: linear-gradient(90deg, var(--denim), var(--denim-mid));
            border-radius: 2px; margin-top: 10px;
        }

        /* ── STEPS ── */
        .steps-grid {
            display: grid; grid-template-columns: 1fr;
            gap: 1rem; margin-bottom: 1.5rem;
        }
        @@media (min-width: 900px) { .steps-grid { grid-template-columns: 1fr 1fr; } }

        .step-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.1);
            box-shadow: var(--shadow-sm);
        }
        .step-card.done { border-color: var(--success); }
        .step-header {
            background: var(--denim-xlight); padding: 0.85rem 1.25rem;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid rgba(27,79,138,0.08);
        }
        .step-header.done { background: #ecfdf5; border-bottom-color: rgba(16,185,129,0.15); }
        .step-num {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--denim); color: var(--white);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Space Grotesk', sans-serif; font-size: 0.82rem; font-weight: 700;
            flex-shrink: 0;
        }
        .step-num.done { background: var(--success); }
        .step-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.92rem; font-weight: 600; color: var(--denim-dark);
        }
        .step-status { margin-left: auto; font-size: 0.75rem; font-weight: 600; color: var(--gray-400); }
        .step-status.done { color: var(--success); }
        .step-body { padding: 1.1rem 1.25rem; }

        /* ── FILTER GRID ── */
        .filter-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;
            margin-bottom: 1rem;
        }
        @@media (min-width: 600px) { .filter-grid { grid-template-columns: repeat(4, 1fr) auto; align-items: end; gap: 0.85rem; } }
        .filter-group { display: flex; flex-direction: column; gap: 4px; }
        .filter-group label {
            font-size: 0.72rem; font-weight: 600; color: var(--denim-dark);
            letter-spacing: 0.3px; text-transform: uppercase;
        }
        .filter-group select,
        .filter-group input[type="date"] {
            width: 100%; padding: 0.55rem 0.7rem;
            border: 1.5px solid var(--gray-200); border-radius: 8px;
            font-family: 'DM Sans', sans-serif; font-size: 0.85rem;
            color: var(--gray-800); background: var(--white);
            outline: none; transition: border-color 0.2s;
            min-height: 38px; cursor: pointer;
            appearance: none; -webkit-appearance: none;
        }
        .filter-group select:focus,
        .filter-group input[type="date"]:focus {
            border-color: var(--denim); box-shadow: 0 0 0 3px rgba(27,79,138,0.1);
        }

        /* ── BUTTONS ── */
        .btn {
            padding: 0.55rem 1.1rem; border-radius: 8px; border: none;
            font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600;
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-primary { background: var(--denim); color: var(--white); }
        .btn-primary:hover:not(:disabled) { background: var(--denim-dark); }
        .btn-compare {
            background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
            color: var(--white); font-size: 0.95rem; padding: 0.7rem 1.6rem;
        }
        .btn-compare:hover:not(:disabled) { filter: brightness(1.1); }
        .btn-success { background: #059669; color: var(--white); }
        .btn-success:hover:not(:disabled) { background: #047857; }
        .btn-outline { background: var(--white); color: var(--denim); border: 1.5px solid var(--denim-light); }
        .btn-outline:hover:not(:disabled) { background: var(--denim-xlight); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-sm { padding: 0.38rem 0.85rem; font-size: 0.8rem; }

        /* ── DATA PILLS ── */
        .data-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 4px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
        }
        .pill-sys  { background: var(--denim-xlight); color: var(--denim); }
        .pill-qc   { background: #fef3c7; color: #92400e; }
        .pill-both { background: #ecfdf5; color: #065f46; }

        /* ── UPLOAD ZONE ── */
        .upload-zone {
            border: 2px dashed var(--gray-200); border-radius: 12px;
            padding: 2rem; text-align: center; cursor: pointer;
            transition: all 0.2s; background: var(--white);
            position: relative;
        }
        .upload-zone:hover, .upload-zone.drag-over {
            border-color: var(--denim); background: var(--denim-xlight);
        }
        .upload-zone.has-file { border-color: var(--success); background: #f0fdf4; }
        .upload-zone input[type="file"] {
            position: absolute; inset: 0; opacity: 0; cursor: pointer;
        }
        .upload-icon { font-size: 2.2rem; margin-bottom: 0.5rem; }
        .upload-title { font-weight: 600; color: var(--denim-dark); font-size: 0.92rem; }
        .upload-sub { font-size: 0.78rem; color: var(--gray-400); margin-top: 4px; }
        .upload-filename {
            font-size: 0.85rem; font-weight: 600; color: var(--success);
            margin-top: 8px;
        }

        /* ── MAPPING PREVIEW ── */
        .mapping-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;
            margin-top: 0.85rem;
        }
        @@media (min-width: 600px) { .mapping-grid { grid-template-columns: repeat(5, 1fr); } }
        .mapping-item {
            background: var(--gray-50); border: 1px solid var(--gray-100);
            border-radius: 8px; padding: 6px 8px; font-size: 0.72rem;
        }
        .mapping-item .mi-label { color: var(--gray-400); font-weight: 600; text-transform: uppercase; font-size: 0.65rem; }
        .mapping-item .mi-col { color: var(--denim-dark); font-weight: 700; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .mapping-item.mapped { border-color: rgba(16,185,129,0.3); background: #f0fdf4; }
        .mapping-item.unmapped { border-color: rgba(239,68,68,0.3); background: #fef2f2; }

        /* ── COMPARE ACTION BAR ── */
        .action-bar {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm);
            padding: 1rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }
        .action-bar-left { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .action-bar-right { display: flex; align-items: center; gap: 8px; }

        /* ── KPI ── */
        .kpi-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem; margin-bottom: 1.5rem;
        }
        @@media (min-width: 600px) { .kpi-grid { grid-template-columns: repeat(4, 1fr); } }
        .kpi-card {
            background: var(--white); border-radius: 12px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm); padding: 1rem 1.1rem;
            display: flex; flex-direction: column; gap: 4px;
        }
        .kpi-label { font-size: 0.7rem; font-weight: 600; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.3px; }
        .kpi-value { font-family: 'Space Grotesk', sans-serif; font-size: 1.6rem; font-weight: 700; color: var(--denim-dark); }
        .kpi-value.green  { color: var(--success); }
        .kpi-value.orange { color: var(--warning); }
        .kpi-value.red    { color: var(--danger); }
        .kpi-sub { font-size: 0.75rem; color: var(--gray-400); }

        /* ── TABLE ── */
        .table-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 1.5rem;
        }
        .table-card-header {
            background: linear-gradient(135deg, var(--denim-dark) 0%, var(--denim) 100%);
            padding: 0.9rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; flex-wrap: wrap;
        }
        .table-card-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.92rem; font-weight: 600; color: var(--white);
            display: flex; align-items: center; gap: 8px;
        }
        .badge {
            background: rgba(255,255,255,0.2); color: var(--white);
            border-radius: 20px; padding: 2px 9px; font-size: 0.72rem; font-weight: 600;
        }
        .table-scroll { overflow-x: auto; }
        .cmp-table { width: 100%; border-collapse: collapse; font-size: 0.79rem; }

        /* Table headers */
        .cmp-table thead tr.th-group th {
            background: var(--denim-dark); color: rgba(255,255,255,0.7);
            padding: 5px 8px; text-align: center; font-size: 0.68rem;
            font-weight: 600; letter-spacing: 0.3px; text-transform: uppercase;
            border-right: 1px solid rgba(255,255,255,0.1);
        }
        .cmp-table thead tr.th-main th {
            background: var(--denim); color: var(--white);
            padding: 7px 9px; text-align: center; font-weight: 600;
            border-right: 1px solid rgba(255,255,255,0.15);
            white-space: nowrap; font-size: 0.75rem;
        }
        .cmp-table thead tr.th-main th.th-left { text-align: left; }
        .cmp-table thead tr.th-main th.th-metric-sys  { background: #1e4d8c; }
        .cmp-table thead tr.th-main th.th-metric-qc   { background: #92400e; }
        .cmp-table thead tr.th-main th.th-metric-gap  { background: #1e293b; }
        .cmp-table thead tr.th-group th.thg-identity  { background: var(--denim-dark); }
        .cmp-table thead tr.th-group th.thg-input      { background: #1e4d8c; }
        .cmp-table thead tr.th-group th.thg-ok         { background: #065f46; }
        .cmp-table thead tr.th-group th.thg-ng         { background: #7f1d1d; }
        .cmp-table thead tr.th-group th.thg-rate       { background: #1e293b; }

        /* Data rows */
        .cmp-table tbody td {
            padding: 7px 9px; border-bottom: 1px solid var(--gray-100);
            border-right: 1px solid var(--gray-100); vertical-align: middle; white-space: nowrap;
        }
        .cmp-table tbody tr:nth-child(even) td { background: #f8fafc; }
        .cmp-table tbody tr:hover td { background: var(--denim-xlight); }
        .cmp-table tbody tr.row-sys-only td { background: #eff6ff !important; }
        .cmp-table tbody tr.row-qc-only  td { background: #fff7ed !important; }
        .cmp-table tbody tr:hover.row-sys-only td,
        .cmp-table tbody tr:hover.row-qc-only  td { filter: brightness(0.96); }

        .td-num { text-align: right; font-variant-numeric: tabular-nums; }
        .td-center { text-align: center; }
        .td-zero { color: var(--gray-300); text-align: right; }

        /* Gap badges */
        .gap-badge {
            display: inline-block; padding: 1px 7px; border-radius: 10px;
            font-size: 0.72rem; font-weight: 700; font-variant-numeric: tabular-nums;
        }
        .gap-0    { background: #dcfce7; color: #166534; }
        .gap-low  { background: #fef9c3; color: #713f12; }
        .gap-high { background: #fee2e2; color: #991b1b; }
        .gap-na   { background: var(--gray-100); color: var(--gray-400); font-style: italic; font-weight: 400; }

        /* Source badges */
        .src-badge {
            display: inline-block; padding: 1px 7px; border-radius: 10px;
            font-size: 0.7rem; font-weight: 700;
        }
        .src-both { background: #dcfce7; color: #166534; }
        .src-sys  { background: var(--denim-xlight); color: var(--denim); }
        .src-qc   { background: #fef3c7; color: #92400e; }

        /* Color tags */
        .color-tag { display: inline-block; padding: 2px 9px; border-radius: 20px; font-size: 0.69rem; font-weight: 600; white-space: nowrap; }
        .color-matte  { background: #1e293b; color: #fff; }
        .color-chrome { background: #e2e8f0; color: #1e293b; border: 1px solid #cbd5e1; }
        .color-brass  { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
        .color-beige  { background: #fef9c3; color: #713f12; border: 1px solid #fde68a; }
        .color-other  { background: var(--denim-xlight); color: var(--denim); }
        .color-none   { background: var(--gray-100); color: var(--gray-600); font-style: italic; }

        /* Total row */
        tr.total-row td {
            background: var(--denim-dark) !important; color: var(--white) !important;
            font-weight: 700;
        }

        /* ── FILTER TABS ── */
        .filter-tabs { display: flex; gap: 6px; margin-bottom: 1rem; flex-wrap: wrap; }
        .ftab {
            padding: 5px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
            cursor: pointer; border: 1.5px solid var(--gray-200); background: var(--white);
            color: var(--gray-600); transition: all 0.15s;
        }
        .ftab:hover { border-color: var(--denim); color: var(--denim); }
        .ftab.active { background: var(--denim); color: var(--white); border-color: var(--denim); }
        .ftab.tab-gap { border-color: #fde68a; color: #92400e; }
        .ftab.tab-gap.active { background: #f59e0b; border-color: #f59e0b; color: var(--white); }
        .ftab.tab-sys { border-color: var(--denim-light); color: var(--denim); }
        .ftab.tab-qc  { border-color: #fde68a; color: #92400e; }

        /* ── PAGINATION ── */
        .pagination-bar {
            padding: 0.85rem 1.5rem; border-top: 1px solid var(--gray-100);
            display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
        }
        .pagination-info { font-size: 0.8rem; color: var(--gray-600); }
        .pagination-controls { display: flex; gap: 4px; }
        .pg-btn {
            min-width: 30px; height: 30px; padding: 0 7px;
            border: 1.5px solid var(--gray-200); border-radius: 7px;
            background: var(--white); color: var(--gray-800);
            font-family: 'DM Sans', sans-serif; font-size: 0.8rem;
            cursor: pointer; transition: all 0.15s;
            display: flex; align-items: center; justify-content: center;
        }
        .pg-btn:hover:not(:disabled) { border-color: var(--denim); color: var(--denim); }
        .pg-btn.active { background: var(--denim); color: var(--white); border-color: var(--denim); font-weight: 700; }
        .pg-btn:disabled { opacity: 0.4; cursor: not-allowed; }

        /* ── EMPTY ── */
        .empty-state { padding: 3.5rem; text-align: center; color: var(--gray-400); }
        .empty-state .ei { font-size: 3rem; margin-bottom: 0.75rem; }
        .empty-state p { font-size: 0.9rem; }

        /* ── LOADING ── */
        .loading-overlay {
            position: fixed; inset: 0; background: rgba(15,47,82,0.4);
            display: flex; align-items: center; justify-content: center;
            z-index: 9999; opacity: 0; pointer-events: none; transition: opacity 0.2s;
        }
        .loading-overlay.show { opacity: 1; pointer-events: all; }
        .loading-box { background: var(--white); border-radius: 14px; padding: 2rem 2.5rem; text-align: center; box-shadow: var(--shadow-md); }
        .spinner { width: 38px; height: 38px; margin: 0 auto 0.9rem; border: 3px solid var(--denim-light); border-top-color: var(--denim); border-radius: 50%; animation: spin 0.8s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .loading-msg { color: var(--denim-dark); font-weight: 600; font-size: 0.88rem; }

        /* ── TOAST ── */
        .toast {
            position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9000;
            background: var(--white); border-radius: 10px; box-shadow: var(--shadow-md);
            padding: 0.8rem 1.2rem; display: flex; align-items: center; gap: 9px;
            min-width: 270px; opacity: 0; transform: translateY(10px);
            transition: opacity 0.25s, transform 0.25s; pointer-events: none;
        }
        .toast.show { opacity: 1; transform: translateY(0); pointer-events: all; }
        .toast.success { border-left: 4px solid var(--success); }
        .toast.error   { border-left: 4px solid var(--danger);  }
        .toast.info    { border-left: 4px solid var(--denim);   }
        #toastMsg { font-size: 0.85rem; color: var(--gray-800); }

        /* ── SHEET / COLUMN SELECTOR ── */
        .selector-panel {
            margin-top: 1rem; padding: 1rem; background: var(--gray-50);
            border: 1px solid var(--gray-200); border-radius: 10px;
            display: none;
        }
        .selector-panel.show { display: block; }
        .selector-section-title {
            font-size: 0.72rem; font-weight: 700; color: var(--denim-dark);
            text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 0.6rem;
        }
        .sheet-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1rem; }
        .sheet-tab {
            padding: 4px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
            cursor: pointer; border: 1.5px solid var(--gray-200);
            background: var(--white); color: var(--gray-600); transition: all 0.15s;
        }
        .sheet-tab:hover { border-color: var(--denim); color: var(--denim); }
        .sheet-tab.active { background: var(--denim); color: var(--white); border-color: var(--denim); }
        .col-map-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem;
        }
        @@media (min-width: 500px) { .col-map-grid { grid-template-columns: repeat(2, 1fr); } }
        @@media (min-width: 700px) { .col-map-grid { grid-template-columns: repeat(3, 1fr); } }
        @@media (min-width: 1000px) { .col-map-grid { grid-template-columns: repeat(4, 1fr); } }
        .col-map-item { display: flex; flex-direction: column; gap: 3px; }
        .col-map-item label {
            font-size: 0.68rem; font-weight: 700; color: var(--denim-dark);
            text-transform: uppercase; letter-spacing: 0.3px;
        }
        .col-map-item label .req { color: var(--danger); }
        .col-map-item select {
            padding: 0.4rem 0.6rem; border: 1.5px solid var(--gray-200); border-radius: 7px;
            font-family: 'DM Sans', sans-serif; font-size: 0.8rem; color: var(--gray-800);
            background: var(--white); outline: none; appearance: none; cursor: pointer;
            transition: border-color 0.2s;
        }
        .col-map-item select:focus { border-color: var(--denim); }
        .col-map-item select.mapped   { border-color: var(--success); background: #f0fdf4; }
        .col-map-item select.unmapped { border-color: #fca5a5; background: #fef2f2; }
        .preview-table-wrap { overflow-x: auto; margin-top: 0.85rem; max-height: 160px; overflow-y: auto; border-radius: 8px; border: 1px solid var(--gray-100); }
        .preview-table { width: 100%; border-collapse: collapse; font-size: 0.72rem; }
        .preview-table th { background: var(--denim); color: var(--white); padding: 5px 8px; white-space: nowrap; position: sticky; top: 0; }
        .preview-table td { padding: 4px 8px; border-bottom: 1px solid var(--gray-100); white-space: nowrap; }
        .preview-table tr:nth-child(even) td { background: var(--gray-50); }
        .confirm-row { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; flex-wrap: wrap; gap: 8px; }
        .parse-info  { font-size: 0.78rem; color: var(--gray-600); }

        /* ── THRESHOLD INPUT ── */
        .threshold-wrap {
            display: flex; align-items: center; gap: 8px;
            font-size: 0.8rem; color: var(--gray-600);
        }
        .threshold-wrap input[type="number"] {
            width: 60px; padding: 4px 6px; border: 1.5px solid var(--gray-200);
            border-radius: 6px; font-size: 0.8rem; text-align: center; outline: none;
        }
        .threshold-wrap input[type="number"]:focus { border-color: var(--denim); }
    </style>
</head>
<body>

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-box">
        <div class="spinner"></div>
        <p class="loading-msg" id="loadingMsg">Đang xử lý...</p>
    </div>
</div>
<div class="toast" id="toast">
    <span id="toastIcon"></span><span id="toastMsg"></span>
</div>

<div class="page-wrapper">

    <!-- ── HEADER ── -->
    <div class="page-header">
        <h1>⚖️ QC vs System — So Sánh Dữ Liệu</h1>
        <p>So sánh dữ liệu hệ thống (Yield Report) với file Excel từ bộ phận QC để xác định gap.</p>
        <div class="header-line"></div>
    </div>

    <!-- ── STEPS ── -->
    <div class="steps-grid">

        <!-- Step 1: System Data -->
        <div class="step-card" id="step1Card">
            <div class="step-header" id="step1Header">
                <div class="step-num" id="step1Num">1</div>
                <span class="step-title">Tải dữ liệu hệ thống</span>
                <span class="step-status" id="step1Status">Chưa tải</span>
            </div>
            <div class="step-body">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label>📅 Từ ngày</label>
                        <input type="date" id="fDateFrom" />
                    </div>
                    <div class="filter-group">
                        <label>📅 Đến ngày</label>
                        <input type="date" id="fDateTo" />
                    </div>
                    <div class="filter-group">
                        <label>⚙️ Công đoạn</label>
                        <select id="fProcess"><option value="">-- Tất cả --</option></select>
                    </div>
                    <div class="filter-group">
                        <label>🎨 Lớp phủ</label>
                        <select id="fColor"><option value="">-- Tất cả --</option></select>
                    </div>
                    <div class="filter-group" style="justify-content:flex-end">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary" id="btnLoadSys" onclick="loadSystemData()">
                            📡 Tải dữ liệu
                        </button>
                    </div>
                </div>
                <div id="sysInfo" style="font-size:0.8rem;color:var(--gray-400)">
                    Chọn khoảng ngày và nhấn Tải dữ liệu.
                </div>
            </div>
        </div>

        <!-- Step 2: QC Excel -->
        <div class="step-card" id="step2Card">
            <div class="step-header" id="step2Header">
                <div class="step-num" id="step2Num">2</div>
                <span class="step-title">Upload file Excel QC</span>
                <span class="step-status" id="step2Status">Chưa upload</span>
            </div>
            <div class="step-body">
                <div class="upload-zone" id="uploadZone">
                    <input type="file" id="qcFile" accept=".xlsx,.xls" onchange="handleFileUpload(this)" />
                    <div class="upload-icon">📂</div>
                    <div class="upload-title">Kéo thả hoặc click để chọn file Excel QC</div>
                    <div class="upload-sub">Cùng format với Yield Report · Tự động nhận diện</div>
                    <div class="upload-filename" id="uploadFilename"></div>
                </div>
                <div id="qcParseResult" style="display:none;margin-top:0.85rem;padding:0.75rem 1rem;background:var(--gray-50);border-radius:10px;border:1px solid var(--gray-100)">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
                        <span id="qcParseInfo" style="font-size:0.85rem;color:var(--gray-700)"></span>
                        <button class="btn btn-outline btn-sm" onclick="document.getElementById('qcFile').click()">🔄 Đổi file</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── QC DATA PREVIEW TABLE ── -->
    <div class="table-card" id="qcTableSection" style="display:none;margin-bottom:1.5rem">
        <div class="table-card-header">
            <h3>📋 Dữ liệu QC Excel — <span id="qcTableTitle">Raw Data</span>
                <span class="badge" id="qcTableBadge">0</span>
            </h3>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <span style="font-size:0.75rem;color:rgba(255,255,255,0.7)">Lọc so sánh:</span>
                <input type="date" id="qcFilterFrom" placeholder="Từ ngày"
                    style="padding:3px 7px;border-radius:6px;border:none;font-size:0.78rem;cursor:pointer"
                    onchange="applyQCDateFilter()" />
                <span style="color:rgba(255,255,255,0.6);font-size:0.78rem">→</span>
                <input type="date" id="qcFilterTo" placeholder="Đến ngày"
                    style="padding:3px 7px;border-radius:6px;border:none;font-size:0.78rem;cursor:pointer"
                    onchange="applyQCDateFilter()" />
                <button class="btn btn-outline btn-sm" onclick="applyQCDateFilter()" style="background:rgba(255,255,255,0.15);color:white;border-color:rgba(255,255,255,0.3)">
                    🔍 Lọc
                </button>
                <button class="btn btn-outline btn-sm" onclick="clearQCFilter()" style="background:transparent;color:rgba(255,255,255,0.6);border-color:rgba(255,255,255,0.2)">✕</button>
            </div>
        </div>
        <div class="table-scroll" id="qcTableScroll"></div>
        <div class="pagination-bar" id="qcPgBar" style="display:none">
            <div class="pagination-info" id="qcPgInfo"></div>
            <div class="pagination-controls" id="qcPgCtrl"></div>
        </div>
    </div>

    <!-- ── ACTION BAR ── -->
    <div class="action-bar">
        <div class="action-bar-left">
            <button class="btn btn-compare" id="btnCompare" onclick="runComparison()" disabled>
                ⚖️ Chạy So Sánh
            </button>
            <div class="threshold-wrap">
                <span>Ngưỡng gap:</span>
                <input type="number" id="gapThreshold" value="5" min="0" max="100" step="1" />
                <span>%</span>
            </div>
        </div>
        <div class="action-bar-right">
            <button class="btn btn-success btn-sm" id="btnExport" onclick="exportComparison()" disabled>
                📥 Xuất Excel So Sánh
            </button>
        </div>
    </div>

    <!-- ── KPI ── -->
    <div class="kpi-grid" id="kpiSection" style="display:none">
        <div class="kpi-card">
            <div class="kpi-label">Tổng cặp so sánh</div>
            <div class="kpi-value" id="kpiTotal">—</div>
            <div class="kpi-sub">Total matched + unmatched</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">✅ Khớp hoàn toàn</div>
            <div class="kpi-value green" id="kpiMatch">—</div>
            <div class="kpi-sub">Gap = 0 trên tất cả metrics</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">⚠️ Có gap</div>
            <div class="kpi-value orange" id="kpiGap">—</div>
            <div class="kpi-sub">Ít nhất 1 metric có gap</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">❌ Không match</div>
            <div class="kpi-value red" id="kpiUnmatched">—</div>
            <div class="kpi-sub">Chỉ có ở 1 nguồn</div>
        </div>
    </div>

    <!-- ── COMPARISON TABLE ── -->
    <div class="table-card" id="tableSection" style="display:none">
        <div class="table-card-header">
            <h3>
                ⚖️ Bảng So Sánh Chi Tiết
                <span class="badge" id="rowBadge">0</span>
            </h3>
            <div style="display:flex;gap:8px;align-items:center">
                <span style="font-size:0.75rem;color:rgba(255,255,255,0.7)">Lọc:</span>
                <button class="ftab active" onclick="setFilter('all')"     id="ftAll">Tất cả</button>
                <button class="ftab tab-gap" onclick="setFilter('gap')"   id="ftGap">Có gap</button>
                <button class="ftab tab-sys" onclick="setFilter('sysonly')" id="ftSys">Chỉ hệ thống</button>
                <button class="ftab tab-qc"  onclick="setFilter('qconly')"  id="ftQC">Chỉ QC</button>
            </div>
        </div>
        <div class="table-scroll" id="tableScroll">
            <div class="empty-state"><div class="ei">⚖️</div><p>Nhấn "Chạy So Sánh" để xem kết quả.</p></div>
        </div>
        <div class="pagination-bar" id="paginationBar" style="display:none">
            <div class="pagination-info" id="pgInfo"></div>
            <div class="pagination-controls" id="pgControls"></div>
        </div>
    </div>

</div>

@section Scripts {
<script>
const pathBase = '@Context.Request.PathBase';

/* ── State ─────────────────────────────────────────────────── */
let sysData      = [];   // from GetDefectReportData
let qcData       = [];   // parsed from uploaded Excel
let qcFiltered   = [];   // filtered by date
let cmpRows      = [];   // merged comparison rows
let filteredRows = [];   // after filter
let colMap       = {};   // QC Excel column mapping
let currentPage  = 1;
const PAGE_SIZE  = 30;
let activeFilter = 'all';

/* ── Init ───────────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', () => {
    const today = new Date(), from = new Date(today);
    from.setDate(today.getDate() - 1);
    document.getElementById('fDateTo').value   = fmtDate(today);
    document.getElementById('fDateFrom').value = fmtDate(from);
    loadFilters();
    setupDropZone();
});

function fmtDate(d) { return d.toISOString().split('T')[0]; }

async function loadFilters() {
    try {
        const [pr, cr] = await Promise.all([
            fetch(`${pathBase}/Production/GetProcesses`),
            fetch(`${pathBase}/Production/GetColors`)
        ]);
        const procs  = await pr.json();
        const colors = await cr.json();
        const ps = document.getElementById('fProcess');
        procs.forEach(p => { if (p) ps.insertAdjacentHTML('beforeend', `<option value="${esc(p)}">${esc(p)}</option>`); });
        const cs = document.getElementById('fColor');
        colors.forEach(c => { if (c) cs.insertAdjacentHTML('beforeend', `<option value="${esc(c)}">${esc(c)}</option>`); });
    } catch(e) { console.error(e); }
}

function setupDropZone() {
    const zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault(); zone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) processFile(file);
    });
}

/* ── Step 1: Load System Data ───────────────────────────────── */
async function loadSystemData() {
    const df = document.getElementById('fDateFrom').value;
    const dt = document.getElementById('fDateTo').value;
    const pr = document.getElementById('fProcess').value;
    const cl = document.getElementById('fColor').value;

    if (!df || !dt) { showToast('Vui lòng chọn khoảng ngày.', 'error'); return; }

    showLoading(true, 'Đang tải dữ liệu hệ thống...');
    document.getElementById('btnLoadSys').disabled = true;

    try {
        const params = new URLSearchParams({ dateFrom: df, dateTo: dt });
        if (pr) params.append('process', pr);
        if (cl) params.append('color', cl);

        const res  = await fetch(`${pathBase}/Production/GetDefectReportData?` + params);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        sysData = data.rows || [];

        setStep1Done(sysData.length);
        checkReadyToCompare();
        showToast(`Tải xong ${sysData.length} dòng từ hệ thống.`, 'success');
    } catch(e) {
        showToast('Lỗi tải dữ liệu: ' + e.message, 'error');
    } finally {
        showLoading(false);
        document.getElementById('btnLoadSys').disabled = false;
    }
}

function setStep1Done(count) {
    document.getElementById('step1Num').classList.add('done');
    document.getElementById('step1Header').classList.add('done');
    document.getElementById('step1Card').classList.add('done');
    document.getElementById('step1Status').className = 'step-status done';
    document.getElementById('step1Status').textContent = `✓ ${count} dòng`;
    document.getElementById('sysInfo').innerHTML = `
        <span class="data-pill pill-sys">🖥️ ${count} dòng từ hệ thống</span>
        &nbsp; từ ${document.getElementById('fDateFrom').value} đến ${document.getElementById('fDateTo').value}`;
}

/* ── Step 2: Upload QC Excel ────────────────────────────────── */
function handleFileUpload(input) {
    if (input.files[0]) processFile(input.files[0]);
}

function readSheetCells(ws) {
    if (!ws['!ref']) return [];
    const range = XLSX.utils.decode_range(ws['!ref']);
    const out   = [];
    for (let R = range.s.r; R <= range.e.r; R++) {
        const row = [];
        for (let C = range.s.c; C <= range.e.c; C++) {
            const addr = XLSX.utils.encode_cell({r: R, c: C});
            const cell = ws[addr];
            if (!cell || cell.v == null) { row.push(''); continue; }
            if (cell.t === 'd' || (cell.t === 'n' && cell.z && /[dDmMyY]/.test(String(cell.z)))) {
                row.push(cell.w || String(cell.v));
            } else {
                row.push(cell.v ?? '');
            }
        }
        out.push(row);
    }
    return out;
}

function processFile(file) {
    if (!file.name.match(/\.(xlsx|xls)$/i)) {
        showToast('Chỉ hỗ trợ file .xlsx hoặc .xls', 'error'); return;
    }
    showLoading(true, 'Đang đọc file Excel QC...');
    const reader = new FileReader();
    reader.onload = (e) => {
        try {
            const wb = XLSX.read(e.target.result, { type:'array', cellDates:true });

            let sheetName = wb.SheetNames[0];
            for (const n of wb.SheetNames) {
                if (n.toLowerCase().includes('raw')) { sheetName = n; break; }
            }

            const ws      = wb.Sheets[sheetName];
            const nonEmpty = readSheetCells(ws).filter(r => r.some(c => c !== '' && c != null));
            if (!nonEmpty.length) {
                showToast('Sheet không có dữ liệu.', 'error');
                showLoading(false); return;
            }

            _rawHeaders  = nonEmpty[0].map(h => {
                if (h instanceof Date) return formatDate(h);
                return String(h ?? '').trim();
            });
            _rawRows = nonEmpty.slice(1)
                .map(r => _rawHeaders.map((_, ci) => String(r[ci] ?? '')))
                .filter(r => parseRowDate(r[colMap.date ?? 0]));
            _sheetName = sheetName;

            const hdrIdx = 0;
            colMap = detectColumns(_rawHeaders);
            const rowsDates = XLSX.utils.sheet_to_json(wb.Sheets[sheetName], {header:1, defval:'', cellDates:true});
            const nonEmptyD = rowsDates.filter(r => r.some(c => c !== '' && c != null));
            qcData = parseQCRows(nonEmptyD, hdrIdx, colMap);
            qcFiltered = [...qcData];

            document.getElementById('uploadZone').classList.add('has-file');
            document.getElementById('uploadFilename').textContent = `📄 ${file.name}`;
            document.getElementById('qcParseResult').style.display = 'block';
            document.getElementById('qcParseInfo').innerHTML =
                `<span class="data-pill pill-qc">📋 ${_rawRows.length} dòng · ${_rawHeaders.length} cột · sheet "${sheetName}"</span>`;

            renderRawTable();
            setStep2Done(_rawRows.length);
            checkReadyToCompare();
            showToast(`Đọc xong ${_rawRows.length} dòng, ${_rawHeaders.length} cột.`, 'success');
        } catch(err) {
            showToast('Lỗi: ' + err.message, 'error');
            console.error(err);
        } finally { showLoading(false); }
    };
    reader.readAsArrayBuffer(file);
}

let _rawHeaders = [];
let _rawRows    = [];
let _sheetName  = '';
let _rawPage    = 1;
const RAW_PAGE  = 30;
let _rawFiltered = [];

function formatDate(d) {
    const M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return `${String(d.getUTCDate()).padStart(2,'0')}-${M[d.getUTCMonth()]}-${d.getUTCFullYear()}`;
}

function renderRawTable() {
    _rawFiltered = [..._rawRows];
    _rawPage = 1;
    document.getElementById('qcTableSection').style.display = 'block';
    document.getElementById('qcTableTitle').textContent = _sheetName;
    document.getElementById('qcTableBadge').textContent = _rawRows.length;
    const df = document.getElementById('fDateFrom').value;
    const dt = document.getElementById('fDateTo').value;
    if (df) document.getElementById('qcFilterFrom').value = df;
    if (dt) document.getElementById('qcFilterTo').value   = dt;
    if (df || dt) applyQCDateFilter();
    else renderRawPage();
    document.getElementById('qcTableSection').scrollIntoView({behavior:'smooth',block:'start'});
}

function applyQCDateFilter() {
    const df = document.getElementById('qcFilterFrom').value;
    const dt = document.getElementById('qcFilterTo').value;
    const dateColIdx = colMap.date ?? 0;

    if (!df && !dt) {
        _rawFiltered = [..._rawRows];
    } else {
        const from = df ? new Date(df + 'T00:00:00') : null;
        const to   = dt ? new Date(dt + 'T23:59:59') : null;
        _rawFiltered = _rawRows.filter(r => {
            const cellVal = r[dateColIdx];
            const d = parseRowDate(String(cellVal));
            if (!d) return true;
            if (from && d < from) return false;
            if (to   && d > to)   return false;
            return true;
        });
        qcFiltered = qcData.filter(r => {
            const d = parseRowDate(r.date);
            if (!d) return true;
            if (from && d < from) return false;
            if (to   && d > to)   return false;
            return true;
        });
    }
    _rawPage = 1;
    document.getElementById('qcTableBadge').textContent = _rawFiltered.length;
    renderRawPage();
    showToast(`Lọc: ${_rawFiltered.length} / ${_rawRows.length} dòng.`, 'info');
}

function clearQCFilter() {
    document.getElementById('qcFilterFrom').value = '';
    document.getElementById('qcFilterTo').value   = '';
    _rawFiltered = [..._rawRows];
    qcFiltered   = [...qcData];
    _rawPage = 1;
    document.getElementById('qcTableBadge').textContent = _rawRows.length;
    renderRawPage();
}

function renderRawPage() {
    const wrap  = document.getElementById('qcTableScroll');
    const pgBar = document.getElementById('qcPgBar');
    const total = _rawFiltered.length;

    if (!total) {
        wrap.innerHTML = `<div class="empty-state"><div class="ei">📭</div>
            <p>Không có dữ liệu. Thử nhấn ✕ xóa bộ lọc.</p></div>`;
        pgBar.style.display = 'none'; return;
    }
    pgBar.style.display = 'flex';
    const totalPages = Math.ceil(total / RAW_PAGE);
    const start = (_rawPage - 1) * RAW_PAGE;
    const slice = _rawFiltered.slice(start, start + RAW_PAGE);

    let html = `<table class="cmp-table"><thead><tr class="th-main">
        ${_rawHeaders.map((h,i) => {
            const isPurple = i >= 11;
            return `<th style="min-width:90px${isPurple?';background:#5b21b6':''}; white-space:normal; line-height:1.3">
                ${esc(h)||('Col '+(i+1))}
            </th>`;
        }).join('')}
    </tr></thead><tbody>`;

    slice.forEach(r => {
        html += '<tr>' + r.map((v, ci) => {
            if (v === '' || v == null) return `<td class="td-zero">—</td>`;
            const s = String(v);
            const cleanS = s.replace(/,/g,'').trim();
            const n = parseFloat(cleanS);
            const isNum = !isNaN(n) && /^-?[\d,\.%]+$/.test(cleanS);
            if (isNum) {
                if (ci === 9) {
                    const pct = n > 1 ? n : n*100;
                    const cls = pct>=10?'rate-bad':pct>=5?'rate-mid':'rate-ok';
                    return `<td class="td-center"><span class="rate-badge ${cls}">${pct.toFixed(1)}%</span></td>`;
                }
                if (ci === 10) {
                    const pct = n > 1 ? n : n*100;
                    const cls = pct<=90?'rate-bad':pct<=95?'rate-mid':'rate-ok';
                    return `<td class="td-center"><span class="rate-badge ${cls}">${pct.toFixed(1)}%</span></td>`;
                }
                if (ci >= 11) {
                    return n > 0
                        ? `<td class="td-num" style="color:#6d28d9;font-weight:700">${fmt(n)}</td>`
                        : `<td class="td-zero">—</td>`;
                }
                return `<td class="td-num">${fmt(n)}</td>`;
            }
            if (ci === 1) return `<td class="td-center" style="font-weight:700;color:var(--denim)">${esc(s)}</td>`;
            if (ci === 0) return `<td style="color:var(--gray-600);font-size:0.78rem">${esc(s)}</td>`;
            return `<td>${esc(s)}</td>`;
        }).join('') + '</tr>';
    });
    html += '</tbody></table>';
    wrap.innerHTML = html;

    const s2 = start+1, e2 = Math.min(start+RAW_PAGE, total);
    document.getElementById('qcPgInfo').textContent = `Hiển thị ${s2}–${e2} / ${total} dòng`;
    const ctrl = document.getElementById('qcPgCtrl');
    ctrl.innerHTML = '';
    const addBtn = (lbl,pg,dis,act) => {
        const b = document.createElement('button');
        b.className = 'pg-btn'+(act?' active':'');
        b.textContent = lbl; b.disabled = dis;
        b.onclick = () => { _rawPage = pg; renderRawPage(); };
        ctrl.appendChild(b);
    };
    addBtn('«',1,_rawPage===1,false);
    addBtn('‹',_rawPage-1,_rawPage===1,false);
    for (let p=Math.max(1,_rawPage-2);p<=Math.min(totalPages,_rawPage+2);p++) addBtn(p,p,false,p===_rawPage);
    addBtn('›',_rawPage+1,_rawPage===totalPages,false);
    addBtn('»',totalPages,_rawPage===totalPages,false);
}

function detectColumns(headers) {
    const find = (kws) => {
        const idx = headers.findIndex(h => kws.some(k => h.toLowerCase().includes(k)));
        return idx >= 0 ? idx : null;
    };
    return {
        date       : find(['date','ngày','日期']),
        partCode   : find(['part code','part_code','mã linh','零件']),
        product    : find(['product','sản phẩm','产品']),
        coating    : find(['coating','lớp phủ','涂层']),
        process    : find(['process','quy trình','công đoạn','工序']),
        inputQty   : find(['input qty','input_qty','sl đầu vào','投入量']),
        okQty      : find(['ok qty','ok_qty','sl đạt','良品数']),
        ngQty      : find(['ng qty','ng_qty','sl lỗi','不良数']),
        outputQty  : find(['output qty','output_qty','sl đầu ra','产出量']),
        defectRate : find(['defect rate','tỷ lệ lỗi','不良率']),
        yieldRate  : find(['yield rate','tỷ lệ đạt','良品率']),
    };
}

function parseRowDate(str) {
    if (!str) return null;
    if (str instanceof Date) return new Date(str.getFullYear(), str.getMonth(), str.getDate());
    const s = String(str).trim();
    const m1 = s.match(/^(\d{1,2})-([A-Za-z]{3})-(\d{4})$/);
    if (m1) {
        const mo = {jan:0,feb:1,mar:2,apr:3,may:4,jun:5,jul:6,aug:7,sep:8,oct:9,nov:10,dec:11}[m1[2].toLowerCase()];
        return mo != null ? new Date(+m1[3], mo, +m1[1]) : null;
    }
    const m2 = s.match(/^(\d{1,2})[\/-](\d{1,2})[\/-](\d{4})$/);
    if (m2) return new Date(+m2[3], +m2[2]-1, +m2[1]);
    const m3 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (m3) return new Date(+m3[1], +m3[2]-1, +m3[3]);
    return null;
}

function parseQCRows(rows, hdrIdx, cm) {
    const result  = [];
    const headers = rows[hdrIdx].map(h => String(h).trim());

    for (let i = hdrIdx + 1; i < rows.length; i++) {
        const r = rows[i];
        if (!r || r.every(c => c === '' || c == null)) continue;

        const dateRaw = cm.date != null ? r[cm.date] : '';
        const dateStr = normalizeDate(dateRaw);
        if (!dateStr) continue;

        const get    = (idx) => idx != null ? String(r[idx] ?? '').trim() : '';
        const getNum = (idx) => {
            if (idx == null) return 0;
            const v = r[idx];
            if (v === '' || v == null) return 0;
            const n = parseFloat(String(v).replace(/,/g,'').replace('%',''));
            return isNaN(n) ? 0 : n;
        };

        let defRate = getNum(cm.defectRate);
        let yldRate = getNum(cm.yieldRate);
        if (defRate <= 1 && defRate > 0) defRate = defRate * 100;
        if (yldRate <= 1 && yldRate > 0) yldRate = yldRate * 100;

        const fixedIdxs = new Set(Object.values(cm).filter(v => v != null));
        const extra = {};
        headers.forEach((h, ci) => {
            if (!fixedIdxs.has(ci) && h && r[ci] !== '' && r[ci] != null) {
                const v = r[ci];
                const n = parseFloat(String(v).replace(/,/g,''));
                extra[h] = isNaN(n) ? String(v) : n;
            }
        });

        result.push({
            date      : dateStr,
            rawDate   : dateRaw,
            partCode  : get(cm.partCode).toUpperCase(),
            product   : get(cm.product),
            coating   : get(cm.coating) || '-',
            process   : get(cm.process),
            inputQty  : getNum(cm.inputQty),
            okQty     : getNum(cm.okQty),
            ngQty     : getNum(cm.ngQty),
            outputQty : getNum(cm.outputQty),
            defectRate: +defRate.toFixed(1),
            yieldRate : +yldRate.toFixed(1),
            extra,
        });
    }
    return result;
}

function normalizeDate(raw) {
    if (!raw) return '';
    if (raw instanceof Date) {
        const M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        return `${String(raw.getUTCDate()).padStart(2,'0')}-${M[raw.getUTCMonth()]}-${raw.getUTCFullYear()}`;
    }
    const s = String(raw).trim();
    if (/^\d{1,2}-[A-Za-z]{3}-\d{4}$/.test(s)) return s;
    const m1 = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
    if (m1) {
        const d = new Date(+m1[3], +m1[2]-1, +m1[1]);
        return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).replace(/ /g, '-');
    }
    const m2 = s.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
    if (m2) {
        const d = new Date(+m2[1], +m2[2]-1, +m2[3]);
        return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).replace(/ /g, '-');
    }
    return s;
}

function setStep2Done(count) {
