/* ── Step 3: Run Comparison ─────────────────────────────────── */
function runComparison() {
    showLoading(true, 'Đang so sánh dữ liệu...');
    setTimeout(() => {
        try {
            cmpRows = mergeData(sysData, _rawFiltered.length > 0 ? qcFiltered : qcData);
            setActiveFilter('all');
            renderKPI();
            document.getElementById('kpiSection').style.display  = 'grid';
            document.getElementById('tableSection').style.display = 'block';
            document.getElementById('btnExport').disabled = false;
            showToast(`So sánh xong ${cmpRows.length} dòng.`, 'success');
        } catch(e) {
            showToast('Lỗi so sánh: ' + e.message, 'error');
        } finally {
            showLoading(false);
        }
    }, 50);
}

/* ═══════════════════════════════════════════════════════════════
   FIX: Normalize helpers — strip CJK chars, lowercase, no spaces
   Key = date + partCode + coating  (process removed from key)
   Fallback match: date + partCode only (when coating missing/differs)
   ═══════════════════════════════════════════════════════════════ */

/**
 * Strip CJK/Chinese characters and parenthetical blocks so that
 * "Planter Base (花盆底座)" and "Planter Base" compare as equal.
 */
function stripCJK(s) {
    return String(s || '')
        // Remove parentheses containing CJK characters
        .replace(/[\(\（][^\)\）]*[\u3000-\u9fff\uff00-\uffef][^\)\）]*[\)\）]/g, '')
        // Remove any remaining CJK unicode ranges
        .replace(/[\u3000-\u9fff\uff00-\uffef\u2e80-\u2eff\u31c0-\u31ef]/g, '')
        .trim();
}

/** Normalize coating: lowercase + strip spaces/hyphens/underscores */
function normalizeCoating(c) {
    return String(c || '').toLowerCase().replace(/[\s\-_]/g, '').trim();
}

/** Normalize part code: uppercase, trim */
function normalizePartCode(p) {
    return String(p || '').toUpperCase().trim();
}

/**
 * Primary match key: date + partCode + normalizedCoating
 * (Process intentionally excluded — QC and System often use different names)
 */
function makeKey(row) {
    const d  = normalizeDate(row.date || '');
    const p  = normalizePartCode(row.partCode);
    const ct = normalizeCoating(row.coating);
    return `${d}||${p}||${ct}`;
}

/** Fallback key: date + partCode only (when coating is blank or mismatched) */
function makePartKey(row) {
    const d = normalizeDate(row.date || '');
    const p = normalizePartCode(row.partCode);
    return `${d}||${p}`;
}

/* ── Merge / Match ───────────────────────────────────────────── */
function mergeData(sys, qc) {
    // ── Primary maps: date + partCode + coating ──
    const sysMap = new Map();
    sys.forEach(r => {
        const k = makeKey(r);
        if (!sysMap.has(k)) sysMap.set(k, []);
        sysMap.get(k).push(r);
    });

    const qcMap = new Map();
    qc.forEach(r => {
        const k = makeKey(r);
        if (!qcMap.has(k)) qcMap.set(k, []);
        qcMap.get(k).push(r);
    });

    // ── Fallback map: date + partCode (for coating-mismatch cases) ──
    const sysByPart = new Map();
    sys.forEach(r => {
        const k = makePartKey(r);
        if (!sysByPart.has(k)) sysByPart.set(k, []);
        sysByPart.get(k).push(r);
    });

    const allKeys     = new Set([...sysMap.keys(), ...qcMap.keys()]);
    const result      = [];
    const usedSysRows = new Set();  // prevent double-counting in fallback

    allKeys.forEach(k => {
        let sysRows    = sysMap.get(k) || [];
        const qcRows   = qcMap.get(k) || [];

        // Fallback: QC has rows but primary coating key found nothing in Sys
        if (qcRows.length > 0 && sysRows.length === 0) {
            const [datePart, partPart] = k.split('||');
            const fallKey = `${datePart}||${partPart}`;
            const candidates = (sysByPart.get(fallKey) || [])
                .filter(r => !usedSysRows.has(r));
            if (candidates.length > 0) sysRows = candidates;
        }

        const maxLen = Math.max(sysRows.length, qcRows.length);
        for (let i = 0; i < maxLen; i++) {
            const s = sysRows[i] || null;
            const q = qcRows[i]  || null;
            if (s) usedSysRows.add(s);

            const base = s || q;
            result.push({
                key     : k + '_' + i,
                date    : base.date,
                partCode: base.partCode,
                product : s?.product || q?.product || '',
                coating : s?.coating || q?.coating || '-',
                process : s?.process || q?.process || '',
                source  : s && q ? 'both' : s ? 'sys' : 'qc',
                sys     : s,
                qc      : q,
                gaps    : computeGaps(s, q),
            });
        }
    });

    return result.sort((a,b) => {
        if (a.date < b.date) return 1; if (a.date > b.date) return -1;
        return a.partCode.localeCompare(b.partCode);
    });
}

function computeGaps(s, q) {
    if (!s || !q) return null;
    const gap = (sv, qv) => {
        const diff = (sv||0) - (qv||0);
        const pct  = sv > 0 ? Math.abs(diff) / sv * 100 : (diff !== 0 ? 100 : 0);
        return { diff, pct: +pct.toFixed(1), sv: sv||0, qv: qv||0 };
    };
    return {
        inputQty  : gap(s.inputQty,   q.inputQty),
        okQty     : gap(s.okQty,      q.okQty),
        ngQty     : gap(s.ngQty,      q.ngQty),
        outputQty : gap(s.outputQty,  q.outputQty),
        defectRate: gap(s.defectRate, q.defectRate),
        yieldRate : gap(s.yieldRate,  q.yieldRate),
    };
}

function hasSignificantGap(row) {
    if (!row.gaps) return false;
    const thr = parseFloat(document.getElementById('gapThreshold').value) || 5;
    return Object.values(row.gaps).some(g => g.pct > thr || Math.abs(g.diff) > 0);
}

/* ── KPI ────────────────────────────────────────────────────── */
function renderKPI() {
    const total     = cmpRows.length;
    const unmatched = cmpRows.filter(r => r.source !== 'both').length;
    const matched   = cmpRows.filter(r => r.source === 'both');
    const withGap   = matched.filter(r => hasSignificantGap(r)).length;
    const perfect   = matched.length - withGap;

    document.getElementById('kpiTotal').textContent     = total;
    document.getElementById('kpiMatch').textContent     = perfect;
    document.getElementById('kpiGap').textContent       = withGap;
    document.getElementById('kpiUnmatched').textContent = unmatched;
}

/* ── Filter ─────────────────────────────────────────────────── */
function setFilter(f) {
    setActiveFilter(f);
}

function setActiveFilter(f) {
    activeFilter = f;
    if (f === 'all')          filteredRows = [...cmpRows];
    else if (f === 'gap')     filteredRows = cmpRows.filter(r => r.source === 'both' && hasSignificantGap(r));
    else if (f === 'sysonly') filteredRows = cmpRows.filter(r => r.source === 'sys');
    else if (f === 'qconly')  filteredRows = cmpRows.filter(r => r.source === 'qc');

    document.getElementById('ftAll').classList.toggle('active', f === 'all');
    document.getElementById('ftGap').classList.toggle('active', f === 'gap');
    document.getElementById('ftSys').classList.toggle('active', f === 'sysonly');
    document.getElementById('ftQC').classList.toggle('active',  f === 'qconly');

    currentPage = 1;
    renderTable();
}

/* ── Table ───────────────────────────────────────────────────── */
function renderTable() {
    const wrap  = document.getElementById('tableScroll');
    const pgBar = document.getElementById('paginationBar');
    const badge = document.getElementById('rowBadge');

    badge.textContent = filteredRows.length;

    if (!filteredRows.length) {
        wrap.innerHTML = `<div class="empty-state"><div class="ei">🔍</div><p>Không có dòng nào phù hợp bộ lọc.</p></div>`;
        pgBar.style.display = 'none';
        return;
    }
    pgBar.style.display = 'flex';

    const totalPages = Math.ceil(filteredRows.length / PAGE_SIZE);
    const start      = (currentPage - 1) * PAGE_SIZE;
    const rows       = filteredRows.slice(start, start + PAGE_SIZE);
    const thr        = parseFloat(document.getElementById('gapThreshold').value) || 5;

    const gapBadge = (g, isRate) => {
        if (!g) return `<span class="gap-badge gap-na">N/A</span>`;
        const diff = g.diff;
        const sign = diff > 0 ? '+' : diff < 0 ? '' : '';
        const label = isRate
            ? `${sign}${diff.toFixed(1)}%`
            : `${sign}${fmt(diff)}`;
        const cls = diff === 0 ? 'gap-0' : g.pct > thr ? 'gap-high' : 'gap-low';
        return `<span class="gap-badge ${cls}">${label}</span>`;
    };

    const valCell = (v, isRate, hasVal) => {
        if (!hasVal) return `<td class="td-zero td-center">—</td>`;
        if (isRate) return `<td class="td-num">${v?.toFixed(1) ?? '—'}%</td>`;
        return `<td class="${v > 0 ? 'td-num' : 'td-zero'}">${fmt(v)}</td>`;
    };

    let html = `<table class="cmp-table">
    <thead>
        <tr class="th-group">
            <th class="thg-identity" colspan="6">Thông tin sản phẩm</th>
            <th class="thg-input"    colspan="3">Input Qty / SL đầu vào</th>
            <th class="thg-ok"       colspan="3">OK Qty / SL đạt</th>
            <th class="thg-ng"       colspan="3">NG Qty / SL lỗi</th>
            <th class="thg-rate"     colspan="3">Defect Rate / Tỷ lệ lỗi</th>
            <th class="thg-rate"     colspan="3">Yield Rate / Tỷ lệ đạt</th>
        </tr>
        <tr class="th-main">
            <th class="th-left"  style="min-width:100px">Date<br><small style="opacity:0.7;font-weight:400">Ngày</small></th>
            <th                  style="min-width:80px">Part Code</th>
            <th class="th-left"  style="min-width:160px">Product</th>
            <th                  style="min-width:110px">Coating</th>
            <th class="th-left"  style="min-width:120px">Process</th>
            <th                  style="min-width:70px">Source</th>
            <!-- Input -->
            <th class="th-metric-sys" style="min-width:74px">Sys</th>
            <th class="th-metric-qc"  style="min-width:74px">QC</th>
            <th class="th-metric-gap" style="min-width:70px">Gap</th>
            <!-- OK -->
            <th class="th-metric-sys" style="min-width:74px">Sys</th>
            <th class="th-metric-qc"  style="min-width:74px">QC</th>
            <th class="th-metric-gap" style="min-width:70px">Gap</th>
            <!-- NG -->
            <th class="th-metric-sys" style="min-width:74px">Sys</th>
            <th class="th-metric-qc"  style="min-width:74px">QC</th>
            <th class="th-metric-gap" style="min-width:70px">Gap</th>
            <!-- Defect Rate -->
            <th class="th-metric-sys" style="min-width:74px">Sys</th>
            <th class="th-metric-qc"  style="min-width:74px">QC</th>
            <th class="th-metric-gap" style="min-width:70px">Gap</th>
            <!-- Yield Rate -->
            <th class="th-metric-sys" style="min-width:74px">Sys</th>
            <th class="th-metric-qc"  style="min-width:74px">QC</th>
            <th class="th-metric-gap" style="min-width:70px">Gap</th>
        </tr>
    </thead><tbody>`;

    rows.forEach(r => {
        const s   = r.sys;
        const q   = r.qc;
        const g   = r.gaps;
        const cls = r.source === 'sys' ? 'row-sys-only' : r.source === 'qc' ? 'row-qc-only' : '';
        const srcBadge = r.source === 'both'
            ? `<span class="src-badge src-both">Both</span>`
            : r.source === 'sys'
            ? `<span class="src-badge src-sys">Sys only</span>`
            : `<span class="src-badge src-qc">QC only</span>`;

        html += `<tr class="${cls}">
            <td style="color:var(--gray-600);font-size:0.76rem">${esc(r.date||'')}</td>
            <td class="td-center" style="font-weight:700;color:var(--denim)">${esc(r.partCode||'—')}</td>
            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis" title="${esc(r.product||'')}">${esc(r.product||'—')}</td>
            <td class="td-center">${colorBadge(r.coating)}</td>
            <td style="color:var(--gray-700)">${esc(r.process||'—')}</td>
            <td class="td-center">${srcBadge}</td>
            ${valCell(s?.inputQty, false, !!s)}
            ${valCell(q?.inputQty, false, !!q)}
            <td class="td-center">${gapBadge(g?.inputQty, false)}</td>
            ${valCell(s?.okQty, false, !!s)}
            ${valCell(q?.okQty, false, !!q)}
            <td class="td-center">${gapBadge(g?.okQty, false)}</td>
            ${valCell(s?.ngQty, false, !!s)}
            ${valCell(q?.ngQty, false, !!q)}
            <td class="td-center">${gapBadge(g?.ngQty, false)}</td>
            ${valCell(s?.defectRate, true, !!s)}
            ${valCell(q?.defectRate, true, !!q)}
            <td class="td-center">${gapBadge(g?.defectRate, true)}</td>
            ${valCell(s?.yieldRate, true, !!s)}
            ${valCell(q?.yieldRate, true, !!q)}
            <td class="td-center">${gapBadge(g?.yieldRate, true)}</td>
        </tr>`;
    });

    html += `</tbody></table>`;
    wrap.innerHTML = html;
    renderPagination(filteredRows.length, totalPages);
}

function renderPagination(total, totalPages) {
    const s = (currentPage-1)*PAGE_SIZE+1, e = Math.min(currentPage*PAGE_SIZE, total);
    document.getElementById('pgInfo').textContent = `Hiển thị ${s}–${e} / ${total} dòng`;
    const ctrl = document.getElementById('pgControls');
    ctrl.innerHTML = '';
    const add = (lbl,pg,dis,act) => {
        const b = document.createElement('button');
        b.className='pg-btn'+(act?' active':'');
        b.textContent=lbl; b.disabled=dis;
        b.onclick=()=>{ currentPage=pg; renderTable(); };
        ctrl.appendChild(b);
    };
    add('«',1,currentPage===1,false);
    add('‹',currentPage-1,currentPage===1,false);
    for (let p=Math.max(1,currentPage-2); p<=Math.min(totalPages,currentPage+2); p++) add(p,p,false,p===currentPage);
    add('›',currentPage+1,currentPage===totalPages,false);
    add('»',totalPages,currentPage===totalPages,false);
}

/* ── Export Comparison Excel ─────────────────────────────────── */
function exportComparison() {
    if (!cmpRows.length) { showToast('Không có dữ liệu để xuất.', 'error'); return; }

    const wb  = XLSX.utils.book_new();
    const df  = document.getElementById('fDateFrom').value || 'all';
    const dt  = document.getElementById('fDateTo').value   || fmtDate(new Date());

    const hdrs = [
        'Date','Part Code','Product','Coating','Process','Source',
        'Input Qty (Sys)','Input Qty (QC)','Input Qty Gap',
        'OK Qty (Sys)','OK Qty (QC)','OK Qty Gap',
        'NG Qty (Sys)','NG Qty (QC)','NG Qty Gap',
        'Defect Rate (Sys)','Defect Rate (QC)','Defect Rate Gap',
        'Yield Rate (Sys)','Yield Rate (QC)','Yield Rate Gap',
    ];

    const aoa = [];
    aoa.push([`QC vs SYSTEM COMPARISON — Kỳ: ${df} → ${dt}`]);
    aoa.push([`Xuất lúc: ${new Date().toLocaleString('vi-VN')}`]);
    aoa.push([]);
    aoa.push(hdrs);

    filteredRows.forEach(r => {
        const s = r.sys, q = r.qc, g = r.gaps;
        aoa.push([
            r.date, r.partCode, r.product, r.coating, r.process, r.source.toUpperCase(),
            s?.inputQty  ?? '', q?.inputQty  ?? '', g?.inputQty?.diff  ?? '',
            s?.okQty     ?? '', q?.okQty     ?? '', g?.okQty?.diff     ?? '',
            s?.ngQty     ?? '', q?.ngQty     ?? '', g?.ngQty?.diff     ?? '',
            s?.defectRate!= null ? s.defectRate/100 : '', q?.defectRate != null ? q.defectRate/100 : '', g?.defectRate?.diff != null ? g.defectRate.diff/100 : '',
            s?.yieldRate != null ? s.yieldRate/100  : '', q?.yieldRate  != null ? q.yieldRate/100  : '', g?.yieldRate?.diff  != null ? g.yieldRate.diff/100  : '',
        ]);
    });

    const ws = XLSX.utils.aoa_to_sheet(aoa);
    ws['!cols'] = [
        {wch:14},{wch:10},{wch:24},{wch:14},{wch:18},{wch:10},
        {wch:14},{wch:14},{wch:12},
        {wch:12},{wch:12},{wch:12},
        {wch:12},{wch:12},{wch:12},
        {wch:16},{wch:16},{wch:14},
        {wch:16},{wch:16},{wch:14},
    ];
    for (let ri = 4; ri < 4 + filteredRows.length; ri++) {
        [15,16,17,18,19,20].forEach(ci => {
            const ref = XLSX.utils.encode_cell({r:ri,c:ci});
            if (ws[ref] && ws[ref].v !== '') ws[ref].z = '0.0%';
        });
    }
    ws['!autofilter'] = { ref: `A4:U4` };
    XLSX.utils.book_append_sheet(wb, ws, 'Comparison');

    const thr = parseFloat(document.getElementById('gapThreshold').value) || 5;
    const bothRows    = cmpRows.filter(r => r.source === 'both');
    const withGapRows = bothRows.filter(r => hasSignificantGap(r));
    const metrics = ['inputQty','okQty','ngQty','defectRate','yieldRate'];
    const sumAoa = [
        ['COMPARISON SUMMARY',''],
        [`Kỳ: ${df} → ${dt}`,''],
        [`Ngưỡng gap: ${thr}%`,''],
        [],
        ['Tổng cặp',         cmpRows.length],
        ['Matched (both)',   bothRows.length],
        ['Chỉ Sys',         cmpRows.filter(r=>r.source==='sys').length],
        ['Chỉ QC',          cmpRows.filter(r=>r.source==='qc').length],
        ['Khớp hoàn toàn',  bothRows.length - withGapRows.length],
        ['Có gap',          withGapRows.length],
        [],
        ['Metric','Max Gap (Sys-QC)','Avg Gap'],
    ];
    metrics.forEach(m => {
        const diffs = bothRows.map(r => r.gaps?.[m]?.diff ?? 0).filter(v => v !== 0);
        sumAoa.push([
            m,
            diffs.length ? Math.max(...diffs.map(Math.abs)).toFixed(1) : 0,
            diffs.length ? (diffs.reduce((a,b)=>a+Math.abs(b),0)/diffs.length).toFixed(1) : 0
        ]);
    });
    const ws2 = XLSX.utils.aoa_to_sheet(sumAoa);
    ws2['!cols'] = [{wch:24},{wch:18},{wch:14}];
    XLSX.utils.book_append_sheet(wb, ws2, 'Summary');

    const stamp = new Date().toISOString().slice(0,10);
    XLSX.writeFile(wb, `QC_Comparison_${df}_${dt}_${stamp}.xlsx`);
    showToast(`Xuất xong ${filteredRows.length} dòng.`, 'success');
}

/* ── Helpers ─────────────────────────────────────────────────── */
function colorBadge(c) {
    if (!c||c==='-') return `<span class="color-tag color-none">—</span>`;
    const l=c.toLowerCase();
    if (l.includes('matt')||l.includes('black')) return `<span class="color-tag color-matte">${esc(c)}</span>`;
    if (l.includes('chrome'))                    return `<span class="color-tag color-chrome">${esc(c)}</span>`;
    if (l.includes('brass'))                     return `<span class="color-tag color-brass">${esc(c)}</span>`;
    if (l.includes('beige'))                     return `<span class="color-tag color-beige">${esc(c)}</span>`;
    return `<span class="color-tag color-other">${esc(c)}</span>`;
}
function fmt(n)    { return n==null||n===0?'0':Number(n).toLocaleString('en-US'); }
function esc(s)    { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function showLoading(v, msg) {
    document.getElementById('loadingOverlay').classList.toggle('show',v);
    if (msg) document.getElementById('loadingMsg').textContent = msg;
}
function showToast(msg, type='info') {
    const el=document.getElementById('toast');
    el.className='toast '+type;
    document.getElementById('toastIcon').textContent=type==='success'?'✅':type==='error'?'❌':'ℹ️';
    document.getElementById('toastMsg').textContent=msg;
    el.classList.add('show');
    setTimeout(()=>el.classList.remove('show'), 3500);
}
</script>
}
</body>
</html>
