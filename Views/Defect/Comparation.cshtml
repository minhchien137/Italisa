@{
    ViewData["Title"] = "QC vs System Comparison";
}

<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="@Url.Content("~/js/i18n.js")"></script>
<style>
:root{--denim:#1B4F8A;--denim-dark:#0f2f52;--denim-mid:#2563a8;--denim-light:#dbeafe;--denim-xlight:#eff6ff;--white:#fff;--gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;--gray-300:#cbd5e1;--gray-400:#94a3b8;--gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--shadow-sm:0 1px 3px rgba(27,79,138,.08);--shadow-md:0 4px 20px rgba(27,79,138,.12)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--gray-50);min-height:100vh;background-image:radial-gradient(ellipse at 20% 50%,rgba(27,79,138,.06) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(37,99,168,.05) 0%,transparent 50%)}
.page-wrapper{max-width:1700px;margin:0 auto;padding:1.5rem 1rem}
@@media(min-width:600px){.page-wrapper{padding:2rem 1.5rem}}
.page-header{margin-bottom:1.5rem}
.page-header h1{font-family:'Space Grotesk',sans-serif;font-size:1.6rem;font-weight:700;color:var(--denim-dark);display:flex;align-items:center;gap:10px}
.page-header p{color:var(--gray-600);font-size:.88rem;margin-top:5px}
.header-line{width:48px;height:4px;background:linear-gradient(90deg,var(--denim),var(--denim-mid));border-radius:2px;margin-top:10px}

.phase-header{background:linear-gradient(135deg,#7c3aed 0%,#5b21b6 100%);color:var(--white);padding:.85rem 1.3rem;border-radius:14px 14px 0 0;display:flex;align-items:center;gap:12px;margin-bottom:0}
.phase-header.cyan{background:linear-gradient(135deg,#0891b2 0%,#0e7490 100%)}
.phase-header.orange{background:linear-gradient(135deg,#ea580c 0%,#c2410c 100%)}
.phase-num{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.95rem;flex-shrink:0}
.phase-title{font-family:'Space Grotesk',sans-serif;font-size:1.02rem;font-weight:700}
.phase-sub{font-size:.78rem;color:rgba(255,255,255,.85);margin-left:auto;font-style:italic}

.phase-body{background:var(--white);border:1px solid rgba(27,79,138,.08);border-top:none;border-radius:0 0 14px 14px;box-shadow:var(--shadow-sm);padding:1.1rem 1.25rem;margin-bottom:1.5rem}
.phase-body.compact{padding:.85rem 1.25rem}

.filter-row{display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
@@media(min-width:700px){.filter-row{grid-template-columns:repeat(5,1fr) auto;align-items:end;gap:.75rem}}
.fg{display:flex;flex-direction:column;gap:4px}
.fg label{font-size:.7rem;font-weight:700;color:var(--denim-dark);text-transform:uppercase;letter-spacing:.3px}
.fg select,.fg input[type=date]{width:100%;padding:.5rem .65rem;border:1.5px solid var(--gray-200);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.84rem;color:var(--gray-800);background:var(--white);outline:none;min-height:38px;cursor:pointer}
.fg select:focus,.fg input[type=date]:focus{border-color:var(--denim);box-shadow:0 0 0 3px rgba(27,79,138,.1)}

.upload-zone{border:2px dashed var(--gray-200);border-radius:10px;padding:1.5rem 1.5rem;text-align:center;cursor:pointer;transition:all .2s;background:var(--white);position:relative}
.upload-zone:hover,.upload-zone.drag-over{border-color:#0891b2;background:#ecfeff}
.upload-zone.has-file{border-color:var(--success);background:#f0fdf4}
.upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.upload-icon{font-size:1.8rem;margin-bottom:.4rem}
.upload-title{font-weight:600;color:var(--denim-dark);font-size:.88rem}
.upload-sub{font-size:.76rem;color:var(--gray-400);margin-top:3px}
.upload-filename{font-size:.85rem;font-weight:600;color:var(--success);margin-top:6px}

.btn{padding:.55rem 1.1rem;border-radius:8px;border:none;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--denim);color:var(--white)}
.btn-primary:hover:not(:disabled){background:var(--denim-dark)}
.btn-cyan{background:linear-gradient(135deg,#0891b2 0%,#0e7490 100%);color:var(--white)}
.btn-cyan:hover:not(:disabled){filter:brightness(1.1)}
.btn-orange{background:linear-gradient(135deg,#ea580c 0%,#c2410c 100%);color:var(--white);font-size:.95rem;padding:.7rem 1.6rem}
.btn-orange:hover:not(:disabled){filter:brightness(1.1)}
.btn-success{background:#059669;color:var(--white)}
.btn-success:hover:not(:disabled){background:#047857}
.btn-outline{background:var(--white);color:var(--denim);border:1.5px solid var(--denim-light)}
.btn-outline:hover:not(:disabled){background:var(--denim-xlight)}
.btn:disabled{opacity:.5;cursor:not-allowed}
.btn-sm{padding:.4rem .85rem;font-size:.78rem}

.kpi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem;margin-bottom:1rem}
@@media(min-width:700px){.kpi-grid{grid-template-columns:repeat(4,1fr);gap:.85rem}}
.kpi-card{background:var(--white);border-radius:10px;border:1px solid rgba(27,79,138,.08);box-shadow:var(--shadow-sm);padding:.85rem 1rem;display:flex;flex-direction:column;gap:3px}
.kpi-label{font-size:.66rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.3px}
.kpi-value{font-family:'Space Grotesk',sans-serif;font-size:1.4rem;font-weight:700;color:var(--denim-dark);line-height:1.1}
.kpi-value.green{color:var(--success)}
.kpi-value.red{color:var(--danger)}
.kpi-value.orange{color:var(--warning)}
.kpi-sub{font-size:.7rem;color:var(--gray-400)}

.table-card{background:var(--white);border-radius:14px;border:1px solid rgba(27,79,138,.08);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:1.5rem}
.table-card.purple-top{border-top:3px solid #7c3aed}
.table-card.cyan-top{border-top:3px solid #0891b2}
.table-card.orange-top{border-top:3px solid #ea580c}
.table-card-h{background:linear-gradient(135deg,var(--denim-dark) 0%,var(--denim) 100%);padding:.85rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.table-card-h h3{font-family:'Space Grotesk',sans-serif;font-size:.92rem;font-weight:600;color:var(--white);display:flex;align-items:center;gap:8px}
.badge{background:rgba(255,255,255,.18);color:var(--white);border-radius:20px;padding:2px 9px;font-size:.72rem;font-weight:600}

.table-scroll{overflow-x:auto;max-height:65vh}
.dt{width:100%;border-collapse:collapse;font-size:.79rem}
.dt thead tr.th-main th{background:var(--denim);color:var(--white);padding:7px 9px;text-align:center;font-weight:600;border-right:1px solid rgba(255,255,255,.15);white-space:nowrap;font-size:.74rem;position:sticky;top:0;z-index:1}
.dt thead tr.th-main th.th-left{text-align:left}
.dt thead tr.th-main th.th-defect{background:#5b21b6}
.dt thead tr.th-main th.th-defect-first{border-left:2px solid rgba(255,255,255,.4)}
.dt thead tr.th-main th .th-en{display:block;font-size:.78rem;font-weight:700;line-height:1.4}
.dt thead tr.th-main th .th-cn{display:block;font-size:.66rem;font-weight:400;opacity:.8;line-height:1.3}
.dt thead tr.th-main th .th-vn{display:block;font-size:.66rem;font-weight:500;opacity:.85;line-height:1.3;color:#a8d0f8}
.dt tbody td{padding:7px 9px;border-bottom:1px solid var(--gray-100);border-right:1px solid var(--gray-100);vertical-align:middle;white-space:nowrap}
.dt tbody tr:nth-child(even) td{background:#f8fafc}
.dt tbody tr:hover td{background:var(--denim-xlight)}
.dt tbody tr.row-sys-only td{background:#eff6ff!important}
.dt tbody tr.row-qc-only td{background:#fff7ed!important}
.td-num{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:var(--denim)}
.td-zero{text-align:right;font-variant-numeric:tabular-nums;color:#d1d5db}
.td-center{text-align:center}
.td-defect{text-align:right;font-variant-numeric:tabular-nums}
.td-defect.td-defect-first{border-left:2px solid #c4b5fd}
.td-defect-nz{font-weight:700;color:var(--danger)}
.rate-badge{display:inline-block;padding:2px 7px;border-radius:20px;font-size:.72rem;font-weight:700}
.rate-ok{background:#ecfdf5;color:#065f46}
.rate-mid{background:#fff7ed;color:#92400e}
.rate-bad{background:#fef2f2;color:#991b1b}
.color-tag{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.69rem;font-weight:600;white-space:nowrap}
.color-matte{background:#1e293b;color:#fff}
.color-chrome{background:#e2e8f0;color:#1e293b;border:1px solid #cbd5e1}
.color-brass{background:#fef3c7;color:#92400e;border:1px solid #fde68a}
.color-beige{background:#fef9c3;color:#713f12;border:1px solid #fde68a}
.color-other{background:var(--denim-xlight);color:var(--denim)}
.color-none{background:var(--gray-100);color:var(--gray-600);font-style:italic}

.dt thead tr.th-group th{background:var(--denim-dark);color:rgba(255,255,255,.7);padding:5px 8px;text-align:center;font-size:.66rem;font-weight:600;letter-spacing:.3px;text-transform:uppercase;border-right:1px solid rgba(255,255,255,.1)}
.dt thead tr.th-main th.th-metric-sys{background:#1e4d8c}
.dt thead tr.th-main th.th-metric-qc{background:#92400e}
.dt thead tr.th-main th.th-metric-gap{background:#1e293b}
.dt thead tr.th-group th.thg-identity{background:var(--denim-dark)}
.dt thead tr.th-group th.thg-input{background:#1e4d8c}
.dt thead tr.th-group th.thg-ok{background:#065f46}
.dt thead tr.th-group th.thg-ng{background:#7f1d1d}
.dt thead tr.th-group th.thg-rate{background:#1e293b}
.gap-badge{display:inline-block;padding:1px 7px;border-radius:10px;font-size:.7rem;font-weight:700;font-variant-numeric:tabular-nums}
.gap-0{background:#dcfce7;color:#166534}
.gap-low{background:#fef9c3;color:#713f12}
.gap-high{background:#fee2e2;color:#991b1b}
.gap-na{background:var(--gray-100);color:var(--gray-400);font-style:italic;font-weight:400}
.src-badge{display:inline-block;padding:1px 7px;border-radius:10px;font-size:.7rem;font-weight:700}
.src-both{background:#dcfce7;color:#166534}
.src-sys{background:var(--denim-xlight);color:var(--denim)}
.src-qc{background:#fef3c7;color:#92400e}

.filter-tabs{display:flex;gap:6px;flex-wrap:wrap}
.ftab{padding:5px 12px;border-radius:20px;font-size:.78rem;font-weight:600;cursor:pointer;border:1.5px solid rgba(255,255,255,.3);background:rgba(255,255,255,.1);color:var(--white);transition:all .15s}
.ftab:hover{background:rgba(255,255,255,.2)}
.ftab.active{background:var(--white);color:var(--denim-dark);border-color:var(--white)}

.threshold-wrap{display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--gray-700)}
.threshold-wrap input[type=number]{width:64px;padding:5px 7px;border:1.5px solid var(--gray-200);border-radius:6px;font-size:.85rem;text-align:center;outline:none}
.threshold-wrap input[type=number]:focus{border-color:var(--denim)}

.pg-bar{padding:.75rem 1.25rem;border-top:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.pg-info{font-size:.78rem;color:var(--gray-600)}
.pg-ctrls{display:flex;gap:4px}
.pg-btn{min-width:28px;height:28px;padding:0 7px;border:1.5px solid var(--gray-200);border-radius:6px;background:var(--white);color:var(--gray-800);font-size:.78rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
.pg-btn:hover:not(:disabled){border-color:var(--denim);color:var(--denim)}
.pg-btn.active{background:var(--denim);color:var(--white);border-color:var(--denim);font-weight:700}
.pg-btn:disabled{opacity:.4;cursor:not-allowed}

.empty{padding:3rem;text-align:center;color:var(--gray-400)}
.empty .ei{font-size:2.8rem;margin-bottom:.75rem}
.loading{position:fixed;inset:0;background:rgba(15,47,82,.4);display:flex;align-items:center;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .2s}
.loading.show{opacity:1;pointer-events:all}
.loading-box{background:var(--white);border-radius:14px;padding:2rem 2.5rem;text-align:center;box-shadow:var(--shadow-md)}
.spinner{width:38px;height:38px;margin:0 auto .9rem;border:3px solid var(--denim-light);border-top-color:var(--denim);border-radius:50%;animation:spin .8s linear infinite}
@@keyframes spin{to{transform:rotate(360deg)}}
.toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9000;background:var(--white);border-radius:10px;box-shadow:var(--shadow-md);padding:.8rem 1.2rem;display:flex;align-items:center;gap:9px;min-width:270px;opacity:0;transform:translateY(10px);transition:opacity .25s,transform .25s;pointer-events:none}
.toast.show{opacity:1;transform:translateY(0);pointer-events:all}
.toast.success{border-left:4px solid var(--success)}
.toast.error{border-left:4px solid var(--danger)}
.toast.info{border-left:4px solid var(--denim)}
#toastMsg{font-size:.85rem;color:var(--gray-800)}

.data-pill{display:inline-flex;align-items:center;gap:6px;padding:4px 11px;border-radius:20px;font-size:.78rem;font-weight:600}
.pill-sys{background:var(--denim-xlight);color:var(--denim)}
.pill-qc{background:#fef3c7;color:#92400e}
</style>
</head>
<body>

<div class="loading" id="loading">
    <div class="loading-box"><div class="spinner"></div><p style="color:var(--denim-dark);font-weight:600;font-size:.88rem" id="loadingMsg">...</p></div>
</div>
<div class="toast" id="toast"><span id="toastIcon"></span><span id="toastMsg"></span></div>

<div class="page-wrapper">

<div class="page-header">
    <h1 data-i18n="cmp.page.title">⚖️ QC Data vs System Data — So Sánh Dữ Liệu</h1>
    <p data-i18n="cmp.page.subtitle">Đối chiếu Yield Report (hệ thống) với file Excel QC để phát hiện gap.</p>
    <div class="header-line"></div>
</div>

<!-- ════════════════════════════ PHASE 1 ════════════════════════════ -->
<div class="phase-header">
    <div class="phase-num">1</div>
    <div class="phase-title" data-i18n="cmp.phase1.title">📊 Dữ liệu Hệ thống (Yield Report)</div>
    <div class="phase-sub" data-i18n="cmp.phase1.sub">Tải dữ liệu từ DB → xem trước khi compare</div>
</div>
<div class="phase-body compact">
    <div class="filter-row">
        <div class="fg">
            <label data-i18n="cmp.label.from">📅 Từ ngày</label>
            <input type="date" id="fDateFrom"/>
        </div>
        <div class="fg">
            <label data-i18n="cmp.label.to">📅 Đến ngày</label>
            <input type="date" id="fDateTo"/>
        </div>
        <div class="fg">
            <label data-i18n="cmp.label.process">⚙️ Công đoạn</label>
            <select id="fProcess"><option value="" data-i18n="cmp.all">-- Tất cả --</option></select>
        </div>
        <div class="fg">
            <label data-i18n="cmp.label.coating">🎨 Lớp phủ</label>
            <select id="fColor"><option value="" data-i18n="cmp.all">-- Tất cả --</option></select>
        </div>
        <div class="fg">
            <label data-i18n="cmp.label.partcode">🔩 Part Code</label>
            <select id="fPartCode"><option value="" data-i18n="cmp.all">-- Tất cả --</option></select>
        </div>
        <div class="fg">
            <label>&nbsp;</label>
            <button class="btn btn-primary" id="btnLoadSys" onclick="loadSystemData()" data-i18n="cmp.btn.load_sys">📡 Tải Hệ thống</button>
        </div>
    </div>
    <div id="sysInfo" style="font-size:.8rem;color:var(--gray-400);margin-top:.6rem" data-i18n="cmp.info.init">
        ⏳ Chọn khoảng ngày và nhấn "Tải Hệ thống" để xem dữ liệu Yield Report.
    </div>
</div>

<div id="sysDataWrap" style="display:none">
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.input">📦 Tổng Input</div><div class="kpi-value" id="sysKpiInput">—</div><div class="kpi-sub" data-i18n="cmp.kpi.input.sub">SL đầu vào</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.ng">❌ Tổng NG</div><div class="kpi-value red" id="sysKpiNG">—</div><div class="kpi-sub" data-i18n="cmp.kpi.ng.sub">SL lỗi</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.defrate">📉 Defect Rate</div><div class="kpi-value red" id="sysKpiDef">—</div><div class="kpi-sub" data-i18n="cmp.kpi.defrate.sub">Tỷ lệ lỗi tổng</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.yield">✅ Yield Rate</div><div class="kpi-value green" id="sysKpiYld">—</div><div class="kpi-sub" data-i18n="cmp.kpi.yield.sub">Tỷ lệ đạt tổng</div></div>
    </div>

    <div class="table-card purple-top">
        <div class="table-card-h">
            <h3><span data-i18n="cmp.table.sys.title">🖥️ System Yield Report</span> <span class="badge" id="sysBadge">0</span></h3>
            <span style="font-size:.75rem;color:rgba(255,255,255,.7)" data-i18n="cmp.table.sys.sub">Dữ liệu từ Production/GetDefectReportData</span>
        </div>
        <div class="table-scroll" id="sysTableScroll"></div>
        <div class="pg-bar" id="sysPgBar" style="display:none">
            <span class="pg-info" id="sysPgInfo"></span>
            <div class="pg-ctrls" id="sysPgCtrl"></div>
        </div>
    </div>
</div>

<!-- ════════════════════════════ PHASE 2 ════════════════════════════ -->
<div class="phase-header cyan">
    <div class="phase-num">2</div>
    <div class="phase-title" data-i18n="cmp.phase2.title">📂 Dữ liệu QC (Excel Upload)</div>
    <div class="phase-sub" data-i18n="cmp.phase2.sub">Upload file QC → hiển thị toàn bộ thông tin</div>
</div>
<div class="phase-body compact">
    <div class="upload-zone" id="uploadZone">
        <input type="file" id="qcFile" accept=".xlsx,.xls" onchange="handleFileUpload(this)"/>
        <div class="upload-icon">📂</div>
        <div class="upload-title" data-i18n="cmp.upload.title">Kéo thả hoặc click để chọn file Excel QC</div>
        <div class="upload-sub" data-i18n="cmp.upload.sub">Cùng format với Yield Report · Tự động nhận diện cột</div>
        <div class="upload-filename" id="uploadFilename"></div>
    </div>
    <div id="qcParseInfo" style="font-size:.8rem;color:var(--gray-400);margin-top:.6rem" data-i18n="cmp.upload.empty">
        ⏳ Chưa upload file.
    </div>
</div>

<div id="qcDataWrap" style="display:none">
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.qckpi.rows">📋 Tổng dòng</div><div class="kpi-value" id="qcKpiRows">—</div><div class="kpi-sub" data-i18n="cmp.qckpi.rows.sub">trong Excel</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.input">📦 Tổng Input</div><div class="kpi-value" id="qcKpiInput">—</div><div class="kpi-sub" data-i18n="cmp.qckpi.input.sub">từ QC</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.ng">❌ Tổng NG</div><div class="kpi-value red" id="qcKpiNG">—</div><div class="kpi-sub" data-i18n="cmp.qckpi.ng.sub">từ QC</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.kpi.defrate">📉 Defect Rate</div><div class="kpi-value red" id="qcKpiDef">—</div><div class="kpi-sub" data-i18n="cmp.qckpi.defrate.sub">trung bình QC</div></div>
    </div>

    <div class="table-card cyan-top">
        <div class="table-card-h" style="background:linear-gradient(135deg,#0e7490 0%,#0891b2 100%)">
            <h3><span data-i18n="cmp.table.qc.title">📋 QC Excel Data</span> — <span id="qcTableTitle">Raw Data</span> <span class="badge" id="qcBadge">0</span></h3>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <span style="font-size:.75rem;color:rgba(255,255,255,.7)" data-i18n="cmp.table.qc.filter">Lọc ngày:</span>
                <input type="date" id="qcFilterFrom" style="padding:3px 7px;border-radius:6px;border:none;font-size:.78rem;cursor:pointer" onchange="applyQCDateFilter()"/>
                <span style="color:rgba(255,255,255,.6);font-size:.78rem">→</span>
                <input type="date" id="qcFilterTo" style="padding:3px 7px;border-radius:6px;border:none;font-size:.78rem;cursor:pointer" onchange="applyQCDateFilter()"/>
                <button class="btn btn-outline btn-sm" onclick="clearQCFilter()" style="background:transparent;color:rgba(255,255,255,.6);border-color:rgba(255,255,255,.2)">✕</button>
            </div>
        </div>
        <div class="table-scroll" id="qcTableScroll"></div>
        <div class="pg-bar" id="qcPgBar" style="display:none">
            <span class="pg-info" id="qcPgInfo"></span>
            <div class="pg-ctrls" id="qcPgCtrl"></div>
        </div>
    </div>
</div>

<!-- ════════════════════════════ PHASE 3 ════════════════════════════ -->
<div class="phase-header orange">
    <div class="phase-num">3</div>
    <div class="phase-title" data-i18n="cmp.phase3.title">⚖️ So sánh Hệ thống vs QC</div>
    <div class="phase-sub" data-i18n="cmp.phase3.sub">Phát hiện gap / sai lệch giữa 2 nguồn</div>
</div>
<div class="phase-body compact">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <button class="btn btn-orange" id="btnCompare" onclick="runComparison()" disabled data-i18n="cmp.btn.compare">⚖️ Chạy So Sánh</button>
            <div class="threshold-wrap">
                <span data-i18n="cmp.label.threshold">Ngưỡng gap:</span>
                <input type="number" id="gapThreshold" value="5" min="0" max="100" step="1"/>
                <span>%</span>
            </div>
        </div>
        <button class="btn btn-success btn-sm" id="btnExport" onclick="exportComparison()" disabled data-i18n="cmp.btn.export">📥 Xuất Excel So Sánh</button>
    </div>
</div>

<div id="cmpDataWrap" style="display:none">
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.cmpkpi.total">Tổng cặp</div><div class="kpi-value" id="kpiTotal">—</div><div class="kpi-sub" data-i18n="cmp.cmpkpi.total.sub">matched + unmatched</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.cmpkpi.match">✅ Khớp hoàn toàn</div><div class="kpi-value green" id="kpiMatch">—</div><div class="kpi-sub" data-i18n="cmp.cmpkpi.match.sub">Gap = 0 trên mọi metric</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.cmpkpi.gap">⚠️ Có gap</div><div class="kpi-value orange" id="kpiGap">—</div><div class="kpi-sub" data-i18n="cmp.cmpkpi.gap.sub">Ít nhất 1 metric lệch</div></div>
        <div class="kpi-card"><div class="kpi-label" data-i18n="cmp.cmpkpi.unmatched">❌ Chỉ 1 bên</div><div class="kpi-value red" id="kpiUnmatched">—</div><div class="kpi-sub" data-i18n="cmp.cmpkpi.unmatched.sub">Sys-only hoặc QC-only</div></div>
    </div>

    <div class="table-card orange-top">
        <div class="table-card-h" style="background:linear-gradient(135deg,#c2410c 0%,#ea580c 100%)">
            <h3><span data-i18n="cmp.table.cmp.title">⚖️ Bảng So Sánh</span> <span class="badge" id="cmpBadge">0</span></h3>
            <div class="filter-tabs">
                <button class="ftab active" onclick="setFilter('all')" id="ftAll" data-i18n="cmp.ftab.all">Tất cả</button>
                <button class="ftab" onclick="setFilter('gap')" id="ftGap" data-i18n="cmp.ftab.gap">⚠️ Có gap</button>
                <button class="ftab" onclick="setFilter('sysonly')" id="ftSys" data-i18n="cmp.ftab.sysonly">🖥️ Chỉ Sys</button>
                <button class="ftab" onclick="setFilter('qconly')" id="ftQC" data-i18n="cmp.ftab.qconly">📋 Chỉ QC</button>
            </div>
        </div>
        <div class="table-scroll" id="cmpTableScroll"></div>
        <div class="pg-bar" id="cmpPgBar" style="display:none">
            <span class="pg-info" id="cmpPgInfo"></span>
            <div class="pg-ctrls" id="cmpPgCtrl"></div>
        </div>
    </div>
</div>

</div>

@section Scripts {
<script>
const pathBase = '@Context.Request.PathBase';

let sysRowsRaw=[], sysData=[], sysDefectTypes=[];
let qcData=[], qcFiltered=[], cmpRows=[], filteredRows=[];
let _rawHeaders=[], _rawRows=[], _sheetName='', _rawFiltered=[];
let colMap={}, activeFilter='all';
const SYS_PAGE=30; let sysPage=1;
const QC_PAGE=30; let qcPage=1;
const CMP_PAGE=30; let cmpPage=1;

document.addEventListener('DOMContentLoaded', () => {
    const today = new Date(), from = new Date(today);
    from.setDate(today.getDate() - 1);
    document.getElementById('fDateTo').value   = fmtDate(today);
    document.getElementById('fDateFrom').value = fmtDate(from);
    loadFilters();
    setupDropZone();
});

// Re-render tables when language changes so dynamic content (table headers, source badges) update
document.addEventListener('langChanged', () => {
    if (sysRowsRaw.length) renderSystemTable();
    if (_rawRows.length)   renderQcTable();
    if (cmpRows.length)    renderCmpTable();
});

function fmtDate(d) { return d.toISOString().split('T')[0]; }

async function loadFilters() {
    try {
        const [pr, cr] = await Promise.all([
            fetch(`${pathBase}/Production/GetProcesses`),
            fetch(`${pathBase}/Production/GetColors`)
        ]);
        const procs  = await pr.json();
        const colors = await cr.json();
        const ps = document.getElementById('fProcess');
        procs.forEach(p => { if (p) ps.insertAdjacentHTML('beforeend', `<option value="${esc(p)}">${esc(p)}</option>`); });
        const cs = document.getElementById('fColor');
        colors.forEach(c => { if (c) cs.insertAdjacentHTML('beforeend', `<option value="${esc(c)}">${esc(c)}</option>`); });
    } catch(e) { console.error(e); }
}

function setupDropZone() {
    const zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault(); zone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) processFile(file);
    });
}

/* ── PHASE 1: System Data ── */
async function loadSystemData() {
    const df = document.getElementById('fDateFrom').value;
    const dt = document.getElementById('fDateTo').value;
    const pr = document.getElementById('fProcess').value;
    const cl = document.getElementById('fColor').value;
    const pc = document.getElementById('fPartCode').value;
    if (!df || !dt) { showToast(t('cmp.toast.no_date'), 'error'); return; }
    showLoading(true, t('cmp.loading.sys'));
    document.getElementById('btnLoadSys').disabled = true;
    try {
        const params = new URLSearchParams({ dateFrom: df, dateTo: dt });
        if (pr) params.append('process', pr);
        if (cl) params.append('color', cl);
        if (pc) params.append('productId', pc);
        const res = await fetch(`${pathBase}/Production/GetDefectReportData?` + params);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        sysRowsRaw = data.rows || [];
        sysDefectTypes = data.defectTypes || [];
        sysData = sysRowsRaw.map(r => ({
            date:r.date, partCode:r.partCode, product:r.product, coating:r.coating, process:r.process,
            inputQty:r.inputQty||0, okQty:r.okQty||0, ngQty:r.ngQty||0, outputQty:r.outputQty||0,
            defectRate:r.defectRate||0, yieldRate:r.yieldRate||100,
        }));
        refreshPartCodeFilter();
        document.getElementById('sysInfo').innerHTML =
            `<span class="data-pill pill-sys">${t('cmp.info.loaded', {n: sysRowsRaw.length, from: df, to: dt})}</span>
             ${pr?` · ${esc(pr)}`:''}${cl?` · ${esc(cl)}`:''}`;
        sysPage = 1;
        renderSystemKpi();
        renderSystemTable();
        document.getElementById('sysDataWrap').style.display = 'block';
        checkCompareReady();
        showToast(t('cmp.toast.load_ok', {n: sysRowsRaw.length}), 'success');
    } catch(e) {
        showToast(t('cmp.toast.load_fail', {msg: e.message}), 'error');
        console.error(e);
    } finally {
        showLoading(false);
        document.getElementById('btnLoadSys').disabled = false;
    }
}

function refreshPartCodeFilter() {
    const sel = document.getElementById('fPartCode');
    const cur = sel.value;
    while (sel.options.length > 1) sel.remove(1);
    const seen = new Map();
    sysRowsRaw.forEach(r => { if (r.productId != null && !seen.has(r.productId)) seen.set(r.productId, r.partCode || String(r.productId)); });
    [...seen.entries()].sort((a,b) => String(a[1]).localeCompare(String(b[1]))).forEach(([v,lbl]) => {
        sel.insertAdjacentHTML('beforeend', `<option value="${v}">${esc(lbl)}</option>`);
    });
    if (cur) sel.value = cur;
}

function renderSystemKpi() {
    if (!sysRowsRaw.length) { ['sysKpiInput','sysKpiNG','sysKpiDef','sysKpiYld'].forEach(id => document.getElementById(id).textContent = '—'); return; }
    const tI = sysRowsRaw.reduce((s,r) => s+(r.inputQty||0), 0);
    const tN = sysRowsRaw.reduce((s,r) => s+(r.ngQty   ||0), 0);
    const tO = sysRowsRaw.reduce((s,r) => s+(r.okQty   ||0), 0);
    document.getElementById('sysKpiInput').textContent = fmt(tI);
    document.getElementById('sysKpiNG').textContent    = fmt(tN);
    document.getElementById('sysKpiDef').textContent   = (tI>0?(tN/tI*100):0).toFixed(1)+'%';
    document.getElementById('sysKpiYld').textContent   = (tI>0?(tO/tI*100):100).toFixed(1)+'%';
}

function renderSystemTable() {
    const wrap  = document.getElementById('sysTableScroll');
    const pgBar = document.getElementById('sysPgBar');
    document.getElementById('sysBadge').textContent = sysRowsRaw.length;
    if (!sysRowsRaw.length) { wrap.innerHTML = `<div class="empty"><div class="ei">📭</div><p>${t('cmp.empty.nodata')}</p></div>`; pgBar.style.display = 'none'; return; }
    pgBar.style.display = 'flex';
    const totalPages = Math.ceil(sysRowsRaw.length / SYS_PAGE);
    const start = (sysPage - 1) * SYS_PAGE;
    const rows  = sysRowsRaw.slice(start, start + SYS_PAGE);

    // Headers stay trilingual (matches Yield Report design)
    const fixedCols = [
        { en:'Date',        cn:'日期',   vn:'Ngày',          w:108 },
        { en:'Part Code',   cn:'零件代码',vn:'Mã linh kiện', w:92  },
        { en:'Product',     cn:'产品名称',vn:'Sản phẩm',     w:150,left:true },
        { en:'SVN Code',    cn:'SVN编码', vn:'Mã SVN',        w:108 },
        { en:'SVN Name',    cn:'SVN名称', vn:'Tên SVN',       w:240,left:true },
        { en:'Coating',     cn:'涂层',   vn:'Lớp phủ',       w:108 },
        { en:'Process',     cn:'工序',   vn:'Quy trình',     w:120,left:true },
        { en:'Input Qty',   cn:'投入量', vn:'SL đầu vào',    w:78 },
        { en:'OK Qty',      cn:'良品数', vn:'SL đạt',        w:74 },
        { en:'NG Qty',      cn:'不良数', vn:'SL lỗi',        w:74 },
        { en:'Defect Rate', cn:'不良率', vn:'Tỷ lệ lỗi',     w:84 },
        { en:'Yield Rate',  cn:'良品率', vn:'Tỷ lệ đạt',     w:84 },
    ];
    let html = `<table class="dt"><thead><tr class="th-main">`;
    fixedCols.forEach(c => {
        html += `<th class="${c.left?'th-left':''}" style="min-width:${c.w}px">
            <span class="th-en">${c.en}</span><span class="th-cn">${c.cn}</span><span class="th-vn">${c.vn}</span></th>`;
    });
    sysDefectTypes.forEach((d, i) => {
        html += `<th class="th-defect${i===0?' th-defect-first':''}" style="min-width:80px">
            <span class="th-en">${esc(d.en||'')}</span><span class="th-cn">${esc(d.cn||'')}</span><span class="th-vn">${esc(d.vn||'')}</span></th>`;
    });
    html += `</tr></thead><tbody>`;
    rows.forEach(r => {
        const rCls = r.defectRate >= 10 ? 'rate-bad' : r.defectRate >= 5 ? 'rate-mid' : 'rate-ok';
        const yCls = r.yieldRate  <= 90 ? 'rate-bad' : r.yieldRate  <= 95 ? 'rate-mid' : 'rate-ok';
        html += `<tr>
            <td style="color:var(--gray-600);font-size:.77rem">${esc(r.date||'')}</td>
            <td class="td-center" style="font-weight:700;color:var(--denim)">${esc(r.partCode||'—')}</td>
            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;color:var(--gray-800)" title="${esc(r.product||'')}">${esc(r.product||'—')}</td>
            <td class="td-center" style="color:var(--denim);font-weight:600;font-size:.77rem">${esc(r.svnCode||'—')}</td>
            <td style="color:var(--gray-600);font-size:.77rem;max-width:240px;overflow:hidden;text-overflow:ellipsis" title="${esc(r.svnName||'')}">${esc(r.svnName||'—')}</td>
            <td class="td-center">${colorBadge(r.coating)}</td>
            <td style="color:var(--gray-700)">${esc(r.process||'—')}</td>
            <td class="${r.inputQty>0?'td-num':'td-zero'}">${fmt(r.inputQty)}</td>
            <td class="${r.okQty>0?'td-num':'td-zero'}" style="color:${r.okQty>0?'var(--success)':''}">${fmt(r.okQty)}</td>
            <td class="${r.ngQty>0?'td-num':'td-zero'}" style="color:${r.ngQty>0?'var(--danger)':''}">${fmt(r.ngQty)}</td>
            <td class="td-center"><span class="rate-badge ${rCls}">${(r.defectRate??0).toFixed(1)}%</span></td>
            <td class="td-center"><span class="rate-badge ${yCls}">${(r.yieldRate??100).toFixed(1)}%</span></td>`;
        sysDefectTypes.forEach((dt,i) => {
            const v = r.defects ? (r.defects[dt.en] || 0) : 0;
            html += `<td class="td-defect${i===0?' td-defect-first':''}${v>0?' td-defect-nz':''}">${v>0?fmt(v):'<span style="color:#e2e8f0">—</span>'}</td>`;
        });
        html += `</tr>`;
    });
    html += `</tbody></table>`;
    wrap.innerHTML = html;
    const s = start+1, e = Math.min(start+SYS_PAGE, sysRowsRaw.length);
    document.getElementById('sysPgInfo').textContent = t('cmp.pg.showing', {from:s, to:e, total:sysRowsRaw.length});
    renderPg('sysPgCtrl', sysPage, totalPages, p => { sysPage = p; renderSystemTable(); });
}

/* ── PHASE 2: QC Excel ── */
function handleFileUpload(input) { if (input.files[0]) processFile(input.files[0]); }

function readSheetCells(ws) {
    if (!ws['!ref']) return [];
    const range = XLSX.utils.decode_range(ws['!ref']);
    const out = [];
    for (let R = range.s.r; R <= range.e.r; R++) {
        const row = [];
        for (let C = range.s.c; C <= range.e.c; C++) {
            const cell = ws[XLSX.utils.encode_cell({r:R,c:C})];
            if (!cell || cell.v == null) { row.push(''); continue; }
            if (cell.t === 'd' || (cell.t === 'n' && cell.z && /[dDmMyY]/.test(String(cell.z)))) {
                row.push(cell.w || String(cell.v));
            } else {
                row.push(cell.v ?? '');
            }
        }
        out.push(row);
    }
    return out;
}

function processFile(file) {
    if (!file.name.match(/\.(xlsx|xls)$/i)) { showToast(t('cmp.toast.bad_ext'), 'error'); return; }
    showLoading(true, t('cmp.loading.qc'));
    const reader = new FileReader();
    reader.onload = (e) => {
        try {
            const wb = XLSX.read(e.target.result, { type:'array', cellDates:true });
            let sheetName = wb.SheetNames[0];
            for (const n of wb.SheetNames) { if (n.toLowerCase().includes('raw')) { sheetName = n; break; } }
            const ws = wb.Sheets[sheetName];
            const nonEmpty = readSheetCells(ws).filter(r => r.some(c => c !== '' && c != null));
            if (!nonEmpty.length) { showToast(t('cmp.toast.sheet_empty'), 'error'); showLoading(false); return; }

            _rawHeaders = nonEmpty[0].map(h => h instanceof Date ? formatDate(h) : String(h ?? '').trim());
            colMap = detectColumns(_rawHeaders);
            _rawRows = nonEmpty.slice(1)
                .map(r => _rawHeaders.map((_, ci) => String(r[ci] ?? '')))
                .filter(r => parseRowDate(r[colMap.date ?? 0]));
            _sheetName = sheetName;

            const rowsDates = XLSX.utils.sheet_to_json(ws, {header:1, defval:'', cellDates:true});
            const nonEmptyD = rowsDates.filter(r => r.some(c => c !== '' && c != null));
            qcData = parseQCRows(nonEmptyD, 0, colMap);
            qcFiltered = [...qcData];

            document.getElementById('uploadZone').classList.add('has-file');
            document.getElementById('uploadFilename').textContent = `📄 ${file.name}`;
            document.getElementById('qcParseInfo').innerHTML =
                `<span class="data-pill pill-qc">${t('cmp.upload.parsed', {n: _rawRows.length, c: _rawHeaders.length, s: sheetName})}</span>`;

            _rawFiltered = [..._rawRows];
            qcPage = 1;
            const df = document.getElementById('fDateFrom').value;
            const dt = document.getElementById('fDateTo').value;
            if (df) document.getElementById('qcFilterFrom').value = df;
            if (dt) document.getElementById('qcFilterTo').value = dt;
            if (df || dt) applyQCDateFilter();

            renderQcKpi();
            renderQcTable();
            document.getElementById('qcDataWrap').style.display = 'block';
            checkCompareReady();
            document.getElementById('qcDataWrap').scrollIntoView({behavior:'smooth',block:'start'});
            showToast(t('cmp.toast.parse_ok', {n: _rawRows.length, c: _rawHeaders.length}), 'success');
        } catch(err) {
            showToast(t('cmp.toast.parse_fail', {msg: err.message}), 'error');
            console.error(err);
        } finally { showLoading(false); }
    };
    reader.readAsArrayBuffer(file);
}

function formatDate(d) {
    const M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return `${String(d.getUTCDate()).padStart(2,'0')}-${M[d.getUTCMonth()]}-${d.getUTCFullYear()}`;
}

function detectColumns(headers) {
    const find = (kws) => {
        const idx = headers.findIndex(h => kws.some(k => h.toLowerCase().includes(k)));
        return idx >= 0 ? idx : null;
    };
    return {
        date:find(['date','ngày','日期']), partCode:find(['part code','part_code','mã linh','零件']),
        product:find(['product','sản phẩm','产品']), coating:find(['coating','lớp phủ','涂层']),
        process:find(['process','quy trình','công đoạn','工序']),
        inputQty:find(['input qty','input_qty','sl đầu vào','投入量']),
        okQty:find(['ok qty','ok_qty','sl đạt','良品数']),
        ngQty:find(['ng qty','ng_qty','sl lỗi','不良数']),
        outputQty:find(['output qty','output_qty','sl đầu ra','产出量']),
        defectRate:find(['defect rate','tỷ lệ lỗi','不良率']),
        yieldRate:find(['yield rate','tỷ lệ đạt','良品率']),
    };
}

function parseRowDate(str) {
    if (!str) return null;
    if (str instanceof Date) return new Date(str.getFullYear(), str.getMonth(), str.getDate());
    const s = String(str).trim();
    const m1 = s.match(/^(\d{1,2})-([A-Za-z]{3})-(\d{4})$/);
    if (m1) {
        const mo = {jan:0,feb:1,mar:2,apr:3,may:4,jun:5,jul:6,aug:7,sep:8,oct:9,nov:10,dec:11}[m1[2].toLowerCase()];
        return mo != null ? new Date(+m1[3], mo, +m1[1]) : null;
    }
    const m2 = s.match(/^(\d{1,2})[\/-](\d{1,2})[\/-](\d{4})$/);
    if (m2) return new Date(+m2[3], +m2[2]-1, +m2[1]);
    const m3 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (m3) return new Date(+m3[1], +m3[2]-1, +m3[3]);
    return null;
}

function parseQCRows(rows, hdrIdx, cm) {
    const result = [];
    for (let i = hdrIdx + 1; i < rows.length; i++) {
        const r = rows[i];
        if (!r || r.every(c => c === '' || c == null)) continue;
        const dateRaw = cm.date != null ? r[cm.date] : '';
        const dateStr = normalizeDate(dateRaw);
        if (!dateStr) continue;
        const get = (idx) => idx != null ? String(r[idx] ?? '').trim() : '';
        const getNum = (idx) => {
            if (idx == null) return 0;
            const v = r[idx];
            if (v === '' || v == null) return 0;
            const n = parseFloat(String(v).replace(/,/g,'').replace('%',''));
            return isNaN(n) ? 0 : n;
        };
        let defRate = getNum(cm.defectRate), yldRate = getNum(cm.yieldRate);
        if (defRate <= 1 && defRate > 0) defRate *= 100;
        if (yldRate <= 1 && yldRate > 0) yldRate *= 100;
        result.push({
            date:dateStr, partCode:get(cm.partCode).toUpperCase(), product:get(cm.product),
            coating:get(cm.coating) || '-', process:get(cm.process),
            inputQty:getNum(cm.inputQty), okQty:getNum(cm.okQty), ngQty:getNum(cm.ngQty),
            outputQty:getNum(cm.outputQty), defectRate:+defRate.toFixed(1), yieldRate:+yldRate.toFixed(1),
        });
    }
    return result;
}

function normalizeDate(raw) {
    if (!raw) return '';
    if (raw instanceof Date) {
        const M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        return `${String(raw.getUTCDate()).padStart(2,'0')}-${M[raw.getUTCMonth()]}-${raw.getUTCFullYear()}`;
    }
    const s = String(raw).trim();
    if (/^\d{1,2}-[A-Za-z]{3}-\d{4}$/.test(s)) return s;
    const m1 = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
    if (m1) {
        const d = new Date(+m1[3], +m1[2]-1, +m1[1]);
        return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).replace(/ /g, '-');
    }
    const m2 = s.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
    if (m2) {
        const d = new Date(+m2[1], +m2[2]-1, +m2[3]);
        return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).replace(/ /g, '-');
    }
    return s;
}

function renderQcKpi() {
    if (!qcData.length) { ['qcKpiRows','qcKpiInput','qcKpiNG','qcKpiDef'].forEach(id => document.getElementById(id).textContent = '—'); return; }
    const tI = qcData.reduce((s,r) => s+(r.inputQty||0), 0);
    const tN = qcData.reduce((s,r) => s+(r.ngQty   ||0), 0);
    document.getElementById('qcKpiRows').textContent = fmt(qcData.length);
    document.getElementById('qcKpiInput').textContent = fmt(tI);
    document.getElementById('qcKpiNG').textContent    = fmt(tN);
    document.getElementById('qcKpiDef').textContent   = (tI>0?(tN/tI*100):0).toFixed(1)+'%';
}

function applyQCDateFilter() {
    const df = document.getElementById('qcFilterFrom').value;
    const dt = document.getElementById('qcFilterTo').value;
    const dateColIdx = colMap.date ?? 0;
    if (!df && !dt) { _rawFiltered = [..._rawRows]; qcFiltered = [...qcData]; }
    else {
        const from = df ? new Date(df + 'T00:00:00') : null;
        const to   = dt ? new Date(dt + 'T23:59:59') : null;
        _rawFiltered = _rawRows.filter(r => {
            const d = parseRowDate(String(r[dateColIdx]));
            if (!d) return true;
            if (from && d < from) return false;
            if (to   && d > to)   return false;
            return true;
        });
        qcFiltered = qcData.filter(r => {
            const d = parseRowDate(r.date);
            if (!d) return true;
            if (from && d < from) return false;
            if (to   && d > to)   return false;
            return true;
        });
    }
    qcPage = 1;
    document.getElementById('qcBadge').textContent = _rawFiltered.length;
    renderQcTable();
}

function clearQCFilter() {
    document.getElementById('qcFilterFrom').value = '';
    document.getElementById('qcFilterTo').value   = '';
    _rawFiltered = [..._rawRows];
    qcFiltered   = [...qcData];
    qcPage = 1;
    document.getElementById('qcBadge').textContent = _rawRows.length;
    renderQcTable();
}

function renderQcTable() {
    const wrap  = document.getElementById('qcTableScroll');
    const pgBar = document.getElementById('qcPgBar');
    const total = _rawFiltered.length;
    document.getElementById('qcTableTitle').textContent = _sheetName;
    if (!total) { wrap.innerHTML = `<div class="empty"><div class="ei">📭</div><p>${t('cmp.empty.nodata')}</p></div>`; pgBar.style.display = 'none'; return; }
    pgBar.style.display = 'flex';
    const totalPages = Math.ceil(total / QC_PAGE);
    const start = (qcPage - 1) * QC_PAGE;
    const slice = _rawFiltered.slice(start, start + QC_PAGE);
    let html = `<table class="dt"><thead><tr class="th-main">
        ${_rawHeaders.map((h,i) => {
            const isPurple = i >= 11;
            return `<th style="min-width:90px${isPurple?';background:#5b21b6':''};white-space:normal;line-height:1.3">${esc(h)||('Col '+(i+1))}</th>`;
        }).join('')}
    </tr></thead><tbody>`;
    slice.forEach(r => {
        html += '<tr>' + r.map((v, ci) => {
            if (v === '' || v == null) return `<td class="td-zero">—</td>`;
            const s = String(v);
            const cleanS = s.replace(/,/g,'').trim();
            const n = parseFloat(cleanS);
            const isNum = !isNaN(n) && /^-?[\d,\.%]+$/.test(cleanS);
            if (isNum) {
                if (ci === colMap.defectRate) { const pct = n > 1 ? n : n*100; const cls = pct>=10?'rate-bad':pct>=5?'rate-mid':'rate-ok'; return `<td class="td-center"><span class="rate-badge ${cls}">${pct.toFixed(1)}%</span></td>`; }
                if (ci === colMap.yieldRate)  { const pct = n > 1 ? n : n*100; const cls = pct<=90?'rate-bad':pct<=95?'rate-mid':'rate-ok'; return `<td class="td-center"><span class="rate-badge ${cls}">${pct.toFixed(1)}%</span></td>`; }
                const defectStartIdx = Math.max(...Object.values(colMap).filter(v => v != null)) + 1;
                if (ci >= defectStartIdx) return n > 0 ? `<td class="td-num" style="color:#6d28d9;font-weight:700">${fmt(n)}</td>` : `<td class="td-zero">—</td>`;
                return `<td class="td-num">${fmt(n)}</td>`;
            }
            if (ci === 1) return `<td class="td-center" style="font-weight:700;color:var(--denim)">${esc(s)}</td>`;
            if (ci === 0) return `<td style="color:var(--gray-600);font-size:.77rem">${esc(s)}</td>`;
            return `<td>${esc(s)}</td>`;
        }).join('') + '</tr>';
    });
    html += '</tbody></table>';
    wrap.innerHTML = html;
    const s2 = start+1, e2 = Math.min(start+QC_PAGE, total);
    document.getElementById('qcPgInfo').textContent = t('cmp.pg.showing', {from:s2, to:e2, total});
    renderPg('qcPgCtrl', qcPage, totalPages, p => { qcPage = p; renderQcTable(); });
}

function checkCompareReady() {
    document.getElementById('btnCompare').disabled = !(sysData.length > 0 && qcData.length > 0);
}

/* ── PHASE 3: Comparison ── */
function normalizeCoating(c) { return String(c||'').toLowerCase().replace(/[\s\-_]/g, '').trim(); }
function normalizePartCode(p) { return String(p||'').toUpperCase().trim(); }
function makeKey(row) {
    const d = normalizeDate(row.date || '');
    const p = normalizePartCode(row.partCode);
    const ct = normalizeCoating(row.coating);
    return `${d}||${p}||${ct}`;
}
function makePartKey(row) {
    const d = normalizeDate(row.date || '');
    const p = normalizePartCode(row.partCode);
    return `${d}||${p}`;
}

function runComparison() {
    showLoading(true, t('cmp.loading.cmp'));
    setTimeout(() => {
        try {
            cmpRows = mergeData(sysData, qcFiltered.length > 0 ? qcFiltered : qcData);
            setFilter('all');
            renderCmpKpi();
            document.getElementById('cmpDataWrap').style.display = 'block';
            document.getElementById('btnExport').disabled = false;
            document.getElementById('cmpDataWrap').scrollIntoView({behavior:'smooth',block:'start'});
            showToast(t('cmp.toast.cmp_ok', {n: cmpRows.length}), 'success');
        } catch(e) {
            showToast(t('cmp.toast.cmp_fail', {msg: e.message}), 'error');
            console.error(e);
        } finally { showLoading(false); }
    }, 50);
}

function mergeData(sys, qc) {
    const sysMap = new Map();
    sys.forEach(r => { const k = makeKey(r); if (!sysMap.has(k)) sysMap.set(k, []); sysMap.get(k).push(r); });
    const qcMap = new Map();
    qc.forEach(r => { const k = makeKey(r); if (!qcMap.has(k)) qcMap.set(k, []); qcMap.get(k).push(r); });
    const sysByPart = new Map();
    sys.forEach(r => { const k = makePartKey(r); if (!sysByPart.has(k)) sysByPart.set(k, []); sysByPart.get(k).push(r); });
    const allKeys = new Set([...sysMap.keys(), ...qcMap.keys()]);
    const result = []; const usedSys = new Set();
    allKeys.forEach(k => {
        let sysRows = sysMap.get(k) || [];
        const qcRows = qcMap.get(k) || [];
        if (qcRows.length > 0 && sysRows.length === 0) {
            const [datePart, partPart] = k.split('||');
            const candidates = (sysByPart.get(`${datePart}||${partPart}`) || []).filter(r => !usedSys.has(r));
            if (candidates.length > 0) sysRows = candidates;
        }
        const maxLen = Math.max(sysRows.length, qcRows.length);
        for (let i = 0; i < maxLen; i++) {
            const s = sysRows[i] || null; const q = qcRows[i] || null;
            if (s) usedSys.add(s);
            const base = s || q;
            result.push({
                key:k+'_'+i, date:base.date, partCode:base.partCode,
                product:s?.product || q?.product || '', coating:s?.coating || q?.coating || '-',
                process:s?.process || q?.process || '',
                source:s && q ? 'both' : s ? 'sys' : 'qc',
                sys:s, qc:q, gaps:computeGaps(s, q),
            });
        }
    });
    return result.sort((a,b) => { if (a.date < b.date) return 1; if (a.date > b.date) return -1; return a.partCode.localeCompare(b.partCode); });
}

function computeGaps(s, q) {
    if (!s || !q) return null;
    const gap = (sv, qv) => {
        const diff = (sv||0) - (qv||0);
        const pct = sv > 0 ? Math.abs(diff)/sv*100 : (diff !== 0 ? 100 : 0);
        return { diff, pct: +pct.toFixed(1), sv: sv||0, qv: qv||0 };
    };
    return {
        inputQty:gap(s.inputQty, q.inputQty), okQty:gap(s.okQty, q.okQty),
        ngQty:gap(s.ngQty, q.ngQty), outputQty:gap(s.outputQty, q.outputQty),
        defectRate:gap(s.defectRate, q.defectRate), yieldRate:gap(s.yieldRate, q.yieldRate),
    };
}

function hasSignificantGap(row) {
    if (!row.gaps) return false;
    const thr = parseFloat(document.getElementById('gapThreshold').value) || 5;
    return Object.values(row.gaps).some(g => g.pct > thr || Math.abs(g.diff) > 0);
}

function renderCmpKpi() {
    const total = cmpRows.length;
    const unmatched = cmpRows.filter(r => r.source !== 'both').length;
    const matched = cmpRows.filter(r => r.source === 'both');
    const withGap = matched.filter(r => hasSignificantGap(r)).length;
    const perfect = matched.length - withGap;
    document.getElementById('kpiTotal').textContent = total;
    document.getElementById('kpiMatch').textContent = perfect;
    document.getElementById('kpiGap').textContent = withGap;
    document.getElementById('kpiUnmatched').textContent = unmatched;
}

function setFilter(f) {
    activeFilter = f;
    if (f === 'all')          filteredRows = [...cmpRows];
    else if (f === 'gap')     filteredRows = cmpRows.filter(r => r.source === 'both' && hasSignificantGap(r));
    else if (f === 'sysonly') filteredRows = cmpRows.filter(r => r.source === 'sys');
    else if (f === 'qconly')  filteredRows = cmpRows.filter(r => r.source === 'qc');
    ['ftAll','ftGap','ftSys','ftQC'].forEach(id => document.getElementById(id).classList.remove('active'));
    document.getElementById(f === 'all' ? 'ftAll' : f === 'gap' ? 'ftGap' : f === 'sysonly' ? 'ftSys' : 'ftQC').classList.add('active');
    cmpPage = 1;
    renderCmpTable();
}

function renderCmpTable() {
    const wrap = document.getElementById('cmpTableScroll');
    const pgBar = document.getElementById('cmpPgBar');
    document.getElementById('cmpBadge').textContent = filteredRows.length;
    if (!filteredRows.length) { wrap.innerHTML = `<div class="empty"><div class="ei">🔍</div><p>${t('cmp.empty.filter')}</p></div>`; pgBar.style.display = 'none'; return; }
    pgBar.style.display = 'flex';
    const totalPages = Math.ceil(filteredRows.length / CMP_PAGE);
    const start = (cmpPage - 1) * CMP_PAGE;
    const rows = filteredRows.slice(start, start + CMP_PAGE);
    const thr = parseFloat(document.getElementById('gapThreshold').value) || 5;

    const gapBadge = (g, isRate) => {
        if (!g) return `<span class="gap-badge gap-na">${t('cmp.gap.na')}</span>`;
        const sign = g.diff > 0 ? '+' : g.diff < 0 ? '' : '';
        const lbl = isRate ? `${sign}${g.diff.toFixed(1)}%` : `${sign}${fmt(g.diff)}`;
        const cls = g.diff === 0 ? 'gap-0' : g.pct > thr ? 'gap-high' : 'gap-low';
        return `<span class="gap-badge ${cls}">${lbl}</span>`;
    };
    const valCell = (v, isRate, has) => {
        if (!has) return `<td class="td-zero td-center">—</td>`;
        if (isRate) return `<td class="td-num">${v?.toFixed(1) ?? '—'}%</td>`;
        return `<td class="${v > 0 ? 'td-num' : 'td-zero'}">${fmt(v)}</td>`;
    };

    let html = `<table class="dt">
    <thead>
        <tr class="th-group">
            <th class="thg-identity" colspan="6">${t('cmp.thg.identity')}</th>
            <th class="thg-input"    colspan="3">${t('cmp.thg.input')}</th>
            <th class="thg-ok"       colspan="3">${t('cmp.thg.ok')}</th>
            <th class="thg-ng"       colspan="3">${t('cmp.thg.ng')}</th>
            <th class="thg-rate"     colspan="3">${t('cmp.thg.defrate')}</th>
            <th class="thg-rate"     colspan="3">${t('cmp.thg.yldrate')}</th>
        </tr>
        <tr class="th-main">
            <th class="th-left"  style="min-width:100px">${t('cmp.th.date')}</th>
            <th                  style="min-width:80px">${t('cmp.th.partcode')}</th>
            <th class="th-left"  style="min-width:160px">${t('cmp.th.product')}</th>
            <th                  style="min-width:110px">${t('cmp.th.coating')}</th>
            <th class="th-left"  style="min-width:120px">${t('cmp.th.process')}</th>
            <th                  style="min-width:70px">${t('cmp.th.source')}</th>
            <th class="th-metric-sys" style="min-width:74px">Sys</th><th class="th-metric-qc" style="min-width:74px">QC</th><th class="th-metric-gap" style="min-width:70px">Gap</th>
            <th class="th-metric-sys" style="min-width:74px">Sys</th><th class="th-metric-qc" style="min-width:74px">QC</th><th class="th-metric-gap" style="min-width:70px">Gap</th>
            <th class="th-metric-sys" style="min-width:74px">Sys</th><th class="th-metric-qc" style="min-width:74px">QC</th><th class="th-metric-gap" style="min-width:70px">Gap</th>
            <th class="th-metric-sys" style="min-width:74px">Sys</th><th class="th-metric-qc" style="min-width:74px">QC</th><th class="th-metric-gap" style="min-width:70px">Gap</th>
            <th class="th-metric-sys" style="min-width:74px">Sys</th><th class="th-metric-qc" style="min-width:74px">QC</th><th class="th-metric-gap" style="min-width:70px">Gap</th>
        </tr>
    </thead><tbody>`;
    rows.forEach(r => {
        const s = r.sys, q = r.qc, g = r.gaps;
        const cls = r.source === 'sys' ? 'row-sys-only' : r.source === 'qc' ? 'row-qc-only' : '';
        const srcB = r.source === 'both'
            ? `<span class="src-badge src-both">${t('cmp.src.both')}</span>`
            : r.source === 'sys' ? `<span class="src-badge src-sys">${t('cmp.src.sys')}</span>` : `<span class="src-badge src-qc">${t('cmp.src.qc')}</span>`;
        html += `<tr class="${cls}">
            <td style="color:var(--gray-600);font-size:.76rem">${esc(r.date||'')}</td>
            <td class="td-center" style="font-weight:700;color:var(--denim)">${esc(r.partCode||'—')}</td>
            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis" title="${esc(r.product||'')}">${esc(r.product||'—')}</td>
            <td class="td-center">${colorBadge(r.coating)}</td>
            <td style="color:var(--gray-700)">${esc(r.process||'—')}</td>
            <td class="td-center">${srcB}</td>
            ${valCell(s?.inputQty,false,!!s)}${valCell(q?.inputQty,false,!!q)}<td class="td-center">${gapBadge(g?.inputQty,false)}</td>
            ${valCell(s?.okQty,false,!!s)}${valCell(q?.okQty,false,!!q)}<td class="td-center">${gapBadge(g?.okQty,false)}</td>
            ${valCell(s?.ngQty,false,!!s)}${valCell(q?.ngQty,false,!!q)}<td class="td-center">${gapBadge(g?.ngQty,false)}</td>
            ${valCell(s?.defectRate,true,!!s)}${valCell(q?.defectRate,true,!!q)}<td class="td-center">${gapBadge(g?.defectRate,true)}</td>
            ${valCell(s?.yieldRate,true,!!s)}${valCell(q?.yieldRate,true,!!q)}<td class="td-center">${gapBadge(g?.yieldRate,true)}</td>
        </tr>`;
    });
    html += `</tbody></table>`;
    wrap.innerHTML = html;
    const s2 = start+1, e2 = Math.min(start+CMP_PAGE, filteredRows.length);
    document.getElementById('cmpPgInfo').textContent = t('cmp.pg.showing', {from:s2, to:e2, total:filteredRows.length});
    renderPg('cmpPgCtrl', cmpPage, totalPages, p => { cmpPage = p; renderCmpTable(); });
}

function exportComparison() {
    if (!cmpRows.length) { showToast(t('cmp.toast.export_nodata'), 'error'); return; }
    const wb = XLSX.utils.book_new();
    const df = document.getElementById('fDateFrom').value || 'all';
    const dt = document.getElementById('fDateTo').value   || fmtDate(new Date());
    const hdrs = ['Date','Part Code','Product','Coating','Process','Source','Input Qty (Sys)','Input Qty (QC)','Input Qty Gap','OK Qty (Sys)','OK Qty (QC)','OK Qty Gap','NG Qty (Sys)','NG Qty (QC)','NG Qty Gap','Defect Rate (Sys)','Defect Rate (QC)','Defect Rate Gap','Yield Rate (Sys)','Yield Rate (QC)','Yield Rate Gap'];
    const aoa = [[`QC vs SYSTEM COMPARISON — ${df} → ${dt}`], [`Generated: ${new Date().toLocaleString('vi-VN')}`], [], hdrs];
    filteredRows.forEach(r => {
        const s = r.sys, q = r.qc, g = r.gaps;
        aoa.push([
            r.date, r.partCode, r.product, r.coating, r.process, r.source.toUpperCase(),
            s?.inputQty ?? '', q?.inputQty ?? '', g?.inputQty?.diff ?? '',
            s?.okQty ?? '', q?.okQty ?? '', g?.okQty?.diff ?? '',
            s?.ngQty ?? '', q?.ngQty ?? '', g?.ngQty?.diff ?? '',
            s?.defectRate != null ? s.defectRate/100 : '', q?.defectRate != null ? q.defectRate/100 : '', g?.defectRate?.diff != null ? g.defectRate.diff/100 : '',
            s?.yieldRate != null ? s.yieldRate/100 : '',   q?.yieldRate != null ? q.yieldRate/100 : '', g?.yieldRate?.diff != null ? g.yieldRate.diff/100 : '',
        ]);
    });
    const ws = XLSX.utils.aoa_to_sheet(aoa);
    ws['!cols'] = [{wch:14},{wch:10},{wch:24},{wch:14},{wch:18},{wch:10},{wch:14},{wch:14},{wch:12},{wch:12},{wch:12},{wch:12},{wch:12},{wch:12},{wch:12},{wch:16},{wch:16},{wch:14},{wch:16},{wch:16},{wch:14}];
    for (let ri = 4; ri < 4 + filteredRows.length; ri++) {
        [15,16,17,18,19,20].forEach(ci => {
            const ref = XLSX.utils.encode_cell({r:ri,c:ci});
            if (ws[ref] && ws[ref].v !== '') ws[ref].z = '0.0%';
        });
    }
    ws['!autofilter'] = { ref: `A4:U4` };
    XLSX.utils.book_append_sheet(wb, ws, 'Comparison');
    const stamp = new Date().toISOString().slice(0,10);
    XLSX.writeFile(wb, `QC_Comparison_${df}_${dt}_${stamp}.xlsx`);
    showToast(t('cmp.toast.export_ok', {n: filteredRows.length}), 'success');
}

function renderPg(elId, page, totalPages, onClick) {
    const ctrl = document.getElementById(elId); ctrl.innerHTML = '';
    const add = (l,p,d,a) => {
        const b = document.createElement('button');
        b.className = 'pg-btn' + (a?' active':'');
        b.textContent = l; b.disabled = d;
        b.onclick = () => onClick(p);
        ctrl.appendChild(b);
    };
    add('«',1,page===1,false); add('‹',page-1,page===1,false);
    for (let p=Math.max(1,page-2);p<=Math.min(totalPages,page+2);p++) add(p,p,false,p===page);
    add('›',page+1,page===totalPages,false); add('»',totalPages,page===totalPages,false);
}

function colorBadge(c) {
    if (!c||c==='-') return `<span class="color-tag color-none">—</span>`;
    const l = c.toLowerCase();
    if (l.includes('matt')||l.includes('black')) return `<span class="color-tag color-matte">${esc(c)}</span>`;
    if (l.includes('chrome'))                    return `<span class="color-tag color-chrome">${esc(c)}</span>`;
    if (l.includes('brass'))                     return `<span class="color-tag color-brass">${esc(c)}</span>`;
    if (l.includes('beige'))                     return `<span class="color-tag color-beige">${esc(c)}</span>`;
    return `<span class="color-tag color-other">${esc(c)}</span>`;
}

function fmt(n) { return n==null||n===0?'0':Number(n).toLocaleString('en-US'); }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function showLoading(v, msg) {
    document.getElementById('loading').classList.toggle('show', v);
    if (msg) document.getElementById('loadingMsg').textContent = msg;
}
function showToast(msg, type='info') {
    const el = document.getElementById('toast');
    el.className = 'toast ' + type;
    document.getElementById('toastIcon').textContent = type==='success'?'✅':type==='error'?'❌':'ℹ️';
    document.getElementById('toastMsg').textContent  = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 3500);
}
</script>
}
