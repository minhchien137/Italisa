@{
    ViewData["Title"] = "Defect Upload";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <style>
        :root {
            --denim:#1B4F8A;--denim-dark:#0f2f52;--denim-mid:#2563a8;
            --denim-light:#dbeafe;--denim-xlight:#eff6ff;
            --white:#fff;--gray-50:#f8fafc;--gray-100:#f1f5f9;
            --gray-200:#e2e8f0;--gray-300:#cbd5e1;--gray-400:#94a3b8;
            --gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;
            --success:#10b981;--warning:#f59e0b;--danger:#ef4444;
            --shadow-sm:0 1px 3px rgba(27,79,138,.08);
            --shadow-md:0 4px 20px rgba(27,79,138,.12);
        }
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'DM Sans',sans-serif;background:var(--gray-50);min-height:100vh;
            background-image:radial-gradient(ellipse at 20% 50%,rgba(27,79,138,.06) 0%,transparent 60%),
                             radial-gradient(ellipse at 80% 20%,rgba(37,99,168,.05) 0%,transparent 50%)}
        .page-wrapper{max-width:1400px;margin:0 auto;padding:2rem 1.5rem}
        .page-header{margin-bottom:1.5rem}
        .page-header h1{font-family:'Space Grotesk',sans-serif;font-size:1.7rem;font-weight:700;color:var(--denim-dark);display:flex;align-items:center;gap:10px}
        .page-header p{color:var(--gray-600);font-size:.9rem;margin-top:6px}
        .header-line{width:48px;height:4px;background:linear-gradient(90deg,var(--denim),var(--denim-mid));border-radius:2px;margin-top:10px}
        .step-card{background:var(--white);border-radius:14px;border:1px solid rgba(27,79,138,.1);box-shadow:var(--shadow-sm);margin-bottom:1.25rem}
        .step-card.done{border-color:var(--success)}
        .step-header{background:var(--denim-xlight);padding:.85rem 1.25rem;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(27,79,138,.08);border-radius:14px 14px 0 0}
        .step-header.done{background:#ecfdf5;border-bottom-color:rgba(16,185,129,.15)}
        .step-num{width:28px;height:28px;border-radius:50%;background:var(--denim);color:var(--white);display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:.82rem;font-weight:700;flex-shrink:0}
        .step-num.done{background:var(--success)}
        .step-title{font-family:'Space Grotesk',sans-serif;font-size:.92rem;font-weight:600;color:var(--denim-dark)}
        .step-status{margin-left:auto;font-size:.75rem;font-weight:600;color:var(--gray-400)}
        .step-status.done{color:var(--success)}
        .step-body{padding:1.1rem 1.25rem}
        .upload-zone{border:2px dashed var(--gray-200);border-radius:12px;padding:2.5rem 2rem;text-align:center;cursor:pointer;transition:all .2s;background:var(--white);position:relative}
        .upload-zone:hover,.upload-zone.drag-over{border-color:var(--denim);background:var(--denim-xlight)}
        .upload-zone.has-file{border-color:var(--success);background:#f0fdf4}
        .upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
        .upload-icon{font-size:2.5rem;margin-bottom:.6rem}
        .upload-title{font-weight:600;color:var(--denim-dark);font-size:.95rem}
        .upload-sub{font-size:.78rem;color:var(--gray-400);margin-top:4px}
        .upload-filename{font-size:.85rem;font-weight:600;color:var(--success);margin-top:8px}
        .sheet-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:.85rem}
        .sheet-tab{padding:4px 12px;border-radius:20px;font-size:.78rem;font-weight:600;cursor:pointer;border:1.5px solid var(--gray-200);background:var(--white);color:var(--gray-600);transition:all .15s}
        .sheet-tab:hover{border-color:var(--denim);color:var(--denim)}
        .sheet-tab.active{background:var(--denim);color:var(--white);border-color:var(--denim)}
        .section-title{font-size:.7rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.65rem;display:flex;align-items:center;gap:8px}
        .section-title::after{content:'';flex:1;height:1px;background:var(--gray-200)}
        .col-map-panel{background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:1rem;margin-top:1rem}
        .col-map-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem}
        @@media(min-width:640px){.col-map-grid{grid-template-columns:repeat(3,1fr)}}
        @@media(min-width:1000px){.col-map-grid{grid-template-columns:repeat(4,1fr)}}
        .col-map-item{display:flex;flex-direction:column;gap:4px}
        .col-map-item label{font-size:.67rem;font-weight:700;color:var(--denim-dark);text-transform:uppercase;letter-spacing:.3px}
        .col-map-item label .req{color:var(--danger)}
        .col-map-item select{width:100%;padding:.42rem .6rem;border:1.5px solid var(--gray-200);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:.78rem;color:var(--gray-800);background:var(--white);outline:none;cursor:pointer;transition:border-color .2s;appearance:none}
        .col-map-item select:focus{border-color:var(--denim)}
        .col-map-item select.mapped{border-color:var(--success);background:#f0fdf4}
        .col-def{width:100%;margin-top:3px;padding:.32rem .6rem;border:1.5px dashed var(--gray-300);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:.74rem;color:var(--gray-700);background:#fffbeb;outline:none;appearance:none}
        .col-def:focus{border-color:var(--warning)}
        .col-def::placeholder{color:var(--gray-400);font-style:italic}

        /* Defect column chips */
        .defect-cols-panel{background:#faf5ff;border:1.5px solid #e9d5ff;border-radius:10px;padding:1rem;margin-top:1rem}
        .defect-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:.65rem}
        .defect-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:.74rem;font-weight:600;cursor:pointer;border:1.5px solid #c4b5fd;background:#f5f3ff;color:#5b21b6;transition:all .15s;user-select:none}
        .defect-chip:hover{background:#ede9fe}
        .defect-chip.selected{background:#7c3aed;color:var(--white);border-color:#7c3aed}
        .defect-chip input[type=checkbox]{display:none}
        .chip-count{font-size:.65rem;opacity:.7}

        /* Preview */
        .preview-wrap{margin-top:.85rem;border-radius:9px;border:1px solid var(--gray-200);overflow:hidden}
        .preview-scroll{overflow-x:auto;max-height:180px;overflow-y:auto}
        .preview-tbl{border-collapse:collapse;font-size:.75rem;white-space:nowrap}
        .preview-tbl th{background:var(--denim);color:var(--white);padding:7px 12px;position:sticky;top:0;z-index:1;font-size:.71rem;font-weight:600;border-right:1px solid rgba(255,255,255,.12)}
        .preview-tbl td{padding:5px 12px;border-bottom:1px solid var(--gray-100);border-right:1px solid var(--gray-100);color:var(--gray-700)}
        .preview-tbl tr:nth-child(even) td{background:var(--gray-50)}

        .btn{padding:.55rem 1.1rem;border-radius:8px;border:none;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap;display:inline-flex;align-items:center;gap:6px}
        .btn-primary{background:var(--denim);color:var(--white)}
        .btn-primary:hover:not(:disabled){background:var(--denim-dark)}
        .btn-review{background:linear-gradient(135deg,#7c3aed 0%,#5b21b6 100%);color:var(--white);font-size:.95rem;padding:.7rem 1.6rem}
        .btn-review:hover:not(:disabled){filter:brightness(1.1)}
        .btn-success{background:#059669;color:var(--white)}
        .btn-success:hover:not(:disabled){background:#047857}
        .btn-outline{background:var(--white);color:var(--denim);border:1.5px solid var(--denim-light)}
        .btn-outline:hover:not(:disabled){background:var(--denim-xlight)}
        .btn:disabled{opacity:.45;cursor:not-allowed}
        .btn-sm{padding:.35rem .8rem;font-size:.78rem}

        .kpi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;margin-bottom:1.25rem}
        @@media(min-width:600px){.kpi-grid{grid-template-columns:repeat(4,1fr)}}
        .kpi-card{background:var(--white);border-radius:12px;border:1px solid rgba(27,79,138,.08);box-shadow:var(--shadow-sm);padding:1rem 1.1rem;display:flex;flex-direction:column;gap:4px}
        .kpi-label{font-size:.7rem;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.3px}
        .kpi-value{font-family:'Space Grotesk',sans-serif;font-size:1.55rem;font-weight:700;color:var(--denim-dark)}
        .kpi-value.green{color:var(--success)}
        .kpi-sub{font-size:.75rem;color:var(--gray-400)}
        .info-chip{display:inline-flex;align-items:center;gap:5px;background:var(--denim-xlight);color:var(--denim);border-radius:20px;padding:3px 10px;font-size:.76rem;font-weight:600}
        .info-chip.vendor{background:#fef3c7;color:#92400e}
        .info-chip.type{background:#f3e8ff;color:#6b21a8}

        .save-bar{background:linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%);border:1.5px solid rgba(16,185,129,.3);border-radius:12px;padding:.9rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
        .action-bar{background:var(--white);border-radius:14px;border:1px solid rgba(27,79,138,.08);box-shadow:var(--shadow-sm);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem}

        .table-card{background:var(--white);border-radius:14px;border:1px solid rgba(27,79,138,.08);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:1.5rem}
        .table-card-header{background:linear-gradient(135deg,var(--denim-dark) 0%,var(--denim) 100%);padding:.9rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
        .table-card-header h3{font-family:'Space Grotesk',sans-serif;font-size:.92rem;font-weight:600;color:var(--white);display:flex;align-items:center;gap:8px}
        .badge{background:rgba(255,255,255,.2);color:var(--white);border-radius:20px;padding:2px 9px;font-size:.72rem;font-weight:600}
        .table-scroll{overflow-x:auto}
        .review-table{width:100%;border-collapse:collapse;font-size:.8rem}
        .review-table thead th{background:var(--denim);color:var(--white);padding:8px 10px;text-align:left;white-space:nowrap;font-size:.74rem;font-weight:600;border-right:1px solid rgba(255,255,255,.15)}
        .review-table thead th.tc{text-align:center}
        .review-table tbody td{padding:7px 10px;border-bottom:1px solid var(--gray-100);border-right:1px solid var(--gray-100);vertical-align:middle;white-space:nowrap}
        .review-table tbody tr:nth-child(even) td{background:var(--gray-50)}
        .review-table tbody tr:hover td{background:var(--denim-xlight)}
        .review-table tbody tr.row-selected td{background:#eff6ff !important}
        .tc{text-align:center}
        .tn{text-align:right;font-variant-numeric:tabular-nums}
        .status-badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.7rem;font-weight:700}
        .s-pending{background:#fef3c7;color:#92400e}
        .s-saved{background:#dcfce7;color:#166534}
        .s-error{background:#fee2e2;color:#991b1b}

        .pagination-bar{padding:.85rem 1.5rem;border-top:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
        .pagination-info{font-size:.8rem;color:var(--gray-600)}
        .pagination-controls{display:flex;gap:4px}
        .pg-btn{min-width:30px;height:30px;padding:0 7px;border:1.5px solid var(--gray-200);border-radius:7px;background:var(--white);color:var(--gray-800);font-family:'DM Sans',sans-serif;font-size:.8rem;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center}
        .pg-btn:hover:not(:disabled){border-color:var(--denim);color:var(--denim)}
        .pg-btn.active{background:var(--denim);color:var(--white);border-color:var(--denim);font-weight:700}
        .pg-btn:disabled{opacity:.4;cursor:not-allowed}
        .empty-state{padding:3rem;text-align:center;color:var(--gray-400)}
        .empty-state .ei{font-size:2.8rem;margin-bottom:.75rem}

        .loading-overlay{position:fixed;inset:0;background:rgba(15,47,82,.4);display:flex;align-items:center;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .2s}
        .loading-overlay.show{opacity:1;pointer-events:all}
        .loading-box{background:var(--white);border-radius:14px;padding:2rem 2.5rem;text-align:center;box-shadow:var(--shadow-md)}
        .spinner{width:38px;height:38px;margin:0 auto .9rem;border:3px solid var(--denim-light);border-top-color:var(--denim);border-radius:50%;animation:spin .8s linear infinite}
        @@keyframes spin{to{transform:rotate(360deg)}}
        .loading-msg{color:var(--denim-dark);font-weight:600;font-size:.88rem}
        .toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9000;background:var(--white);border-radius:10px;box-shadow:var(--shadow-md);padding:.8rem 1.2rem;display:flex;align-items:center;gap:9px;min-width:270px;opacity:0;transform:translateY(10px);transition:opacity .25s,transform .25s;pointer-events:none}
        .toast.show{opacity:1;transform:translateY(0);pointer-events:all}
        .toast.success{border-left:4px solid var(--success)}
        .toast.error{border-left:4px solid var(--danger)}
        .toast.info{border-left:4px solid var(--denim)}
        #toastMsg{font-size:.85rem;color:var(--gray-800)}
        #reviewSection{display:none}
    </style>
</head>
<body>
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-box"><div class="spinner"></div>
    <p class="loading-msg" id="loadingMsg">Đang xử lý...</p></div>
</div>
<div class="toast" id="toast"><span id="toastIcon">ℹ️</span><span id="toastMsg"></span></div>

<div class="page-wrapper">
<div class="page-header">
    <h1>📤 Defect Upload</h1>
    <p>Upload file Excel (Raw Data tab) — tự động nhận diện cột lỗi, unpivot và lưu vào hệ thống.</p>
    <div class="header-line"></div>
</div>

<!-- STEP 1 -->
<div class="step-card" id="cardStep1">
    <div class="step-header" id="hdrStep1">
        <div class="step-num" id="numStep1">1</div>
        <span class="step-title">Upload File Excel</span>
        <span class="step-status" id="statusStep1">Chưa chọn file</span>
    </div>
    <div class="step-body">
        <div class="upload-zone" id="uploadZone">
            <input type="file" id="fileInput" accept=".xlsx,.xls,.csv" />
            <div class="upload-icon">📂</div>
            <div class="upload-title">Kéo thả file vào đây hoặc nhấn để chọn</div>
            <div class="upload-sub">Hỗ trợ: .xlsx, .xls · Chọn tab Raw Data</div>
            <div class="upload-filename" id="uploadFilename" style="display:none"></div>
        </div>

        <!-- Sheet selector -->
        <div id="sheetSelectorWrap" style="display:none;margin-top:1rem">
            <div class="section-title">Chọn Sheet</div>
            <div class="sheet-tabs" id="sheetTabs"></div>
        </div>

        <!-- Column mapping -->
        <div id="colMapWrap" style="display:none;margin-top:1.1rem">
            <div class="section-title">Ánh xạ cột cố định</div>
            <div class="col-map-panel">
                <div class="col-map-grid">
                    <div class="col-map-item">
                        <label>Date <span class="req">*</span></label>
                        <select id="mapDate"><option value="">-- chọn cột --</option></select>
                        <input type="date" class="col-def" id="defDate" />
                    </div>
                    <div class="col-map-item">
                        <label>Part Code → Product ID <span class="req">*</span></label>
                        <select id="mapPartCode"><option value="">-- chọn cột --</option></select>
                        <select class="col-def" id="defPartCode"><option value="">-- Chọn Process trước --</option></select>
                    </div>
                    <div class="col-map-item">
                        <label>Process</label>
                        <select id="mapProcess"><option value="">-- chọn cột --</option></select>
                        <select class="col-def" id="defProcess" onchange="onDefaultProcessChange()"><option value="">-- Mặc định --</option></select>
                    </div>
                    <div class="col-map-item">
                        <label>Coating / Color</label>
                        <select id="mapColor"><option value="">-- chọn cột --</option></select>
                        <select class="col-def" id="defColor"><option value="">-- Mặc định --</option></select>
                    </div>
                    <div class="col-map-item">
                        <label>Vendor <small style="color:var(--gray-400);text-transform:none">★ default</small></label>
                        <select id="mapVendor"><option value="">-- chọn cột --</option></select>
                        <select class="col-def" id="defVendor"><option value="">-- Mặc định --</option></select>
                    </div>
                    <!-- Type -->
                    <div class="col-map-item">
                        <label>Type <span style="color:var(--gray-400);font-size:.6rem;text-transform:none">★ Defect</span></label>
                        <select id="mapType"><option value="">-- chọn cột --</option></select>
                        <select class="col-def" id="defType">
                            <option value="Defect" selected>Defect</option>
                            <option value="Production Qty">Production Qty</option>
                            <option value="Man Q'ty">Man Q'ty</option>
                        </select>
                    </div>
                    <!-- Quantity -->
                    <div class="col-map-item">
                        <label>Quantity</label>
                        <select id="mapQuantity"><option value="">-- chọn cột --</option></select>
                        <input type="number" class="col-def" id="defQuantity" placeholder="mặc định..." min="0" />
                    </div>
                    <!-- Description -->
                    <div class="col-map-item">
                        <label>Description</label>
                        <select id="mapDesc"><option value="">-- chọn cột --</option></select>
                        <input type="text" class="col-def" id="defDesc" placeholder="nhập mặc định…" />
                    </div>
                </div>
            </div>

            <!-- Defect columns -->
            <div class="defect-cols-panel" id="defectColsPanel" style="display:none">
                <div class="section-title" style="color:#6b21a8">🐛 Cột Defect được nhận diện
                    <button class="btn btn-sm" style="background:#f5f3ff;color:#6b21a8;border:1px solid #c4b5fd;margin-left:auto" onclick="toggleAllDefectCols(true)">☑ Chọn tất</button>
                    <button class="btn btn-sm" style="background:#f5f3ff;color:#6b21a8;border:1px solid #c4b5fd" onclick="toggleAllDefectCols(false)">☐ Bỏ chọn</button>
                </div>
                <p style="font-size:.76rem;color:#7c3aed;margin-bottom:.5rem">
                    Mỗi cột được chọn sẽ tạo <strong>1 bản ghi riêng</strong> trong bảng Production với <code>type_value="Defect"</code>, <code>defect_name=tên cột</code>, <code>product_qty=giá trị</code> — chỉ với dòng có giá trị &gt; 0.
                </p>
                <div class="defect-chips" id="defectChips"></div>
                <div style="margin-top:.75rem;font-size:.76rem;color:#9333ea" id="defectColCount"></div>
            </div>

            <!-- Preview -->
            <div id="previewWrap" style="display:none;margin-top:1.1rem">
                <div class="section-title">Preview (5 dòng đầu)</div>
                <div class="preview-wrap">
                    <div class="preview-scroll">
                        <table class="preview-tbl">
                            <thead id="previewThead"></thead>
                            <tbody id="previewTbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div style="margin-top:1rem;display:flex;gap:.75rem;align-items:center;flex-wrap:wrap">
                <button class="btn btn-review" id="btnReview" disabled onclick="doReview()">
                    🔍 Review & Unpivot dữ liệu
                </button>
                <span id="parseInfo" style="font-size:.8rem;color:var(--gray-600);font-weight:500"></span>
            </div>
        </div>
    </div>
</div>

<!-- STEP 2: Review -->
<div id="reviewSection">
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label">Tổng bản ghi</div>
            <div class="kpi-value" id="kpiTotal">0</div>
            <div class="kpi-sub">sau unpivot</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Đã chọn lưu</div>
            <div class="kpi-value green" id="kpiSelected">0</div>
            <div class="kpi-sub">bản ghi</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Loại lỗi</div>
            <div class="kpi-value" id="kpiDefectTypes">0</div>
            <div class="kpi-sub">unique defect names</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Tổng SL lỗi</div>
            <div class="kpi-value" style="color:var(--danger)" id="kpiTotalQty">0</div>
            <div class="kpi-sub">product_qty tổng cộng</div>
        </div>
    </div>

    <div class="save-bar" id="saveBar" style="display:none">
        <div style="display:flex;align-items:center;gap:10px">
            <span style="font-size:1.4rem">💾</span>
            <div>
                <div style="font-size:.88rem;color:#065f46;font-weight:600" id="saveBarText">Sẵn sàng lưu</div>
                <div style="font-size:.76rem;color:#059669" id="saveBarSub">Chọn bản ghi muốn lưu rồi nhấn Save</div>
            </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn btn-outline btn-sm" onclick="selectAll()">☑ Chọn tất cả</button>
            <button class="btn btn-outline btn-sm" onclick="deselectAll()">☐ Bỏ chọn</button>
            <button class="btn btn-success" id="btnSave" onclick="doSave()" disabled>💾 Lưu bản ghi đã chọn</button>
        </div>
    </div>

    <div class="action-bar">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span style="font-family:'Space Grotesk',sans-serif;font-weight:600;color:var(--denim-dark);font-size:.88rem">📊 Review dữ liệu Defect (unpivoted)</span>
            <span class="badge" style="background:var(--denim);color:var(--white)" id="actionBadge">0</span>
        </div>
        <div style="display:flex;gap:8px">
            <button class="btn btn-outline btn-sm" onclick="backToUpload()">↩ Upload lại</button>
            <button class="btn btn-outline btn-sm" onclick="exportReview()">📥 Xuất Excel</button>
        </div>
    </div>

    <div class="table-card">
        <div class="table-card-header">
            <h3>🐛 Danh sách Defect Records <span class="badge" id="tblBadge">0</span></h3>
            <span style="font-size:.75rem;color:rgba(255,255,255,.7)">1 dòng Excel → N bản ghi (N = số loại lỗi có giá trị > 0)</span>
        </div>
        <div class="table-scroll">
            <table class="review-table">
                <thead>
                    <tr>
                        <th class="tc" style="width:36px"><input type="checkbox" id="chkAll" onchange="toggleAll(this)" /></th>
                        <th>#</th>
                        <th>Ngày</th>
                        <th>Part Code</th>
                        <th>Product ID</th>
                        <th>Process</th>
                        <th>Coating</th>
                        <th>Vendor</th>
                        <th>Defect Name <span style="font-size:.65rem;opacity:.7">(tên cột)</span></th>
                        <th class="tc">Qty</th>
                        <th>Type</th>
                        <th class="tc">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="reviewTbody">
                    <tr><td colspan="12">
                        <div class="empty-state"><div class="ei">📋</div><p>Upload file và nhấn Review để xem dữ liệu</p></div>
                    </td></tr>
                </tbody>
            </table>
        </div>
        <div class="pagination-bar">
            <span class="pagination-info" id="pgInfo">—</span>
            <div class="pagination-controls" id="pgControls"></div>
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
const pathBase = '@Context.Request.PathBase';

/* ── State ─────────────────────────────────────────── */
let workbook      = null;
let rawRows       = [];    // raw objects from sheet
let rawHeaders    = [];    // all column headers
let reviewRows    = [];    // unpivoted rows
let partCodeMap   = [];    // [{partCode, productId, italisaNo, itemCode}]
let selectedDefectCols = new Set();
let currentPage   = 1;
const PAGE_SIZE   = 50;

// Fixed columns that are NOT defect columns
const FIXED_COL_KEYWORDS = [
    'date','ngày','ngay','日期',
    'part code','mã linh','ma linh','零件','partcode',
    'product','sản phẩm','san pham','产品','item name',
    'coating','lớp phủ','lop phu','涂层','color','màu','mau',
    'process','quy trình','quy trinh','工序','công đoạn',
    'input qty','sl đầu vào','投入量',
    'ok qty','sl đạt','良品',
    'ng qty','sl lỗi','不良数',
    'output qty','sl đầu ra','产出量',
    'defect rate','tỷ lệ lỗi','不良率',
    'yield rate','tỷ lệ đạt','良品率',
    'svn code','svn name','italisa pn'
];

/* ── Init ──────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('defDate').value = new Date().toISOString().slice(0,10);
    setupUploadZone();
    loadPartCodeMap();
    loadDropdowns();
});

async function loadPartCodeMap() {
    try {
        const r = await fetch(`${pathBase}/Defect/GetPartCodeMap`);
        if (r.ok) partCodeMap = await r.json();
    } catch(e) { console.warn('Part code map unavailable:', e.message); }
}

/* ── Upload Zone ───────────────────────────────────── */
async function loadDropdowns() {
    try {
        const [vr, pr, cr] = await Promise.all([
            fetch(`${pathBase}/Production/GetVendors`),
            fetch(`${pathBase}/Production/GetProcesses`),
            fetch(`${pathBase}/Production/GetColors`),
        ]);
        const vendors   = await vr.json();
        const processes = await pr.json();
        const colors    = await cr.json();

        // Vendor default dropdown
        const dv = document.getElementById('defVendor');
        if (dv && dv.tagName === 'SELECT') {
            vendors.forEach(v => { if(v) dv.insertAdjacentHTML('beforeend',
                `<option value="${esc(v)}">${esc(v)}</option>`); });
            const ita = Array.from(dv.options).find(o => o.value.toUpperCase().includes('ITA'));
            if (ita) dv.value = ita.value;
        }

        // Process default dropdown
        const dp = document.getElementById('defProcess');
        if (dp && dp.tagName === 'SELECT')
            processes.forEach(p => { if(p) dp.insertAdjacentHTML('beforeend',
                `<option value="${esc(p)}">${esc(p)}</option>`); });

        // Color default dropdown
        const dc = document.getElementById('defColor');
        if (dc && dc.tagName === 'SELECT')
            colors.forEach(c => { if(c) dc.insertAdjacentHTML('beforeend',
                `<option value="${esc(c)}">${esc(c)}</option>`); });

    } catch(e) { console.warn('loadDropdowns:', e.message); }
}

async function onDefaultProcessChange() {
    const proc = document.getElementById('defProcess').value;
    const dp   = document.getElementById('defPartCode');
    if (!dp || dp.tagName !== 'SELECT') return;
    dp.innerHTML = '<option value="">-- Mặc định --</option>';
    if (!proc) return;
    try {
        const r = await fetch(`${pathBase}/Production/GetCodesByProcess?process=${encodeURIComponent(proc)}`);
        if (!r.ok) return;
        const codes = await r.json();
        codes.forEach(c => dp.insertAdjacentHTML('beforeend',
            `<option value="${c.value}">${esc(c.text)}</option>`));
    } catch(e) {}
}

function setupUploadZone() {
    const zone  = document.getElementById('uploadZone');
    const input = document.getElementById('fileInput');
    input.addEventListener('change', e => { if (e.target.files[0]) handleFile(e.target.files[0]); });
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault(); zone.classList.remove('drag-over');
        if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
    });
}

function handleFile(file) {
    showLoading(true, 'Đang đọc file...');
    const zone = document.getElementById('uploadZone');
    zone.classList.add('has-file');
    document.getElementById('uploadFilename').textContent = '✅ ' + file.name;
    document.getElementById('uploadFilename').style.display = 'block';
    document.getElementById('statusStep1').textContent = file.name;
    document.getElementById('numStep1').classList.add('done');
    document.getElementById('hdrStep1').classList.add('done');
    document.getElementById('cardStep1').classList.add('done');

    const reader = new FileReader();
    reader.onload = e => {
        try {
            workbook = XLSX.read(e.target.result, { type:'array' });
            buildSheetTabs();
        } catch(err) { showToast('Lỗi đọc file: ' + err.message, 'error'); }
        finally { showLoading(false); }
    };
    reader.readAsArrayBuffer(file);
}

/* ── Sheet Tabs ────────────────────────────────────── */
function buildSheetTabs() {
    const tabs = document.getElementById('sheetTabs');
    tabs.innerHTML = '';
    workbook.SheetNames.forEach((name, i) => {
        const btn = document.createElement('button');
        btn.className = 'sheet-tab' + (i===0 ? ' active' : '');
        btn.textContent = name;
        btn.onclick = () => {
            document.querySelectorAll('.sheet-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadSheet(name);
        };
        tabs.appendChild(btn);
    });
    document.getElementById('sheetSelectorWrap').style.display = 'block';

    // Auto-select "Raw Data" or similar
    const rawTab = workbook.SheetNames.find(n => n.toLowerCase().includes('raw'));
    if (rawTab) {
        const btn = [...document.querySelectorAll('.sheet-tab')]
            .find(b => b.textContent === rawTab);
        if (btn) { btn.click(); return; }
    }
    loadSheet(workbook.SheetNames[0]);
}

function loadSheet(name) {
    const ws   = workbook.Sheets[name];
    const json = XLSX.utils.sheet_to_json(ws, { header:1, defval:'', raw:false });
    if (!json.length) { showToast('Sheet không có dữ liệu.', 'error'); return; }

    // Find header row
    let hdrIdx = 0;
    for (let i = 0; i < Math.min(5, json.length); i++) {
        const row = json[i].map(c => String(c).toLowerCase());
        if (row.some(c => c.includes('date') || c.includes('ngày') || c.includes('part'))) {
            hdrIdx = i; break;
        }
    }
    rawHeaders = json[hdrIdx].map((h, i) => String(h || `Col_${i+1}`).trim());
    rawRows    = [];
    for (let r = hdrIdx + 1; r < json.length; r++) {
        const row = {};
        rawHeaders.forEach((h, i) => { row[h] = json[r][i] ?? ''; });
        // Skip empty rows
        if (rawHeaders.every(h => row[h] === '' || row[h] == null)) continue;
        rawRows.push(row);
    }

    buildColDropdowns(rawHeaders);
    autoMap(rawHeaders);
    detectDefectCols(rawHeaders);
    buildPreview(rawHeaders, json, hdrIdx);

    document.getElementById('parseInfo').textContent = `${rawRows.length} dòng dữ liệu`;
    document.getElementById('colMapWrap').style.display = 'block';
    updateReviewBtn();
}

/* ── Column dropdowns ──────────────────────────────── */
const MAP_FIELDS = ['mapDate','mapPartCode','mapProcess','mapColor','mapVendor','mapType','mapQuantity','mapDesc'];

function buildColDropdowns(headers) {
    MAP_FIELDS.forEach(id => {
        const sel = document.getElementById(id);
        if (!sel) return;
        sel.innerHTML = '<option value="">-- chọn cột --</option>';
        headers.forEach(h => {
            const opt = document.createElement('option');
            opt.value = h; opt.textContent = h;
            sel.appendChild(opt);
        });
        sel.onchange = () => { sel.classList.toggle('mapped', sel.value !== ''); updateReviewBtn(); };
        sel.className = sel.className.replace(/mapped/g,'').trim();
    });
}

function autoMap(headers) {
    const hints = {
        mapDate:     ['date','ngày','ngay','日期'],
        mapPartCode: ['part code','mã linh','ma linh','零件代码','part_code','italisa pn'],
        mapProcess:  ['process','quy trình','quy trinh','工序'],
        mapColor:    ['coating','lớp phủ','lop phu','涂层','color','màu'],
        mapVendor:   ['vendor','nhà cung cấp'],
        mapType:     ['type','loại','type_value'],
        mapQuantity: ['quantity','qty','số lượng','input qty','sl đầu'],
        mapDesc:     ['description','ghi chú','note','mô tả'],
    };
    const low = h => String(h).toLowerCase().trim();
    Object.entries(hints).forEach(([id, kws]) => {
        const sel = document.getElementById(id);
        if (!sel) return;
        const match = Array.from(sel.options).find(o =>
            kws.some(k => low(o.value).includes(k))
        );
        if (match) { sel.value = match.value; sel.classList.add('mapped'); }
    });
}

/* ── Defect column detection ───────────────────────── */
function isFixedCol(header) {
    const l = header.toLowerCase().trim();
    return FIXED_COL_KEYWORDS.some(kw => l.includes(kw));
}

function detectDefectCols(headers) {
    const candidates = headers.filter(h => !isFixedCol(h) && h.trim() !== '');
    const panel  = document.getElementById('defectColsPanel');
    const chips  = document.getElementById('defectChips');
    const count  = document.getElementById('defectColCount');

    chips.innerHTML = '';
    selectedDefectCols.clear();

    if (!candidates.length) { panel.style.display = 'none'; return; }
    panel.style.display = 'block';

    candidates.forEach(col => {
        // Count non-zero values in rawRows
        const nonZero = rawRows.filter(r => {
            const v = parseFloat(String(r[col]).replace(/,/g,''));
            return !isNaN(v) && v > 0;
        }).length;

        const chip = document.createElement('label');
        chip.className = 'defect-chip selected';
        chip.dataset.col = col;
        chip.innerHTML = `<input type="checkbox" checked />${esc(col)} <span class="chip-count">(${nonZero})</span>`;
        chip.querySelector('input').addEventListener('change', e => {
            if (e.target.checked) { selectedDefectCols.add(col); chip.classList.add('selected'); }
            else                  { selectedDefectCols.delete(col); chip.classList.remove('selected'); }
            updateDefectCount();
            updateReviewBtn();
        });
        chips.appendChild(chip);
        selectedDefectCols.add(col);
    });

    updateDefectCount();
    updateReviewBtn();
}

function updateDefectCount() {
    const sel = selectedDefectCols.size;
    const total = document.getElementById('defectChips').children.length;
    const totalQty = rawRows.reduce((sum, row) => {
        [...selectedDefectCols].forEach(col => {
            const v = parseFloat(String(row[col]).replace(/,/g,''));
            if (!isNaN(v) && v > 0) sum += v;
        });
        return sum;
    }, 0);
    document.getElementById('defectColCount').textContent =
        `${sel}/${total} cột được chọn · ước tính ~${rawRows.filter(r => [...selectedDefectCols].some(c => parseFloat(String(r[c]).replace(/,/g,'')) > 0)).length} dòng sau unpivot`;
}

function toggleAllDefectCols(select) {
    document.querySelectorAll('#defectChips .defect-chip').forEach(chip => {
        const cb = chip.querySelector('input');
        const col = chip.dataset.col;
        cb.checked = select;
        if (select) { selectedDefectCols.add(col); chip.classList.add('selected'); }
        else         { selectedDefectCols.delete(col); chip.classList.remove('selected'); }
    });
    updateDefectCount();
    updateReviewBtn();
}

/* ── Preview ───────────────────────────────────────── */
function buildPreview(headers, json, hdrIdx) {
    const thead = document.getElementById('previewThead');
    const tbody = document.getElementById('previewTbody');
    const maxC  = Math.min(headers.length, 15);

    thead.innerHTML = '<tr>' + headers.slice(0,maxC).map(h =>
        `<th title="${esc(h)}">${esc(h)}</th>`).join('') + '</tr>';

    tbody.innerHTML = '';
    json.slice(hdrIdx+1, hdrIdx+6).forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = headers.slice(0,maxC).map((_, ci) =>
            `<td>${esc(String(row[ci] ?? ''))}</td>`).join('');
        tbody.appendChild(tr);
    });
    document.getElementById('previewWrap').style.display = 'block';
}

function updateReviewBtn() {
    const dateOk = document.getElementById('mapDate').value !== ''  || document.getElementById('defDate').value !== '';
    const pcOk   = document.getElementById('mapPartCode').value !== '' || document.getElementById('defPartCode').value !== '';
    const defOk  = selectedDefectCols.size > 0;
    document.getElementById('btnReview').disabled = !(dateOk && defOk);
}

/* ── REVIEW / UNPIVOT ──────────────────────────────── */
function doReview() {
    if (!rawRows.length || !selectedDefectCols.size) {
        showToast('Cần có dữ liệu và ít nhất 1 cột defect được chọn.', 'error'); return;
    }

    showLoading(true, 'Đang unpivot dữ liệu...');

    setTimeout(() => {
        try {
            const getCol  = id => document.getElementById(id)?.value || '';
            const getDef  = id => document.getElementById(id)?.value?.trim() || '';
            const defaultDate = getDef('defDate') || new Date().toISOString().slice(0,10);

            reviewRows = [];

            rawRows.forEach((row, ri) => {
                // ── Fixed fields ──
                const dateRaw = getCol('mapDate') ? row[getCol('mapDate')] : '';
                const dateStr = parseExcelDate(dateRaw) || defaultDate;

                const partCode = (getCol('mapPartCode') ? row[getCol('mapPartCode')] : '') || getDef('defPartCode');
                const productId = resolveProductId(String(partCode).trim());

                const process  = (getCol('mapProcess')  ? String(row[getCol('mapProcess')]  ?? '') : '') || getDef('defProcess') || '';
                const color    = (getCol('mapColor')    ? String(row[getCol('mapColor')]    ?? '') : '') || getDef('defColor')   || '';
                const vendor   = (getCol('mapVendor')   ? String(row[getCol('mapVendor')]   ?? '') : '') || getDef('defVendor')  || 'ITA';
                const typeVal  = (getCol('mapType')     ? String(row[getCol('mapType')]     ?? '') : '') || getDef('defType')    || 'Defect';
                const desc     = (getCol('mapDesc')     ? String(row[getCol('mapDesc')]     ?? '') : '') || getDef('defDesc')    || '';
                const qtyDef   = (getCol('mapQuantity') ? String(row[getCol('mapQuantity')] ?? '') : '') || getDef('defQuantity') || '';

                // ── UNPIVOT: one record per defect column with value > 0 ──
                selectedDefectCols.forEach(col => {
                    const rawVal = String(row[col] ?? '').replace(/,/g,'').trim();
                    const qty    = parseFloat(rawVal);
                    if (isNaN(qty) || qty <= 0) return; // skip zero/empty

                    reviewRows.push({
                        _idx:         reviewRows.length,
                        _selected:    true,
                        _status:      'pending',
                        _partCode:    partCode,
                        date_finished: dateStr,
                        product_id:   productId,
                        process,
                        color,
                        vendor,
                        type_value:   'Defect',
                        defect_name:  col,       // column header = defect name
                        product_qty:  qty,
                        description:  desc,
                        image_path:   null,
                    });
                });
            });

            if (!reviewRows.length) {
                showToast('Không có giá trị > 0 trong các cột defect được chọn.', 'error');
                showLoading(false); return;
            }

            currentPage = 1;
            renderReviewTable();
            updateKPI();
            document.getElementById('reviewSection').style.display = 'block';
            document.getElementById('saveBar').style.display = 'flex';
            document.getElementById('reviewSection').scrollIntoView({ behavior:'smooth', block:'start' });
            showToast(`Unpivot xong: ${reviewRows.length} bản ghi từ ${rawRows.length} dòng × ${selectedDefectCols.size} cột.`, 'success');
        } catch(e) {
            showToast('Lỗi: ' + e.message, 'error');
            console.error(e);
        } finally { showLoading(false); }
    }, 30);
}

/* ── Helpers ───────────────────────────────────────── */
function parseExcelDate(v) {
    if (!v && v !== 0) return '';
    const s = String(v).trim();
    // "13-May-2026"
    const m1 = s.match(/^(\d{1,2})-([A-Za-z]{3})-(\d{4})$/);
    if (m1) {
        const mo = {jan:'01',feb:'02',mar:'03',apr:'04',may:'05',jun:'06',
                    jul:'07',aug:'08',sep:'09',oct:'10',nov:'11',dec:'12'}[m1[2].toLowerCase()];
        return mo ? `${m1[3]}-${mo}-${m1[1].padStart(2,'0')}` : '';
    }
    // "13/05/2026"
    const m2 = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
    if (m2) return `${m2[3]}-${m2[2].padStart(2,'0')}-${m2[1].padStart(2,'0')}`;
    // "2026-05-13"
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
    // Try JS Date
    const d = new Date(s);
    if (!isNaN(d)) return d.toISOString().slice(0,10);
    return '';
}

function resolveProductId(partCode) {
    if (!partCode) return null;
    const pc  = partCode.toUpperCase().trim();
    const num = parseInt(pc.replace(/^Y0*/,''));
    if (isNaN(num)) return null;
    const match = partCodeMap.find(m => m.italisaNo === num || m.partCode === pc);
    return match ? match.productId : null;
}

/* ── Render Review Table ───────────────────────────── */
function renderReviewTable() {
    const tbody = document.getElementById('reviewTbody');
    const total = reviewRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    currentPage = Math.min(currentPage, totalPages);
    const slice = reviewRows.slice((currentPage-1)*PAGE_SIZE, currentPage*PAGE_SIZE);

    if (!slice.length) {
        tbody.innerHTML = `<tr><td colspan="12"><div class="empty-state"><div class="ei">📋</div><p>Không có dữ liệu</p></div></td></tr>`;
        return;
    }

    tbody.innerHTML = slice.map((r, si) => {
        const gi = (currentPage-1)*PAGE_SIZE + si + 1;
        const statusHtml = r._status==='saved'
            ? `<span class="status-badge s-saved">✅ Đã lưu</span>`
            : r._status==='error'
            ? `<span class="status-badge s-error">❌ Lỗi</span>`
            : `<span class="status-badge s-pending">⏳ Chờ</span>`;
        const cls = r._selected ? 'row-selected' : '';
        return `<tr class="${cls}" id="row_${r._idx}">
            <td class="tc"><input type="checkbox" ${r._selected?'checked':''} onchange="toggleRow(${r._idx},this)" /></td>
            <td style="color:var(--gray-400);font-size:.75rem">${gi}</td>
            <td style="color:var(--gray-600);font-size:.77rem">${esc(r.date_finished)}</td>
            <td style="font-weight:700;color:var(--denim)">${esc(r._partCode||'—')}</td>
            <td style="color:var(--gray-600)">${r.product_id ?? '<em style="color:var(--gray-300)">—</em>'}</td>
            <td style="font-weight:600;color:var(--denim-dark)">${esc(r.process||'—')}</td>
            <td>${esc(r.color||'—')}</td>
            <td><span class="info-chip vendor">${esc(r.vendor)}</span></td>
            <td style="font-weight:700;color:#6d28d9;max-width:200px;overflow:hidden;text-overflow:ellipsis" title="${esc(r.defect_name)}">${esc(r.defect_name)}</td>
            <td class="tn" style="font-weight:700;color:var(--danger)">${Number(r.product_qty).toLocaleString('en-US')}</td>
            <td><span class="info-chip type">Defect</span></td>
            <td class="tc">${statusHtml}</td>
        </tr>`;
    }).join('');

    document.getElementById('tblBadge').textContent   = total;
    document.getElementById('actionBadge').textContent = total + ' dòng';
    renderPagination(total, totalPages);
    updateChkAll();
}

function updateKPI() {
    const total   = reviewRows.length;
    const sel     = reviewRows.filter(r => r._selected).length;
    const types   = new Set(reviewRows.map(r => r.defect_name)).size;
    const totalQ  = reviewRows.reduce((s, r) => s + (r.product_qty||0), 0);

    document.getElementById('kpiTotal').textContent      = total;
    document.getElementById('kpiSelected').textContent   = sel;
    document.getElementById('kpiDefectTypes').textContent = types;
    document.getElementById('kpiTotalQty').textContent   = totalQ.toLocaleString('en-US');

    const txt = document.getElementById('saveBarText');
    const sub = document.getElementById('saveBarSub');
    if (sel === 0) { txt.textContent = 'Chưa chọn bản ghi'; sub.textContent = 'Tick checkbox để chọn'; }
    else { txt.textContent = `${sel} bản ghi được chọn`; sub.textContent = 'Nhấn "Lưu" để ghi vào hệ thống'; }
    document.getElementById('btnSave').disabled = sel === 0;
}

function toggleRow(idx, chk) {
    const r = reviewRows.find(r => r._idx === idx); if (!r) return;
    r._selected = chk.checked;
    document.getElementById('row_'+idx)?.classList.toggle('row-selected', chk.checked);
    updateKPI(); updateChkAll();
}
function toggleAll(chk) {
    reviewRows.slice((currentPage-1)*PAGE_SIZE, currentPage*PAGE_SIZE).forEach(r => r._selected = chk.checked);
    renderReviewTable(); updateKPI();
}
function selectAll()   { reviewRows.forEach(r => r._selected = true);  renderReviewTable(); updateKPI(); }
function deselectAll() { reviewRows.forEach(r => r._selected = false); renderReviewTable(); updateKPI(); }
function updateChkAll() {
    const slice = reviewRows.slice((currentPage-1)*PAGE_SIZE, currentPage*PAGE_SIZE);
    const chkAll = document.getElementById('chkAll');
    const sel = slice.filter(r => r._selected).length;
    chkAll.checked = sel === slice.length && slice.length > 0;
    chkAll.indeterminate = sel > 0 && sel < slice.length;
}

/* ── Save ──────────────────────────────────────────── */
async function doSave() {
    const toSave = reviewRows.filter(r => r._selected && r._status !== 'saved');
    if (!toSave.length) { showToast('Không có bản ghi nào được chọn.', 'error'); return; }

    if (!confirm(`Lưu ${toSave.length} bản ghi Defect vào hệ thống?`)) return;

    showLoading(true, `Đang lưu ${toSave.length} bản ghi...`);

    const payload = toSave.map(r => ({
        process:       r.process       || null,
        product_qty:   r.product_qty   ? Math.round(r.product_qty) : null,
        product_id:    r.product_id    ? parseInt(r.product_id)    : null,
        color:         r.color         || null,
        vendor:        r.vendor        || 'ITA',
        type_value:    r.type_value || 'Defect',
        defect_name:   r.defect_name   || null,
        date_finished: r.date_finished || new Date().toISOString().slice(0,10),
        description:   r.description   || null,
        image_path:    null,
    }));

    try {
        const res = await fetch(`${pathBase}/Defect/SaveBatch`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (res.ok) {
            toSave.forEach(r => { r._status = 'saved'; r._selected = false; });
            renderReviewTable(); updateKPI();
            showToast(`✅ Đã lưu ${toSave.length} bản ghi!`, 'success');
        } else {
            const err = await res.text();
            toSave.forEach(r => r._status = 'error');
            renderReviewTable();
            showToast('Lỗi lưu: ' + err, 'error');
        }
    } catch(e) {
        showToast('Lỗi kết nối: ' + e.message, 'error');
    } finally { showLoading(false); }
}

/* ── Pagination ────────────────────────────────────── */
function renderPagination(total, totalPages) {
    const s = (currentPage-1)*PAGE_SIZE+1, e = Math.min(currentPage*PAGE_SIZE, total);
    document.getElementById('pgInfo').textContent = `Hiển thị ${s}–${e} / ${total} dòng`;
    const ctrl = document.getElementById('pgControls');
    ctrl.innerHTML = '';
    const add = (l, p, d, a) => {
        const b = document.createElement('button');
        b.className = 'pg-btn' + (a?' active':'');
        b.textContent = l; b.disabled = d;
        b.onclick = () => { currentPage = p; renderReviewTable(); };
        ctrl.appendChild(b);
    };
    add('«',1,currentPage===1,false);
    add('‹',currentPage-1,currentPage===1,false);
    for (let p=Math.max(1,currentPage-2);p<=Math.min(totalPages,currentPage+2);p++) add(p,p,false,p===currentPage);
    add('›',currentPage+1,currentPage===totalPages,false);
    add('»',totalPages,currentPage===totalPages,false);
}

/* ── Export ────────────────────────────────────────── */
function exportReview() {
    if (!reviewRows.length) { showToast('Không có dữ liệu.', 'error'); return; }
    const wb  = XLSX.utils.book_new();
    const aoa = [['Defect Upload — Unpivoted — ' + new Date().toLocaleString('vi-VN')],[]];
    aoa.push(['#','Ngày','Part Code','Product ID','Process','Coating','Vendor','Defect Name','Qty','Type','Trạng thái']);
    reviewRows.forEach((r,i) => aoa.push([
        i+1, r.date_finished, r._partCode, r.product_id, r.process,
        r.color, r.vendor, r.defect_name, r.product_qty, 'Defect',
        r._status==='saved'?'Đã lưu':(r._selected?'Đã chọn':'Chưa chọn')
    ]));
    const ws = XLSX.utils.aoa_to_sheet(aoa);
    ws['!cols'] = [{wch:4},{wch:12},{wch:10},{wch:10},{wch:16},{wch:14},{wch:8},{wch:30},{wch:8},{wch:8},{wch:10}];
    XLSX.utils.book_append_sheet(wb, ws, 'Defect Upload');
    XLSX.writeFile(wb, `Defect_Upload_${new Date().toISOString().slice(0,10)}.xlsx`);
    showToast('Xuất Excel xong.', 'success');
}

function backToUpload() {
    document.getElementById('reviewSection').style.display = 'none';
    document.getElementById('saveBar').style.display = 'none';
    window.scrollTo({ top:0, behavior:'smooth' });
}

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function showLoading(v, msg) {
    document.getElementById('loadingOverlay').classList.toggle('show', v);
    if (msg) document.getElementById('loadingMsg').textContent = msg;
}
function showToast(msg, type='info') {
    const el = document.getElementById('toast');
    el.className = 'toast ' + type;
    document.getElementById('toastIcon').textContent = type==='success'?'✅':type==='error'?'❌':'ℹ️';
    document.getElementById('toastMsg').textContent  = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 4000);
}
</script>
}
