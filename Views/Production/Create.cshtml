@{
    ViewData["Title"] = "Production Data Entry";
    var vendors   = ViewBag.Vendors   as List<ItalisaTools.Models.SVN_Italisa_vendor>  ?? new();
    var processes = ViewBag.Processes as List<ItalisaTools.Models.SVN_Italisa_Process> ?? new();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />
    <!-- Select2 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />
    <style>
        :root {
            --denim: #1B4F8A;
            --denim-dark: #0f2f52;
            --denim-mid: #2563a8;
            --denim-light: #dbeafe;
            --denim-xlight: #eff6ff;
            --white: #ffffff;
            --gray-50: #f8fafc;
            --gray-100: #f1f5f9;
            --gray-200: #e2e8f0;
            --gray-400: #94a3b8;
            --gray-600: #475569;
            --gray-800: #1e293b;
            --success: #10b981;
            --danger: #ef4444;
            --shadow-sm: 0 1px 3px rgba(27,79,138,0.08);
            --shadow-md: 0 4px 20px rgba(27,79,138,0.12);
            --shadow-lg: 0 8px 40px rgba(27,79,138,0.18);
            --nav-height: 60px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50);
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(27,79,138,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(37,99,168,0.05) 0%, transparent 50%);
        }

        /* ── NAV ── */
        nav {
            background: var(--denim-dark);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: var(--nav-height);
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--white);
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .nav-brand span {
            background: var(--denim-mid);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #a8d0f8;
        }
        @@media (max-width: 360px) { .nav-brand span { display: none; } }

        .nav-links { display: flex; gap: 4px; }
        .nav-links a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 0.84rem;
            font-weight: 500;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .nav-links a:hover { background: rgba(255,255,255,0.12); color: var(--white); }
        .nav-links a.active { background: var(--denim-mid); color: var(--white); }

        @@media (max-width: 480px) {
            .nav-links a .nav-label { display: none; }
            .nav-links a { padding: 6px 10px; font-size: 1rem; }
        }

        /* ── LAYOUT ── */
        .page-wrapper {
            max-width: 760px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        @@media (min-width: 600px) { .page-wrapper { padding: 3rem 1.5rem; } }

        .page-header { margin-bottom: 1.75rem; }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--denim-dark);
            line-height: 1.2;
        }
        @@media (min-width: 600px) { .page-header h1 { font-size: 1.75rem; } }
        .page-header p { color: var(--gray-600); font-size: 0.9rem; margin-top: 6px; }
        .header-line {
            width: 48px; height: 4px;
            background: linear-gradient(90deg, var(--denim), var(--denim-mid));
            border-radius: 2px; margin-top: 12px;
        }

        /* ── CARD ── */
        .form-card {
            background: var(--white);
            border-radius: 16px;
            box-shadow: var(--shadow-md);
            border: 1px solid rgba(27,79,138,0.08);
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg, var(--denim) 0%, var(--denim-mid) 100%);
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        @@media (min-width: 600px) { .card-header { padding: 1.5rem 2rem; } }
        .card-header-icon {
            width: 38px; height: 38px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .card-header h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            color: var(--white);
        }
        .card-header p { font-size: 0.78rem; color: rgba(255,255,255,0.7); margin-top: 2px; }
        .card-body { padding: 1.25rem; }
        @@media (min-width: 600px) { .card-body { padding: 2rem; } }

        /* ── FORM ── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }
        @@media (min-width: 540px) {
            .form-grid { grid-template-columns: 1fr 1fr; gap: 1.25rem; }
        }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group.full { grid-column: 1 / -1; }

        label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--denim-dark);
            letter-spacing: 0.3px;
            text-transform: uppercase;
        }
        label .required { color: var(--danger); margin-left: 2px; }

        input[type="number"],
        input[type="datetime-local"] {
            width: 100%;
            padding: 0.72rem 1rem;
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            color: var(--gray-800);
            background: var(--white);
            transition: all 0.2s;
            outline: none;
            min-height: 44px;
        }
        input[type="number"]:focus,
        input[type="datetime-local"]:focus {
            border-color: var(--denim);
            box-shadow: 0 0 0 3px rgba(27,79,138,0.1);
        }
        input[type="number"]:hover,
        input[type="datetime-local"]:hover { border-color: var(--denim-mid); }

        textarea {
            width: 100%;
            padding: 0.72rem 1rem;
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            color: var(--gray-800);
            background: var(--white);
            transition: all 0.2s;
            outline: none;
            resize: vertical;
            min-height: 90px;
        }
        textarea:focus { border-color: var(--denim); box-shadow: 0 0 0 3px rgba(27,79,138,0.1); }
        textarea:hover { border-color: var(--denim-mid); }

        /* ── IMAGE UPLOAD AREA ── */
        .image-upload-area {
            border: 2px dashed var(--gray-200);
            border-radius: 12px;
            padding: 1.25rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            background: var(--gray-50);
            position: relative;
        }
        .image-upload-area:hover,
        .image-upload-area.dragover {
            border-color: var(--denim);
            background: var(--denim-xlight);
        }
        .image-upload-area input[type="file"] {
            position: absolute; inset: 0;
            width: 100%; height: 100%;
            opacity: 0; cursor: pointer;
        }
        .upload-icon { font-size: 2rem; margin-bottom: 6px; }
        .upload-text { font-size: 0.85rem; color: var(--gray-600); font-weight: 500; }
        .upload-hint { font-size: 0.76rem; color: var(--gray-400); margin-top: 4px; }

        /* ── IMAGE PREVIEW ── */
        .image-preview-wrap {
            display: none;
            position: relative;
            border-radius: 10px;
            overflow: hidden;
            border: 1.5px solid var(--gray-200);
        }
        .image-preview-wrap.show { display: block; }
        .image-preview-wrap img {
            width: 100%;
            max-height: 220px;
            object-fit: cover;
            display: block;
        }
        .image-remove-btn {
            position: absolute;
            top: 8px; right: 8px;
            background: rgba(0,0,0,0.55);
            color: white;
            border: none;
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }
        .image-remove-btn:hover { background: var(--danger); }

        /* ── SELECT2 CUSTOM THEME ── */
        .select2-container--default .select2-selection--single {
            height: 44px !important;
            border: 1.5px solid var(--gray-200) !important;
            border-radius: 10px !important;
            display: flex !important;
            align-items: center !important;
            padding: 0 0.75rem !important;
            background: var(--white) !important;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .select2-container--default.select2-container--focus .select2-selection--single,
        .select2-container--default.select2-container--open .select2-selection--single {
            border-color: var(--denim) !important;
            box-shadow: 0 0 0 3px rgba(27,79,138,0.1) !important;
            outline: none !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--gray-800) !important;
            font-family: 'DM Sans', sans-serif !important;
            font-size: 0.92rem !important;
            line-height: 44px !important;
            padding: 0 !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__placeholder {
            color: var(--gray-400) !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 44px !important;
            right: 8px !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow b {
            border-color: var(--denim) transparent transparent transparent !important;
        }
        .select2-container--default.select2-container--open .select2-selection--single .select2-selection__arrow b {
            border-color: transparent transparent var(--denim) transparent !important;
        }
        .select2-dropdown {
            border: 1.5px solid var(--denim-light) !important;
            border-radius: 10px !important;
            box-shadow: var(--shadow-md) !important;
            font-family: 'DM Sans', sans-serif !important;
            font-size: 0.92rem !important;
            overflow: hidden;
        }
        .select2-container--default .select2-search--dropdown .select2-search__field {
            border: 1.5px solid var(--gray-200) !important;
            border-radius: 6px !important;
            padding: 8px 10px !important;
            font-family: 'DM Sans', sans-serif !important;
            font-size: 0.9rem !important;
            outline: none !important;
        }
        .select2-container--default .select2-search--dropdown .select2-search__field:focus {
            border-color: var(--denim) !important;
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: var(--denim) !important;
        }
        .select2-container--default .select2-results__option[aria-selected=true] {
            background-color: var(--denim-xlight) !important;
            color: var(--denim-dark) !important;
        }
        .select2-results__option { padding: 10px 12px !important; }
        .select2-container { width: 100% !important; }

        /* ── CODE SELECT LOADING STATE ── */
        .code-loading-hint {
            font-size: 0.78rem;
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 6px;
            min-height: 18px;
        }
        .code-loading-hint.info    { color: var(--gray-400); }
        .code-loading-hint.warning { color: #d97706; }
        .code-loading-hint.success { color: var(--success); }

        .code-spinner {
            width: 12px; height: 12px;
            border: 2px solid var(--denim-light);
            border-top-color: var(--denim);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
            flex-shrink: 0;
        }
        .code-spinner.show { display: inline-block; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .input-hint { font-size: 0.78rem; color: var(--gray-400); margin-top: 2px; }

        /* ── SECTION LABEL ── */
        .section-label {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--gray-400);
            grid-column: 1 / -1;
            margin-top: 0.25rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px dashed var(--gray-200);
        }

        /* ── DIVIDER ── */
        .form-divider {
            border: none;
            border-top: 1px dashed var(--gray-200);
            margin: 1.25rem 0;
        }
        @@media (min-width: 600px) { .form-divider { margin: 1.5rem 0; } }

        /* ── BUTTONS ── */
        .btn-row {
            display: flex;
            flex-direction: column-reverse;
            gap: 10px;
        }
        @@media (min-width: 480px) {
            .btn-row { flex-direction: row; justify-content: flex-end; gap: 12px; }
        }
        .btn {
            padding: 0.78rem 1.5rem;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.93rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 46px;
            width: 100%;
        }
        @@media (min-width: 480px) { .btn { width: auto; } }
        .btn-outline {
            background: var(--white);
            border: 1.5px solid var(--gray-200);
            color: var(--gray-600);
        }
        .btn-outline:hover { border-color: var(--denim); color: var(--denim); background: var(--denim-xlight); }
        .btn-primary {
            background: linear-gradient(135deg, var(--denim) 0%, var(--denim-mid) 100%);
            color: var(--white);
            box-shadow: 0 4px 14px rgba(27,79,138,0.3);
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(27,79,138,0.4); }
        .btn-primary:active { transform: translateY(0); }
        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        /* ── MODAL ── */
        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(15,47,82,0.5);
            backdrop-filter: blur(4px);
            z-index: 1000;
            align-items: flex-end;
            justify-content: center;
            padding: 0;
        }
        @@media (min-width: 540px) {
            .modal-overlay { align-items: center; padding: 1rem; }
        }
        .modal-overlay.show { display: flex; animation: fadeIn 0.2s; }
        .modal-box {
            background: var(--white);
            border-radius: 20px 20px 0 0;
            padding: 1.75rem 1.25rem;
            width: 100%;
            max-width: 100%;
            box-shadow: var(--shadow-lg);
            animation: slideUp 0.3s cubic-bezier(0.34,1.2,0.64,1);
            max-height: 90vh;
            overflow-y: auto;
        }
        @@media (min-width: 540px) {
            .modal-box { border-radius: 16px; padding: 2rem; max-width: 460px; }
        }
        .modal-handle {
            width: 40px; height: 4px;
            background: var(--gray-200);
            border-radius: 2px;
            margin: 0 auto 1.25rem;
        }
        @@media (min-width: 540px) { .modal-handle { display: none; } }

        .modal-icon {
            width: 52px; height: 52px;
            background: var(--denim-xlight);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.5rem;
        }
        .modal-box h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--denim-dark);
            text-align: center;
        }
        .modal-box p {
            color: var(--gray-600);
            font-size: 0.88rem;
            text-align: center;
            margin-top: 8px;
            line-height: 1.6;
        }
        .modal-summary {
            background: var(--denim-xlight);
            border-radius: 10px;
            padding: 0.9rem 1rem;
            margin: 1.1rem 0;
            font-size: 0.86rem;
            color: var(--denim-dark);
        }
        .modal-summary-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 5px 0;
            border-bottom: 1px solid rgba(27,79,138,0.08);
            gap: 8px;
        }
        .modal-summary-row:last-child { border-bottom: none; }
        .modal-summary-row span:first-child { color: var(--gray-600); white-space: nowrap; flex-shrink: 0; }
        .modal-summary-row span:last-child {
            font-weight: 600;
            color: var(--denim-dark);
            text-align: right;
            word-break: break-word;
        }
        .modal-btn-row { display: flex; gap: 10px; margin-top: 1.25rem; }
        .modal-btn-row .btn { flex: 1; }

        /* ── TOAST ── */
        .toast {
            position: fixed;
            bottom: 1.25rem; left: 50%;
            transform: translateX(-50%) translateY(120px);
            padding: 0.85rem 1.25rem;
            border-radius: 12px;
            font-size: 0.88rem;
            font-weight: 500;
            display: flex; align-items: center; gap: 10px;
            box-shadow: var(--shadow-lg);
            z-index: 9999;
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            width: calc(100% - 2rem);
            max-width: 400px;
        }
        .toast.show { transform: translateX(-50%) translateY(0); }
        @@media (min-width: 600px) {
            .toast {
                top: 1.5rem; right: 1.5rem;
                bottom: auto; left: auto;
                transform: translateX(120%);
                width: auto; max-width: 360px;
            }
            .toast.show { transform: translateX(0); }
        }
        .toast.success { background: var(--success); color: white; }
        .toast.error   { background: var(--danger);  color: white; }
        .toast-icon { font-size: 1.2rem; flex-shrink: 0; }

        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @@keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>
</head>
<body>

<div class="page-wrapper">
    <div class="page-header">
        <h1 data-i18n="create.title">Production Data Entry</h1>
        <p data-i18n="create.subtitle">Fill in all the information below to record data into the system.</p>
        <div class="header-line"></div>
    </div>

    <div class="form-card">
        <div class="card-header">
            <div class="card-header-icon">📝</div>
            <div>
                <h2 data-i18n="create.card.title">Entry Form</h2>
            </div>
        </div>
        <div class="card-body">
            <div class="form-grid">

                <!-- ── Core fields ── -->
                <div class="form-group">
                    <label data-i18n="label.vendor">Vendor <span class="required">*</span></label>
                    <select id="vendorSelect">
                        <option value="" data-i18n="ph.vendor">-- Select Vendor --</option>
                        @foreach (var v in vendors)
                        {
                            <option value="@v.vendor_code">@v.vendor_code - @v.vendor</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label data-i18n="label.process">Process <span class="required">*</span></label>
                    <select id="processSelect">
                        <option value="" data-i18n="ph.process">-- Select Process --</option>
                        @foreach (var p in processes)
                        {
                            <option value="@p.process">@p.process</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label data-i18n="label.code">Code <span class="required">*</span></label>
                    <select id="codeSelect">
                        <option value="" data-i18n="ph.code">-- Select Process first --</option>
                    </select>
                    <div class="code-loading-hint info" id="codeHint">
                        <span class="code-spinner" id="codeSpinner"></span>
                        <span id="codeHintText" data-i18n="hint.code.default">⬆ Select a Process to load matching codes</span>
                    </div>
                </div>

                <div class="form-group">
                    <label data-i18n="label.type">Type <span class="required">*</span></label>
                    <select id="typeSelect">
                        <option value="" data-i18n="ph.type">-- Select Type --</option>
                        <option value="Production Qty" data-i18n="type.production">Production Quantity</option>
                        <option value="Man Q'ty" data-i18n="type.manpower">Man Power</option>
                    </select>
                </div>

                <div class="form-group">
                    <label data-i18n="label.quantity">Quantity <span class="required">*</span></label>
                    <input type="number" id="quantityInput" min="1" data-i18n-ph="ph.quantity" placeholder="Enter quantity..." inputmode="numeric" />
                    <span class="input-hint" data-i18n="hint.quantity">Enter a positive integer</span>
                </div>

                <!-- ── Date / Time ── -->
                <div class="form-group">
                    <label data-i18n="label.datetime">Date &amp; Time <span class="required">*</span></label>
                    <input type="datetime-local" id="dateFinishedInput" />
                    <span class="input-hint" data-i18n="hint.datetime">Default: current date/time</span>
                </div>

                <!-- ── Description ── -->
                <div class="form-group full">
                    <label data-i18n="label.description">Description "optional"</label>
                    <textarea id="descriptionInput" data-i18n-ph="ph.description" placeholder="Enter additional notes or description (optional)..."></textarea>
                </div>

                <!-- ── Image ── -->
                <div class="form-group full">
                    <label data-i18n="label.image">Image (Photo / Upload) "optional"</label>
                    <div class="image-upload-area" id="uploadArea">
                        <input type="file" id="imageInput"
                               accept="image/*"
                               capture="environment" />
                        <div class="upload-icon">📷</div>
                        <div class="upload-text" data-i18n="upload.text">Tap to upload or take a photo</div>
                        <div class="upload-hint" data-i18n="upload.hint">Supports JPG, PNG, WEBP · Max 10 MB</div>
                    </div>
                    <div class="image-preview-wrap" id="previewWrap">
                        <img id="previewImg" src="" alt="Preview" />
                        <button class="image-remove-btn" onclick="removeImage()">✕ Remove</button>
                    </div>
                </div>

            </div>

            <hr class="form-divider" />

            <div class="btn-row">
                <button class="btn btn-outline" onclick="resetForm()" data-i18n="btn.reset">🔄 Reset</button>
                <button class="btn btn-primary" id="saveBtn" onclick="openConfirmModal()" data-i18n="btn.save">💾 Save Data</button>
            </div>
        </div>
    </div>
</div>

<!-- CONFIRM MODAL -->
<div class="modal-overlay" id="confirmModal">
    <div class="modal-box">
        <div class="modal-handle"></div>
        <div class="modal-icon">💾</div>
        <h3 data-i18n="modal.title">Confirm Save</h3>
        <p data-i18n="modal.subtitle">Please review the information before saving to the system.</p>
        <div class="modal-summary" id="modalSummary"></div>
        <div class="modal-btn-row">
            <button class="btn btn-outline" onclick="closeModal()" data-i18n="btn.cancel">✖ Cancel</button>
            <button class="btn btn-primary" id="confirmSaveBtn" onclick="submitForm()" data-i18n="btn.confirm">✔ Confirm</button>
        </div>
    </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
    <span class="toast-icon" id="toastIcon"></span>
    <span id="toastMsg"></span>
</div>

@section Scripts {

<!-- jQuery FIRST -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<!-- THEN Select2 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>

<script>
    const pathBase = '@Context.Request.PathBase'.replace(/\/$/, '');

    // ── Select2 helpers ───────────────────────────────────────────────────────
    function getSelect2Config(phKey, noSearch) {
        return {
            width: '100%',
            placeholder: t(phKey),
            language: {
                noResults:  () => t('ph.vendor') === t('ph.vendor') ? "No results found" : "Không có kết quả",
                searching:  () => "..."
            },
            ...(noSearch ? { minimumResultsForSearch: Infinity } : {})
        };
    }

    function initSelect2() {
        $('#vendorSelect') .select2(getSelect2Config('ph.vendor'));
        $('#processSelect').select2(getSelect2Config('ph.process'));
        $('#codeSelect')   .select2(getSelect2Config('ph.code'));
        $('#typeSelect')   .select2(getSelect2Config('ph.type', true));
    }

    // Re-init Select2 on lang change so placeholders update
    document.addEventListener('langChanged', () => {
        ['#vendorSelect','#processSelect','#codeSelect','#typeSelect'].forEach(sel => {
            if ($(sel).data('select2')) $(sel).select2('destroy');
        });
        initSelect2();
        $('#processSelect').on('change', function () { loadCodesByProcess($(this).val()); });
    });

    // ── Init ──────────────────────────────────────────────────────────────────
    $(document).ready(function () {
        initSelect2();
        setDefaultDateTime();
        $('#processSelect').on('change', function () {
            loadCodesByProcess($(this).val());
        });
        const savedVendor = localStorage.getItem('lastVendor');
        if (savedVendor) $('#vendorSelect').val(savedVendor).trigger('change');
    });

    // ── Set default datetime to now ──
    function setDefaultDateTime() {
        const now = new Date();
        const pad = n => String(n).padStart(2, '0');
        const local = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;
        document.getElementById('dateFinishedInput').value = local;
    }

    // ── Image handling ────────────────────────────────────────────────────────
    document.getElementById('imageInput').addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;
        if (file.size > 10 * 1024 * 1024) {
            showToast('Image is too large (max 10 MB).', 'error');
            this.value = '';
            return;
        }
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('previewWrap').classList.add('show');
            document.getElementById('uploadArea').style.display = 'none';
        };
        reader.readAsDataURL(file);
    });

    const uploadArea = document.getElementById('uploadArea');
    uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('dragover'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
    uploadArea.addEventListener('drop', e => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file && file.type.startsWith('image/')) {
            const dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('imageInput').files = dt.files;
            document.getElementById('imageInput').dispatchEvent(new Event('change'));
        }
    });

    function removeImage() {
        document.getElementById('imageInput').value = '';
        document.getElementById('previewImg').src   = '';
        document.getElementById('previewWrap').classList.remove('show');
        document.getElementById('uploadArea').style.display = '';
    }

    // ── Load codes by process ─────────────────────────────────────────────────
    async function loadCodesByProcess(processValue) {
        const $codeSelect = $('#codeSelect');
        const spinner     = document.getElementById('codeSpinner');
        const hintEl      = document.getElementById('codeHint');
        const hintText    = document.getElementById('codeHintText');

        $codeSelect.empty().append(`<option value="">-- Loading... --</option>`).trigger('change');

        if (!processValue) {
            $codeSelect.empty().append(`<option value="">${t('ph.code')}</option>`).trigger('change');
            hintEl.className     = 'code-loading-hint info';
            hintText.textContent = t('hint.code.default');
            spinner.classList.remove('show');
            return;
        }

        spinner.classList.add('show');
        hintEl.className     = 'code-loading-hint info';
        hintText.textContent = t('hint.code.loading');

        try {
            const res   = await fetch(`${pathBase}/Production/GetCodesByProcess?process=${encodeURIComponent(processValue)}`);
            const codes = await res.json();

            $codeSelect.empty().append(`<option value="">${t('ph.code')}</option>`);

            if (codes.length === 0) {
                hintEl.className     = 'code-loading-hint warning';
                hintText.textContent = t('hint.code.empty', { v: processValue });
            } else {
                codes.forEach(c => $codeSelect.append(new Option(c.text, c.value)));
                hintEl.className     = 'code-loading-hint success';
                hintText.textContent = t('hint.code.ok', { n: codes.length, v: processValue });
            }
            $codeSelect.trigger('change');
        } catch (e) {
            $codeSelect.empty().append(`<option value="">${t('hint.code.error')}</option>`).trigger('change');
            hintEl.className     = 'code-loading-hint warning';
            hintText.textContent = t('hint.code.error');
            console.error('GetCodesByProcess error:', e);
        } finally {
            spinner.classList.remove('show');
        }
    }

    // ── Collect form data ─────────────────────────────────────────────────────
    function getFormData() {
        const vendorSel  = document.getElementById('vendorSelect');
        const codeSel    = document.getElementById('codeSelect');
        const typeSel    = document.getElementById('typeSelect');
        const processSel = document.getElementById('processSelect');
        const imageFile  = document.getElementById('imageInput').files[0] || null;

        return {
            vendor:       vendorSel.value,
            vendorText:   vendorSel.options[vendorSel.selectedIndex]?.text,
            process:      processSel.value,
            processText:  processSel.options[processSel.selectedIndex]?.text,
            productId:    parseInt(codeSel.value) || null,
            codeText:     codeSel.options[codeSel.selectedIndex]?.text,
            typeValue:    typeSel.value,
            quantity:     parseInt(document.getElementById('quantityInput').value) || null,
            dateFinished: document.getElementById('dateFinishedInput').value,
            description:  document.getElementById('descriptionInput').value.trim(),
            imageFile:    imageFile
        };
    }

    function validateForm(data) {
        if (!data.vendor)                         return t('val.vendor');
        if (!data.process)                        return t('val.process');
        if (!data.productId)                      return t('val.code');
        if (!data.typeValue)                      return t('val.type');
        if (!data.quantity || data.quantity <= 0) return t('val.quantity');
        if (!data.dateFinished)                   return t('val.datetime');
        return null;
    }

    // ── Helper: build summary rows ────────────────────────────────────────────
    function buildSummaryRows(data, dtDisplay, dtColor) {
        const descLabel = data.description
            ? (data.description.length > 60 ? data.description.substring(0, 60) + '…' : data.description)
            : '(none)';
        const imgLabel = data.imageFile ? `📎 ${data.imageFile.name}` : '(none)';
        const dtStyle  = dtColor ? `style="color:${dtColor};font-weight:700;"` : '';
        return `
            <div class="modal-summary-row"><span>Vendor</span><span>${data.vendor}</span></div>
            <div class="modal-summary-row"><span>Process</span><span>${data.processText}</span></div>
            <div class="modal-summary-row"><span>Code</span><span>${data.codeText}</span></div>
            <div class="modal-summary-row"><span>Type</span><span>${data.typeValue}</span></div>
            <div class="modal-summary-row"><span>Quantity</span><span>${data.quantity}</span></div>
            <div class="modal-summary-row"><span>Date &amp; Time</span><span ${dtStyle}>${dtDisplay}</span></div>
            <div class="modal-summary-row"><span>Description</span><span>${descLabel}</span></div>
            <div class="modal-summary-row"><span>Image</span><span>${imgLabel}</span></div>
        `;
    }

    // ── Tab switch trong modal ca đêm ─────────────────────────────────────────
    function switchShiftTab(mode) {
        const s = window._nightShiftState;
        if (!s) return;
        s.mode = mode;

        const tabNight = document.getElementById('tabNight');
        const tabNow   = document.getElementById('tabNow');

        if (mode === 'night') {
            tabNight.style.background = 'linear-gradient(135deg,#d97706,#f59e0b)';
            tabNight.style.color      = 'white';
            tabNow.style.background   = 'var(--gray-100)';
            tabNow.style.color        = 'var(--gray-600)';
            document.getElementById('shiftSummaryRows').innerHTML =
                buildSummaryRows(s.data, `23:00 — ${s.dateLabel}`, '#d97706');
        } else {
            tabNow.style.background   = 'linear-gradient(135deg,var(--denim),var(--denim-mid))';
            tabNow.style.color        = 'white';
            tabNight.style.background = 'var(--gray-100)';
            tabNight.style.color      = 'var(--gray-600)';
            document.getElementById('shiftSummaryRows').innerHTML =
                buildSummaryRows(s.data, new Date(s.nowDt).toLocaleString(), null);
        }
    }

    // ── Confirm modal (tích hợp night shift) ──────────────────────────────────
    function openConfirmModal() {
        const data  = getFormData();
        const error = validateForm(data);
        if (error) { showToast(error, 'error'); return; }

        const now   = new Date();
        const hours = now.getHours();
        const mins  = now.getMinutes();

        // ── Trước 7:30 sáng → hiện modal ca đêm ──
        if (hours < 7 || (hours === 7 && mins < 30)) {
            const yesterday = new Date(now);
            yesterday.setDate(yesterday.getDate() - 1);

            const dd        = String(yesterday.getDate()).padStart(2, '0');
            const mm        = String(yesterday.getMonth() + 1).padStart(2, '0');
            const yyyy      = yesterday.getFullYear();
            const dateLabel = `${dd}/${mm}/${yyyy}`;
            const hh        = String(hours).padStart(2, '0');
            const mn        = String(mins).padStart(2, '0');
            const nightDt   = `${yyyy}-${mm}-${dd}T23:00`;

            // Lưu state để submitForm đọc
            window._nightShiftState = {
                mode:      'night',
                data:      data,
                nightDt:   nightDt,
                nowDt:     data.dateFinished,
                dateLabel: dateLabel
            };

            document.getElementById('modalSummary').innerHTML = `
                <!-- Banner cảnh báo -->
                <div style="
                    background: linear-gradient(135deg,#d97706,#f59e0b);
                    border-radius: 10px;
                    padding: 0.7rem 1rem;
                    margin-bottom: 0.85rem;
                    text-align: center;
                    color: white;
                    font-size: 0.83rem;
                    font-weight: 600;
                ">
                    ${t('night.banner', { hh, mn })}
                </div>

                <!-- Tab chọn ca -->
                <div style="display:flex; border-radius:10px; overflow:hidden; border:1.5px solid var(--gray-200); margin-bottom:0.85rem;">
                    <button id="tabNight" onclick="switchShiftTab('night')" style="
                        flex:1; padding:0.6rem 0.4rem;
                        border:none; cursor:pointer;
                        font-family:'DM Sans',sans-serif;
                        font-size:0.8rem; font-weight:600;
                        background: linear-gradient(135deg,#d97706,#f59e0b);
                        color: white;
                        line-height:1.4;
                        transition: all 0.2s;
                    ">${t('night.tab.night')}<br><span style="font-size:0.72rem;font-weight:400;opacity:0.9;">${t('night.tab.night.sub', { date: dateLabel })}</span></button>
                    <button id="tabNow" onclick="switchShiftTab('now')" style="
                        flex:1; padding:0.6rem 0.4rem;
                        border:none; cursor:pointer;
                        font-family:'DM Sans',sans-serif;
                        font-size:0.8rem; font-weight:600;
                        background: var(--gray-100);
                        color: var(--gray-600);
                        line-height:1.4;
                        transition: all 0.2s;
                    ">${t('night.tab.now')}<br><span style="font-size:0.72rem;font-weight:400;">${t('night.tab.now.sub', { hh, mn })}</span></button>
                </div>

                <!-- Summary rows (reactive theo tab) -->
                <div id="shiftSummaryRows">
                    ${buildSummaryRows(data, `23:00 — ${dateLabel}`, '#d97706')}
                </div>
            `;

            document.querySelector('#confirmModal .modal-icon').textContent = '🌙';
            document.querySelector('#confirmModal h3').textContent          = t('night.modal.title');
            document.querySelector('#confirmModal > .modal-box > p').textContent = t('night.modal.subtitle');

        } else {
            // ── Giờ bình thường → modal gốc ──
            window._nightShiftState = null;

            const dtLabel = data.dateFinished
                ? new Date(data.dateFinished).toLocaleString()
                : '—';

            document.getElementById('modalSummary').innerHTML =
                buildSummaryRows(data, dtLabel, null);

            document.querySelector('#confirmModal .modal-icon').textContent = '💾';
            document.querySelector('#confirmModal h3').textContent          = t('modal.title');
            document.querySelector('#confirmModal > .modal-box > p').textContent = t('modal.subtitle');
        }

        document.getElementById('confirmModal').classList.add('show');
    }

    function closeModal() {
        document.getElementById('confirmModal').classList.remove('show');
    }

    // ── Compress image trước khi upload ──────────────────────────────────────
    async function compressImageFile(file, maxWidth = 1280, quality = 0.82) {
        return new Promise((resolve) => {
            const img = new Image();
            const url = URL.createObjectURL(file);
            img.onload = () => {
                const scale   = Math.min(maxWidth / img.width, 1);
                const canvas  = document.createElement('canvas');
                canvas.width  = img.width  * scale;
                canvas.height = img.height * scale;
                canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
                URL.revokeObjectURL(url);
                canvas.toBlob(
                    blob => resolve(new File([blob], file.name.replace(/\.[^.]+$/, '.jpg'), { type: 'image/jpeg' })),
                    'image/jpeg', quality
                );
            };
            img.src = url;
        });
    }

    // ── Submit (multipart/form-data) ──────────────────────────────────────────
    async function submitForm() {
        const data = getFormData();
        const btn  = document.getElementById('confirmSaveBtn');

        // Override datetime nếu người dùng chọn ca đêm
        if (window._nightShiftState) {
            data.dateFinished = window._nightShiftState.mode === 'night'
                ? window._nightShiftState.nightDt
                : window._nightShiftState.nowDt;
        }

        btn.disabled    = true;
        btn.textContent = t('btn.saving');

        try {
            const formData = new FormData();
            formData.append('vendor',       data.vendor);
            formData.append('process',      data.process);
            formData.append('productId',    data.productId);
            formData.append('typeValue',    data.typeValue);
            formData.append('quantity',     data.quantity);
            formData.append('dateFinished', data.dateFinished);
            formData.append('description',  data.description);

            // ── Compress ảnh trước khi gửi ──
            if (data.imageFile) {
                const compressed = await compressImageFile(data.imageFile);
                formData.append('imageFile', compressed, compressed.name);
            }

            const response = await fetch(`${pathBase}/Production/Create`, {
                method: 'POST',
                body:   formData
            });

            const result = await response.json();
            closeModal();

            if (result.success) {
                localStorage.setItem('lastVendor', data.vendor);
                showToast(result.message, 'success');
                resetForm();
            } else {
                showToast(result.message, 'error');
            }
        } catch (e) {
            closeModal();
            showToast(t('toast.network_error'), 'error');
        } finally {
            btn.disabled  = false;
            btn.innerHTML = t('btn.confirm');
        }
    }

    // ── Reset ─────────────────────────────────────────────────────────────────
    function resetForm() {
        const savedVendor = localStorage.getItem('lastVendor');
        if (savedVendor) {
            $('#vendorSelect').val(savedVendor).trigger('change');
        } else {
            $('#vendorSelect').val('').trigger('change');
        }
        $('#processSelect').val('').trigger('change');
        $('#typeSelect').val('').trigger('change');
        document.getElementById('quantityInput').value    = '';
        document.getElementById('descriptionInput').value = '';
        setDefaultDateTime();
        removeImage();
    }

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg, type) {
        const toast = document.getElementById('toast');
        toast.className = 'toast ' + type;
        document.getElementById('toastIcon').textContent = type === 'success' ? '✅' : '❌';
        document.getElementById('toastMsg').textContent  = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3500);
    }

    document.getElementById('confirmModal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });

</script>
}
}

</body>
</html>
