@{
    ViewData["Title"] = "Defect Report";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <style>
        :root {
            --denim:        #1B4F8A;
            --denim-dark:   #0f2f52;
            --denim-mid:    #2563a8;
            --denim-light:  #dbeafe;
            --denim-xlight: #eff6ff;
            --white:        #ffffff;
            --gray-50:      #f8fafc;
            --gray-100:     #f1f5f9;
            --gray-200:     #e2e8f0;
            --gray-400:     #94a3b8;
            --gray-600:     #475569;
            --gray-800:     #1e293b;
            --success:      #10b981;
            --warning:      #f59e0b;
            --danger:       #ef4444;
            --shadow-sm:    0 1px 3px rgba(27,79,138,0.08);
            --shadow-md:    0 4px 20px rgba(27,79,138,0.12);
            --nav-height:   60px;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50);
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(27,79,138,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(37,99,168,0.05) 0%, transparent 50%);
        }

        /* ── NAV ── */
        nav {
            background: var(--denim-dark);
            padding: 0 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            height: var(--nav-height);
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
            position: sticky; top: 0; z-index: 200;
        }
        .nav-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem; font-weight: 700;
            color: var(--white); letter-spacing: 0.5px;
            display: flex; align-items: center; gap: 8px;
        }
        .nav-brand span {
            background: var(--denim-mid); padding: 2px 8px; border-radius: 4px;
            font-size: 0.7rem; font-weight: 600; letter-spacing: 1.5px;
            text-transform: uppercase; color: #a8d0f8;
        }
        .nav-links { display: flex; gap: 4px; }
        .nav-links a {
            color: rgba(255,255,255,0.7); text-decoration: none;
            padding: 6px 12px; border-radius: 6px;
            font-size: 0.84rem; font-weight: 500;
            transition: all 0.2s; white-space: nowrap;
        }
        .nav-links a:hover { background: rgba(255,255,255,0.12); color: var(--white); }
        .nav-links a.active { background: var(--denim-mid); color: var(--white); }
        @@media (max-width: 480px) {
            .nav-links a .nav-label { display: none; }
            .nav-links a { padding: 6px 10px; font-size: 1rem; }
        }

        /* ── LAYOUT ── */
        .page-wrapper { max-width: 1700px; margin: 0 auto; padding: 1.5rem 1rem; }
        @@media (min-width: 600px) { .page-wrapper { padding: 2.5rem 1.5rem; } }
        .page-header { margin-bottom: 1.5rem; }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem; font-weight: 700; color: var(--denim-dark);
        }
        @@media (min-width: 600px) { .page-header h1 { font-size: 1.75rem; } }
        .page-header p { color: var(--gray-600); font-size: 0.9rem; margin-top: 6px; }
        .header-line {
            width: 48px; height: 4px;
            background: linear-gradient(90deg, var(--denim), var(--denim-mid));
            border-radius: 2px; margin-top: 12px;
        }

        /* ── FILTER ── */
        .filter-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm); margin-bottom: 1.5rem; overflow: hidden;
        }
        .filter-header {
            background: var(--denim-xlight); padding: 0.9rem 1.25rem;
            display: flex; align-items: center; justify-content: space-between;
            border-bottom: 1px solid rgba(27,79,138,0.1);
            cursor: pointer; user-select: none;
        }
        .filter-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.92rem; font-weight: 600; color: var(--denim-dark);
            display: flex; align-items: center; gap: 8px;
        }
        .filter-toggle { font-size: 0.8rem; color: var(--denim); font-weight: 600; transition: transform 0.3s; }
        .filter-toggle.collapsed { transform: rotate(-90deg); }
        @@media (min-width: 768px) { .filter-toggle { display: none; } }
        .filter-body { padding: 1rem 1.25rem; }
        .filter-body.collapsed { display: none; }
        @@media (min-width: 768px) { .filter-body { display: block !important; } }
        .filter-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;
        }
        @@media (min-width: 600px) { .filter-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; } }
        @@media (min-width: 900px) { .filter-grid { grid-template-columns: repeat(5, 1fr) auto; align-items: end; gap: 1rem; } }
        .filter-group { display: flex; flex-direction: column; gap: 5px; }
        .filter-group label {
            font-size: 0.75rem; font-weight: 600; color: var(--denim-dark);
            letter-spacing: 0.3px; text-transform: uppercase;
        }
        .filter-group select,
        .filter-group input[type="date"] {
            width: 100%; padding: 0.6rem 0.75rem;
            border: 1.5px solid var(--gray-200); border-radius: 8px;
            font-family: 'DM Sans', sans-serif; font-size: 0.88rem;
            color: var(--gray-800); background: var(--white);
            outline: none; transition: border-color 0.2s, box-shadow 0.2s;
            min-height: 40px; cursor: pointer;
            appearance: none; -webkit-appearance: none;
        }
        .filter-group select:focus,
        .filter-group input[type="date"]:focus {
            border-color: var(--denim); box-shadow: 0 0 0 3px rgba(27,79,138,0.1);
        }
        .filter-btn-group { justify-content: flex-end; }
        .filter-actions { display: flex; gap: 8px; }
        .btn {
            padding: 0.6rem 1.2rem; border-radius: 8px; border: none;
            font-family: 'DM Sans', sans-serif; font-size: 0.88rem; font-weight: 600;
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-primary { background: var(--denim); color: var(--white); }
        .btn-primary:hover:not(:disabled) { background: var(--denim-dark); }
        .btn-outline { background: var(--white); color: var(--denim); border: 1.5px solid var(--denim-light); }
        .btn-outline:hover:not(:disabled) { background: var(--denim-xlight); }
        .btn-success { background: #059669; color: var(--white); }
        .btn-success:hover:not(:disabled) { background: #047857; }
        .btn:disabled { opacity: 0.55; cursor: not-allowed; }
        .btn-sm { padding: 0.4rem 0.85rem; font-size: 0.8rem; }

        /* ── KPI ── */
        .kpi-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 1rem; margin-bottom: 1.5rem;
        }
        @@media (min-width: 900px) { .kpi-grid { grid-template-columns: repeat(4, 1fr); } }
        .kpi-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm); padding: 1.25rem 1.5rem;
            display: flex; align-items: flex-start; gap: 1rem;
        }
        .kpi-icon {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
        }
        .kpi-icon.blue   { background: var(--denim-xlight); }
        .kpi-icon.red    { background: #fef2f2; }
        .kpi-icon.green  { background: #ecfdf5; }
        .kpi-icon.orange { background: #fff7ed; }
        .kpi-body { flex: 1; min-width: 0; }
        .kpi-label { font-size: 0.75rem; font-weight: 600; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.4px; }
        .kpi-value { font-family: 'Space Grotesk', sans-serif; font-size: 1.6rem; font-weight: 700; color: var(--denim-dark); margin-top: 4px; }
        .kpi-value.red   { color: var(--danger); }
        .kpi-value.green { color: var(--success); }
        .kpi-sub { font-size: 0.78rem; color: var(--gray-400); margin-top: 3px; }

        /* ── CHARTS ── */
        .charts-grid {
            display: grid; grid-template-columns: 1fr;
            gap: 1rem; margin-bottom: 1.5rem;
        }
        @@media (min-width: 900px)  { .charts-grid { grid-template-columns: 2fr 1fr; } }
        @@media (min-width: 1200px) { .charts-grid { grid-template-columns: 2fr 1fr 1fr; } }
        .chart-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08); box-shadow: var(--shadow-sm); overflow: hidden;
        }
        .chart-card-header {
            background: linear-gradient(135deg, var(--denim-dark) 0%, var(--denim) 100%);
            padding: 1rem 1.25rem;
        }
        .chart-card-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.9rem; font-weight: 600; color: var(--white);
        }
        .chart-body { padding: 1.25rem; }

        /* ── TABLE ── */
        .table-card {
            background: var(--white); border-radius: 14px;
            border: 1px solid rgba(27,79,138,0.08);
            box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 1.5rem;
        }
        .table-card-header {
            background: linear-gradient(135deg, var(--denim-dark) 0%, var(--denim) 100%);
            padding: 1rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; flex-wrap: wrap;
        }
        .table-card-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.95rem; font-weight: 600; color: var(--white);
            display: flex; align-items: center; gap: 8px;
        }
        .badge {
            background: rgba(255,255,255,0.18); color: var(--white);
            border-radius: 20px; padding: 3px 10px; font-size: 0.75rem; font-weight: 600;
        }
        .table-scroll { overflow-x: auto; }
        .defect-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
        .defect-table thead th {
            background: var(--denim); color: var(--white);
            padding: 10px 12px; text-align: center; font-weight: 600;
            white-space: nowrap; border-right: 1px solid rgba(255,255,255,0.15);
            vertical-align: middle; position: sticky; top: 0; z-index: 10;
        }
        .defect-table thead th.th-left { text-align: left; }
        .defect-table thead th.th-defect {
            background: #5b21b6; font-size: 0.75rem; line-height: 1.3;
        }
        .defect-table thead th.th-defect-first {
            border-left: 2px solid rgba(255,255,255,0.4);
        }
        .defect-table thead th .th-sub {
            display: block; font-size: 0.67rem; font-weight: 400; opacity: 0.75; margin-top: 2px;
        }
        .defect-table tbody td {
            padding: 9px 12px; border-bottom: 1px solid var(--gray-100);
            border-right: 1px solid var(--gray-100); vertical-align: middle; white-space: nowrap;
        }
        .defect-table tbody tr:nth-child(even) td { background: var(--gray-50); }
        .defect-table tbody tr:hover td { background: var(--denim-xlight); }
        .td-num  { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: var(--denim); }
        .td-zero { text-align: right; font-variant-numeric: tabular-nums; color: var(--gray-300); }
        .td-center { text-align: center; }
        .td-defect { text-align: right; font-variant-numeric: tabular-nums; }
        .td-defect.td-defect-first { border-left: 2px solid #c4b5fd; }
        .td-defect-nz { font-weight: 700; color: var(--danger); }
        .rate-badge {
            display: inline-block; padding: 2px 8px;
            border-radius: 20px; font-size: 0.75rem; font-weight: 700;
        }
        .rate-ok  { background: #ecfdf5; color: #065f46; }
        .rate-mid { background: #fff7ed; color: #92400e; }
        .rate-bad { background: #fef2f2; color: #991b1b; }
        .color-tag {
            display: inline-block; padding: 2px 10px; border-radius: 20px;
            font-size: 0.73rem; font-weight: 600; white-space: nowrap;
        }
        .color-matte  { background: #1e293b; color: #fff; }
        .color-chrome { background: #e2e8f0; color: #1e293b; border: 1px solid #cbd5e1; }
        .color-brass  { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
        .color-beige  { background: #fef9c3; color: #713f12; border: 1px solid #fde68a; }
        .color-other  { background: var(--denim-xlight); color: var(--denim); }
        .color-none   { background: var(--gray-100); color: var(--gray-600); font-style: italic; }
        tr.total-row td {
            background: var(--denim-dark) !important;
            color: var(--white) !important; font-weight: 700;
        }
        tr.total-row td.td-zero { color: rgba(255,255,255,0.4) !important; }

        /* ── PAGINATION ── */
        .pagination-bar {
            padding: 1rem 1.5rem; border-top: 1px solid var(--gray-100);
            display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
        }
        .pagination-info { font-size: 0.82rem; color: var(--gray-600); }
        .pagination-controls { display: flex; gap: 4px; }
        .pg-btn {
            min-width: 32px; height: 32px; padding: 0 8px;
            border: 1.5px solid var(--gray-200); border-radius: 7px;
            background: var(--white); color: var(--gray-800);
            font-family: 'DM Sans', sans-serif; font-size: 0.82rem;
            cursor: pointer; transition: all 0.15s;
            display: flex; align-items: center; justify-content: center;
        }
        .pg-btn:hover:not(:disabled) { border-color: var(--denim); color: var(--denim); }
        .pg-btn.active { background: var(--denim); color: var(--white); border-color: var(--denim); font-weight: 700; }
        .pg-btn:disabled { opacity: 0.4; cursor: not-allowed; }

        /* ── MISC ── */
        .empty-state { padding: 3rem; text-align: center; color: var(--gray-400); }
        .empty-state .empty-icon { font-size: 3rem; margin-bottom: 0.75rem; }
        .empty-state p { font-size: 0.9rem; }
        .loading-overlay {
            position: fixed; inset: 0; background: rgba(15,47,82,0.45);
            display: flex; align-items: center; justify-content: center;
            z-index: 9999; opacity: 0; pointer-events: none; transition: opacity 0.2s;
        }
        .loading-overlay.show { opacity: 1; pointer-events: all; }
        .loading-box {
            background: var(--white); border-radius: 14px;
            padding: 2rem 2.5rem; text-align: center; box-shadow: var(--shadow-md);
        }
        .spinner {
            width: 40px; height: 40px; margin: 0 auto 1rem;
            border: 3px solid var(--denim-light); border-top-color: var(--denim);
            border-radius: 50%; animation: spin 0.8s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .toast {
            position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9000;
            background: var(--white); border-radius: 10px; box-shadow: var(--shadow-md);
            padding: 0.85rem 1.25rem; display: flex; align-items: center; gap: 10px;
            min-width: 280px; max-width: 420px;
            opacity: 0; transform: translateY(12px);
            transition: opacity 0.25s, transform 0.25s; pointer-events: none;
        }
        .toast.show { opacity: 1; transform: translateY(0); pointer-events: all; }
        .toast.success { border-left: 4px solid var(--success); }
        .toast.error   { border-left: 4px solid var(--danger);  }
        .toast.info    { border-left: 4px solid var(--denim);   }
        #toastMsg { font-size: 0.88rem; color: var(--gray-800); }
    </style>
</head>
<body>


<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-box">
        <div class="spinner"></div>
        <p style="color:var(--denim-dark);font-weight:600;font-size:0.9rem">Đang tải dữ liệu...</p>
    </div>
</div>
<div class="toast" id="toast">
    <span id="toastIcon"></span><span id="toastMsg"></span>
</div>

<div class="page-wrapper">
    <!-- Header -->
    <div class="page-header">
        <h1>🔍 Defect Report — Báo Cáo Tỷ Lệ Lỗi & Tỷ Lệ Đạt</h1>
        <p>Phân tích tỷ lệ lỗi, tỷ lệ đạt theo công đoạn, lớp phủ và mã sản phẩm. Dữ liệu từ bảng sản xuất SVN.</p>
        <div class="header-line"></div>
    </div>

    <!-- Filter -->
    <div class="filter-card">
        <div class="filter-header" onclick="toggleFilter()">
            <h3>🔎 Bộ lọc dữ liệu / Filters</h3>
            <span class="filter-toggle" id="filterToggle">▼</span>
        </div>
        <div class="filter-body" id="filterBody">
            <div class="filter-grid">
                <div class="filter-group">
                    <label>📅 Từ ngày</label>
                    <input type="date" id="fDateFrom" />
                </div>
                <div class="filter-group">
                    <label>📅 Đến ngày</label>
                    <input type="date" id="fDateTo" />
                </div>
                <div class="filter-group">
                    <label>⚙️ Công đoạn / Process</label>
                    <select id="fProcess"><option value="">-- Tất cả --</option></select>
                </div>
                <div class="filter-group">
                    <label>🎨 Lớp phủ / Coating</label>
                    <select id="fColor"><option value="">-- Tất cả --</option></select>
                </div>
                <div class="filter-group">
                    <label>🔩 Mã sản phẩm</label>
                    <select id="fProduct"><option value="">-- Tất cả --</option></select>
                </div>
                <div class="filter-group filter-btn-group">
                    <label>&nbsp;</label>
                    <div class="filter-actions">
                        <button class="btn btn-outline" onclick="resetFilters()">↺ Reset</button>
                        <button class="btn btn-primary" id="btnApply" onclick="loadData()">▶ Áp dụng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon blue">📦</div>
            <div class="kpi-body">
                <div class="kpi-label">Tổng SL đầu vào</div>
                <div class="kpi-value" id="kpiInput">—</div>
                <div class="kpi-sub">Total Input Quantity</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon red">❌</div>
            <div class="kpi-body">
                <div class="kpi-label">Tổng SL lỗi (NG)</div>
                <div class="kpi-value red" id="kpiNG">—</div>
                <div class="kpi-sub">Total NG Quantity</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon orange">📉</div>
            <div class="kpi-body">
                <div class="kpi-label">Tỷ lệ lỗi</div>
                <div class="kpi-value red" id="kpiDefRate">—</div>
                <div class="kpi-sub">Overall Defect Rate</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon green">✅</div>
            <div class="kpi-body">
                <div class="kpi-label">Tỷ lệ đạt</div>
                <div class="kpi-value green" id="kpiYield">—</div>
                <div class="kpi-sub">Overall Yield Rate</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-grid">
        <div class="chart-card">
            <div class="chart-card-header">
                <h3>📈 Xu hướng tỷ lệ lỗi theo ngày &nbsp;<small style="opacity:0.7;font-weight:400">(Defect Rate Trend)</small></h3>
            </div>
            <div class="chart-body">
                <div style="position:relative;height:230px"><canvas id="chartTrend"></canvas></div>
            </div>
        </div>
        <div class="chart-card">
            <div class="chart-card-header">
                <h3>🔝 Top loại lỗi &nbsp;<small style="opacity:0.7;font-weight:400">(Top Defect Types)</small></h3>
            </div>
            <div class="chart-body">
                <div style="position:relative;height:230px"><canvas id="chartDefects"></canvas></div>
            </div>
        </div>
        <div class="chart-card">
            <div class="chart-card-header">
                <h3>⚙️ Tỷ lệ lỗi theo công đoạn</h3>
            </div>
            <div class="chart-body">
                <div style="position:relative;height:230px"><canvas id="chartProcess"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="table-card">
        <div class="table-card-header">
            <h3>
                📋 Chi tiết tỷ lệ lỗi theo sản phẩm &amp; công đoạn
                <span class="badge" id="rowBadge">0 dòng</span>
            </h3>
            <button class="btn btn-success btn-sm" id="btnExcel" onclick="exportExcel()" disabled>
                📥 Export Excel
            </button>
        </div>
        <div class="table-scroll" id="tableScroll">
            <div class="empty-state">
                <div class="empty-icon">📊</div>
                <p>Chọn bộ lọc và nhấn <strong>Áp dụng</strong> để tải dữ liệu.</p>
            </div>
        </div>
        <div class="pagination-bar" id="paginationBar" style="display:none">
            <div class="pagination-info" id="pgInfo"></div>
            <div class="pagination-controls" id="pgControls"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const pathBase = '@Context.Request.PathBase'.replace(/\/$/, '');

    let allRows     = [];
    let defectTypes = [];
    let currentPage = 1;
    const PAGE_SIZE = 25;
    let chartTrend = null, chartDefects = null, chartProcess = null;

    // ── Init ──────────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        const today = new Date();
        const from  = new Date(today); from.setDate(today.getDate() - 30);
        document.getElementById('fDateTo').value   = fmtDate(today);
        document.getElementById('fDateFrom').value = fmtDate(from);
        loadFilters();
        loadData();
    });

    function fmtDate(d) { return d.toISOString().split('T')[0]; }

    async function loadFilters() {
        try {
            const [pr, cr] = await Promise.all([
                fetch(`${pathBase}/Production/GetProcesses`),
                fetch(`${pathBase}/Production/GetColors`)
            ]);
            const processes = await pr.json();
            const colors    = await cr.json();

            const ps = document.getElementById('fProcess');
            processes.forEach(p => { if (p) ps.insertAdjacentHTML('beforeend', `<option value="${esc(p)}">${esc(p)}</option>`); });

            const cs = document.getElementById('fColor');
            colors.forEach(c => { if (c) cs.insertAdjacentHTML('beforeend', `<option value="${esc(c)}">${esc(c)}</option>`); });
        } catch(e) { console.error('loadFilters', e); }
    }

    // ── Load Data ─────────────────────────────────────────────────────────────
    async function loadData() {
        const params = new URLSearchParams();
        const df  = document.getElementById('fDateFrom').value;
        const dt  = document.getElementById('fDateTo').value;
        const pr  = document.getElementById('fProcess').value;
        const cl  = document.getElementById('fColor').value;
        const pid = document.getElementById('fProduct').value;
        if (df)  params.append('dateFrom',  df);
        if (dt)  params.append('dateTo',    dt);
        if (pr)  params.append('process',   pr);
        if (cl)  params.append('color',     cl);
        if (pid) params.append('productId', pid);

        showLoading(true);
        document.getElementById('btnApply').disabled  = true;
        document.getElementById('btnExcel').disabled  = true;

        try {
            const res  = await fetch(`${pathBase}/Production/GetDefectReportData?` + params);
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();

            allRows     = data.rows        || [];
            defectTypes = data.defectTypes || [];
            currentPage = 1;

            renderKPI();
            renderCharts();
            renderTable();
            populateProductFilter();

            document.getElementById('btnExcel').disabled = !allRows.length;
            showToast(`Tải xong ${allRows.length} dòng.`, 'success');
        } catch(e) {
            console.error('loadData', e);
            showToast('Lỗi: ' + e.message, 'error');
        } finally {
            showLoading(false);
            document.getElementById('btnApply').disabled = false;
        }
    }

    function populateProductFilter() {
        const sel = document.getElementById('fProduct');
        const cur = sel.value;
        while (sel.options.length > 1) sel.remove(1);
        const seen = new Map();
        allRows.forEach(r => {
            if (r.productId != null && !seen.has(r.productId))
                seen.set(r.productId, r.partCode || String(r.productId));
        });
        seen.forEach((lbl, v) => sel.insertAdjacentHTML('beforeend',
            `<option value="${v}">${esc(lbl)}</option>`));
        if (cur) sel.value = cur;
    }

    // ── KPI ───────────────────────────────────────────────────────────────────
    function renderKPI() {
        if (!allRows.length) {
            ['kpiInput','kpiNG','kpiDefRate','kpiYield'].forEach(id => document.getElementById(id).textContent = '—');
            return;
        }
        const totIn = allRows.reduce((s,r) => s + (r.inputQty||0), 0);
        const totNG = allRows.reduce((s,r) => s + (r.ngQty   ||0), 0);
        const totOK = allRows.reduce((s,r) => s + (r.okQty   ||0), 0);
        const dr    = totIn > 0 ? (totNG / totIn * 100) : 0;
        const yr    = totIn > 0 ? (totOK / totIn * 100) : 100;
        document.getElementById('kpiInput').textContent   = fmt(totIn);
        document.getElementById('kpiNG').textContent      = fmt(totNG);
        document.getElementById('kpiDefRate').textContent = dr.toFixed(1) + '%';
        document.getElementById('kpiYield').textContent   = yr.toFixed(1) + '%';
    }

    // ── Charts ────────────────────────────────────────────────────────────────
    function renderCharts() {
        // 1. Trend by date
        const byDate = {};
        allRows.forEach(r => {
            if (!byDate[r.date]) byDate[r.date] = { ng:0, input:0 };
            byDate[r.date].ng    += r.ngQty    || 0;
            byDate[r.date].input += r.inputQty || 0;
        });
        const dates = Object.keys(byDate).sort();
        const rates = dates.map(d => byDate[d].input > 0 ? +(byDate[d].ng/byDate[d].input*100).toFixed(1) : 0);

        const ctx1 = document.getElementById('chartTrend').getContext('2d');
        if (chartTrend) chartTrend.destroy();
        chartTrend = new Chart(ctx1, {
            type: 'line',
            data: {
                labels: dates,
                datasets: [{
                    label: 'Defect Rate (%)',
                    data: rates,
                    borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.08)',
                    borderWidth: 2.5, pointRadius: 4, pointBackgroundColor: '#ef4444',
                    tension: 0.35, fill: true
                }]
            },
            options: {
                responsive:true, maintainAspectRatio:false,
                plugins:{ legend:{display:false} },
                scales:{
                    x:{ ticks:{font:{size:10},maxRotation:45}, grid:{display:false} },
                    y:{ ticks:{callback:v=>v+'%',font:{size:10}}, beginAtZero:true }
                }
            }
        });

        // 2. Top defect types (doughnut)
        const defTot = {};
        allRows.forEach(r => { if (r.defects) Object.entries(r.defects).forEach(([k,v]) => { defTot[k]=(defTot[k]||0)+v; }); });
        const defSorted = Object.entries(defTot).sort((a,b)=>b[1]-a[1]).slice(0,10);
        const PALETTE = ['#ef4444','#f97316','#eab308','#22c55e','#06b6d4','#6366f1','#ec4899','#14b8a6','#f59e0b','#a855f7'];
        const ctx2 = document.getElementById('chartDefects').getContext('2d');
        if (chartDefects) chartDefects.destroy();
        chartDefects = new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: defSorted.map(x=>x[0]),
                datasets: [{ data: defSorted.map(x=>x[1]), backgroundColor: PALETTE, borderWidth:2, borderColor:'#fff' }]
            },
            options: {
                responsive:true, maintainAspectRatio:false,
                plugins:{ legend:{ position:'right', labels:{font:{size:10},boxWidth:12} } }
            }
        });

        // 3. Defect rate by process (horizontal bar)
        const byProc = {};
        allRows.forEach(r => {
            const p = r.process || '(unknown)';
            if (!byProc[p]) byProc[p] = {ng:0,input:0};
            byProc[p].ng    += r.ngQty    || 0;
            byProc[p].input += r.inputQty || 0;
        });
        const procSorted = Object.entries(byProc)
            .map(([k,v]) => ({ k, rate: v.input > 0 ? +(v.ng/v.input*100).toFixed(1) : 0 }))
            .sort((a,b) => b.rate - a.rate).slice(0, 8);

        const ctx3 = document.getElementById('chartProcess').getContext('2d');
        if (chartProcess) chartProcess.destroy();
        chartProcess = new Chart(ctx3, {
            type: 'bar',
            data: {
                labels: procSorted.map(x=>x.k),
                datasets: [{
                    label: 'Defect Rate (%)',
                    data: procSorted.map(x=>x.rate),
                    backgroundColor: procSorted.map(x =>
                        x.rate>=10 ? 'rgba(239,68,68,0.8)' : x.rate>=5 ? 'rgba(245,158,11,0.8)' : 'rgba(16,185,129,0.8)'
                    ),
                    borderRadius:4, borderSkipped:false
                }]
            },
            options: {
                indexAxis:'y', responsive:true, maintainAspectRatio:false,
                plugins:{legend:{display:false}},
                scales:{
                    x:{ ticks:{callback:v=>v+'%',font:{size:10}}, beginAtZero:true },
                    y:{ ticks:{font:{size:9}} }
                }
            }
        });
    }

    // ── Table ─────────────────────────────────────────────────────────────────
    function renderTable() {
        const wrap  = document.getElementById('tableScroll');
        const pgBar = document.getElementById('paginationBar');
        const badge = document.getElementById('rowBadge');

        badge.textContent = `${allRows.length} dòng`;

        if (!allRows.length) {
            wrap.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><p>Không có dữ liệu trong khoảng thời gian đã chọn.</p></div>`;
            pgBar.style.display = 'none';
            return;
        }
        pgBar.style.display = 'flex';

        const totalPages = Math.ceil(allRows.length / PAGE_SIZE);
        const start      = (currentPage - 1) * PAGE_SIZE;
        const rows       = allRows.slice(start, start + PAGE_SIZE);

        // Header
        let html = `<table class="defect-table"><thead><tr>
            <th class="th-left" style="min-width:106px">Date<span class="th-sub">Ngày</span></th>
            <th style="min-width:96px">Part Code<span class="th-sub">Mã linh kiện</span></th>
            <th class="th-left" style="min-width:150px">Product<span class="th-sub">Sản phẩm</span></th>
            <th style="min-width:120px">Coating<span class="th-sub">Lớp phủ</span></th>
            <th class="th-left" style="min-width:130px">Process<span class="th-sub">Quy trình</span></th>
            <th style="min-width:84px">Input Qty<span class="th-sub">SL đầu vào</span></th>
            <th style="min-width:78px">OK Qty<span class="th-sub">SL đạt</span></th>
            <th style="min-width:78px">NG Qty<span class="th-sub">SL lỗi</span></th>
            <th style="min-width:84px">Output Qty<span class="th-sub">SL đầu ra</span></th>
            <th style="min-width:88px">Defect Rate<span class="th-sub">Tỷ lệ lỗi</span></th>
            <th style="min-width:88px">Yield Rate<span class="th-sub">Tỷ lệ đạt</span></th>`;
        defectTypes.forEach((dt, i) => {
            html += `<th class="th-defect${i===0?' th-defect-first':''}" style="min-width:88px">${esc(dt)}</th>`;
        });
        html += `</tr></thead><tbody>`;

        // Rows
        let totIn=0, totOK=0, totNG=0;
        const totDef = {};
        defectTypes.forEach(dt => { totDef[dt] = 0; });

        rows.forEach(r => {
            totIn += r.inputQty  || 0;
            totOK += r.okQty     || 0;
            totNG += r.ngQty     || 0;

            const rCls = r.defectRate >= 10 ? 'rate-bad' : r.defectRate >= 5 ? 'rate-mid' : 'rate-ok';
            const yCls = r.yieldRate  <= 90 ? 'rate-bad' : r.yieldRate  <= 95 ? 'rate-mid' : 'rate-ok';

            html += `<tr>
                <td style="color:var(--gray-600);font-size:0.8rem">${esc(r.date||'')}</td>
                <td class="td-center" style="font-weight:700;color:var(--denim)">${esc(r.partCode||'—')}</td>
                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;color:var(--gray-800)" title="${esc(r.product||'')}">${esc(r.product||'—')}</td>
                <td class="td-center">${colorBadge(r.coating)}</td>
                <td style="color:var(--gray-700)">${esc(r.process||'—')}</td>
                <td class="${r.inputQty>0?'td-num':'td-zero'}">${fmt(r.inputQty)}</td>
                <td class="${r.okQty>0?'td-num':'td-zero'}" style="color:${r.okQty>0?'var(--success)':''}">${fmt(r.okQty)}</td>
                <td class="${r.ngQty>0?'td-num':'td-zero'}" style="color:${r.ngQty>0?'var(--danger)':''}">${fmt(r.ngQty)}</td>
                <td class="${r.outputQty>0?'td-num':'td-zero'}">${fmt(r.outputQty)}</td>
                <td class="td-center"><span class="rate-badge ${rCls}">${(r.defectRate??0).toFixed(1)}%</span></td>
                <td class="td-center"><span class="rate-badge ${yCls}">${(r.yieldRate??100).toFixed(1)}%</span></td>`;

            defectTypes.forEach((dt, i) => {
                const v = r.defects ? (r.defects[dt]||0) : 0;
                totDef[dt] = (totDef[dt]||0) + v;
                html += `<td class="td-defect${i===0?' td-defect-first':''}${v>0?' td-defect-nz':''}">${v>0?fmt(v):'<span style="color:var(--gray-200)">—</span>'}</td>`;
            });
            html += `</tr>`;
        });

        // Total row
        const totDR = totIn > 0 ? (totNG/totIn*100).toFixed(1) : '0.0';
        const totYR = totIn > 0 ? (totOK/totIn*100).toFixed(1) : '100.0';
        html += `<tr class="total-row">
            <td colspan="5" style="text-align:left;padding-left:16px;letter-spacing:0.3px">
                📊 TOTAL — trang ${currentPage}/${Math.ceil(allRows.length/PAGE_SIZE)} &nbsp;|&nbsp; ${allRows.length} dòng
            </td>
            <td style="text-align:right">${fmt(totIn)}</td>
            <td style="text-align:right">${fmt(totOK)}</td>
            <td style="text-align:right">${fmt(totNG)}</td>
            <td style="text-align:right">${fmt(totOK)}</td>
            <td style="text-align:center">${totDR}%</td>
            <td style="text-align:center">${totYR}%</td>`;
        defectTypes.forEach((dt,i) => {
            const v = totDef[dt]||0;
            html += `<td class="${i===0?'td-defect-first':''}" style="text-align:right${v===0?';color:rgba(255,255,255,0.35)':''}">${v>0?fmt(v):'—'}</td>`;
        });
        html += `</tr></tbody></table>`;

        wrap.innerHTML = html;
        renderPagination(allRows.length, totalPages);
    }

    function renderPagination(total, totalPages) {
        const s = (currentPage-1)*PAGE_SIZE+1;
        const e = Math.min(currentPage*PAGE_SIZE, total);
        document.getElementById('pgInfo').textContent = `Hiển thị ${s}–${e} / ${total} dòng`;

        const ctrl = document.getElementById('pgControls');
        ctrl.innerHTML = '';
        const add = (lbl, pg, dis, act) => {
            const b = document.createElement('button');
            b.className = 'pg-btn' + (act?' active':'');
            b.textContent = lbl; b.disabled = dis;
            b.onclick = () => { currentPage = pg; renderTable(); };
            ctrl.appendChild(b);
        };
        add('«', 1, currentPage===1, false);
        add('‹', currentPage-1, currentPage===1, false);
        const lo = Math.max(1, currentPage-2), hi = Math.min(totalPages, currentPage+2);
        for (let p=lo; p<=hi; p++) add(p, p, false, p===currentPage);
        add('›', currentPage+1, currentPage===totalPages, false);
        add('»', totalPages,    currentPage===totalPages, false);
    }

    // ── Color badge ───────────────────────────────────────────────────────────
    function colorBadge(c) {
        if (!c || c==='-') return `<span class="color-tag color-none">—</span>`;
        const l = c.toLowerCase();
        if (l.includes('matt')||l.includes('black'))  return `<span class="color-tag color-matte">${esc(c)}</span>`;
        if (l.includes('chrome'))                     return `<span class="color-tag color-chrome">${esc(c)}</span>`;
        if (l.includes('brass'))                      return `<span class="color-tag color-brass">${esc(c)}</span>`;
        if (l.includes('beige'))                      return `<span class="color-tag color-beige">${esc(c)}</span>`;
        return `<span class="color-tag color-other">${esc(c)}</span>`;
    }

    // ── Export Excel ──────────────────────────────────────────────────────────
    function exportExcel() {
        if (!allRows.length) { showToast('Không có dữ liệu.', 'error'); return; }

        const df = document.getElementById('fDateFrom').value || 'all';
        const dt = document.getElementById('fDateTo').value   || fmtDate(new Date());
        const wb = XLSX.utils.book_new();

        // ─ Sheet 1: Detail
        const hdr = [
            'Date / Ngày','Part Code / Mã linh kiện','Product / Sản phẩm',
            'Coating / Lớp phủ','Process / Công đoạn',
            'Input Qty / SL đầu vào','OK Qty / SL đạt','NG Qty / SL lỗi',
            'Output Qty / SL đầu ra','Defect Rate / Tỷ lệ lỗi','Yield Rate / Tỷ lệ đạt',
            ...defectTypes
        ];
        const aoa = [];
        aoa.push([`DEFECT REPORT — BÁO CÁO TỶ LỆ LỖI & TỶ LỆ ĐẠT`]);
        aoa.push([`Kỳ: ${df}  →  ${dt}   |   Xuất lúc: ${new Date().toLocaleString('vi-VN')}`]);
        aoa.push([]);
        aoa.push(hdr);
        allRows.forEach(r => aoa.push([
            r.date, r.partCode||'', r.product||'', r.coating||'-', r.process||'',
            r.inputQty||0, r.okQty||0, r.ngQty||0, r.outputQty||0,
            r.inputQty>0 ? r.defectRate/100 : 0,
            r.inputQty>0 ? r.yieldRate /100 : 1,
            ...defectTypes.map(dt2 => r.defects ? (r.defects[dt2]||0) : 0)
        ]));
        // Total
        const tI = allRows.reduce((s,r)=>s+(r.inputQty||0),0);
        const tO = allRows.reduce((s,r)=>s+(r.okQty   ||0),0);
        const tN = allRows.reduce((s,r)=>s+(r.ngQty   ||0),0);
        aoa.push(['TOTAL',`${allRows.length} dòng`,'','','',tI,tO,tN,tO,
            tI>0?tN/tI:0, tI>0?tO/tI:1,
            ...defectTypes.map(dt2=>allRows.reduce((s,r)=>s+(r.defects?r.defects[dt2]||0:0),0))
        ]);
        const ws1 = XLSX.utils.aoa_to_sheet(aoa);
        ws1['!cols'] = [
            {wch:14},{wch:14},{wch:24},{wch:16},{wch:20},
            {wch:12},{wch:10},{wch:10},{wch:12},{wch:16},{wch:16},
            ...defectTypes.map(()=>({wch:14}))
        ];
        // Format % columns (col J=index9, K=index10, 0-based header at row 4 → data starts row 5)
        for (let ri=4; ri<4+allRows.length+2; ri++) {
            ['J','K'].forEach(col => {
                const ref = col + (ri+1);
                if (ws1[ref]) ws1[ref].z = '0.0%';
            });
        }
        XLSX.utils.book_append_sheet(wb, ws1, 'Defect Report');

        // ─ Sheet 2: Summary
        const defTot={};
        allRows.forEach(r=>{if(r.defects)Object.entries(r.defects).forEach(([k,v])=>{defTot[k]=(defTot[k]||0)+v;});});
        const byProc2={};
        allRows.forEach(r=>{const p=r.process||'?';if(!byProc2[p])byProc2[p]={ng:0,input:0};byProc2[p].ng+=r.ngQty||0;byProc2[p].input+=r.inputQty||0;});
        const sumAoa=[
            ['DEFECT REPORT — SUMMARY'],
            [`Kỳ: ${df} → ${dt}`],[],
            ['KPI',''],
            ['Total Input Qty', tI],['Total OK Qty', tO],['Total NG Qty', tN],
            ['Overall Defect Rate', tI>0?tN/tI:0],['Overall Yield Rate', tI>0?tO/tI:1],
            [],[`TOP DEFECT TYPES (${Object.keys(defTot).length} loại)`,''],
            ['Defect Type','Total Qty'],
            ...Object.entries(defTot).sort((a,b)=>b[1]-a[1]).map(([k,v])=>[k,v]),
            [],['DEFECT RATE BY PROCESS','','',''],
            ['Process','Input Qty','NG Qty','Defect Rate'],
            ...Object.entries(byProc2).sort((a,b)=>b[1].ng-a[1].ng).map(([k,v])=>[k,v.input,v.ng,v.input>0?v.ng/v.input:0])
        ];
        const ws2 = XLSX.utils.aoa_to_sheet(sumAoa);
        ws2['!cols'] = [{wch:30},{wch:16},{wch:14},{wch:16}];
        XLSX.utils.book_append_sheet(wb, ws2, 'Summary');

        const stamp = new Date().toISOString().slice(0,10);
        XLSX.writeFile(wb, `DefectReport_${df}_to_${dt}_${stamp}.xlsx`);
        showToast(`Đã xuất ${allRows.length} dòng ra Excel.`, 'success');
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function toggleFilter() {
        const b = document.getElementById('filterBody');
        const t = document.getElementById('filterToggle');
        b.classList.toggle('collapsed');
        t.classList.toggle('collapsed', b.classList.contains('collapsed'));
    }
    function resetFilters() {
        const today = new Date(), from = new Date(today);
        from.setDate(today.getDate()-30);
        document.getElementById('fDateFrom').value = fmtDate(from);
        document.getElementById('fDateTo').value   = fmtDate(today);
        ['fProcess','fColor','fProduct'].forEach(id => document.getElementById(id).value = '');
        loadData();
    }
    function fmt(n) { return n==null||n===0 ? '0' : Number(n).toLocaleString('en-US'); }
    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function showLoading(v) { document.getElementById('loadingOverlay').classList.toggle('show',v); }
    function showToast(msg, type='info') {
        const el = document.getElementById('toast');
        el.className = 'toast ' + type;
        document.getElementById('toastIcon').textContent = type==='success'?'✅':type==='error'?'❌':'ℹ️';
        document.getElementById('toastMsg').textContent  = msg;
        el.classList.add('show');
        setTimeout(()=>el.classList.remove('show'), 3500);
    }
</script>
}
</body>
</html>
